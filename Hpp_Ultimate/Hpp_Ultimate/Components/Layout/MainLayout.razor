@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject SeededBusinessDataStore Store

<div class="shell-background">
    <div class="ambient ambient-a"></div>
    <div class="ambient ambient-b"></div>
    <div class="ambient ambient-c"></div>
</div>

@if (IsLoginPage)
{
    <div class="auth-shell">
        <div class="auth-shell-brand">
            <a href="/login" class="auth-shell-link">
                <span class="auth-shell-mark">+</span>
                <span>
                    <strong>HPP Ultimate</strong>
                    <small>Workspace operasional.</small>
                </span>
            </a>
        </div>

        <main class="auth-main modern-ui-scope">
            @Body
        </main>
    </div>
}
else
{
    <div class="app-shell">
        <aside class="app-sidebar modern-nav-scope">
            <NavMenu />
        </aside>

        <main class="app-main modern-ui-scope">
            <header class="app-topbar">
                <div class="topbar-context">
                    <span class="topbar-label">Area kerja</span>
                    <strong>@CurrentSection</strong>
                </div>
            </header>

            <article class="app-content">
                @Body
            </article>
        </main>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    <div class="blazor-error-copy">
        <strong>Sesi aplikasi terganggu</strong>
        <span>Terjadi error yang belum tertangani. Muat ulang halaman untuk melanjutkan pekerjaan.</span>
    </div>
    <div class="blazor-error-actions">
        <a href="." class="reload">Muat ulang</a>
        <button type="button" class="dismiss" aria-label="Tutup pesan error">Tutup</button>
    </div>
</div>

@code {
    private bool IsLoginPage => CurrentPath.Equals("login", StringComparison.OrdinalIgnoreCase);
    private bool RequiresAuthenticatedSession => !IsLoginPage;

    private string CurrentPath
    {
        get
        {
            var path = Navigation.ToBaseRelativePath(Navigation.Uri);
            return string.IsNullOrWhiteSpace(path) ? "/" : path.Trim('/');
        }
    }

    private string CurrentSection => CurrentPath switch
    {
        "/" => "Dashboard",
        "produk" => "Katalog Material",
        "gudang" => "Stok Gudang",
        "produksi" => "Produksi",
        "belanja" => "Pembelian Material",
        "pembukuan" => "Pembukuan",
        "resep" => "Resep",
        "pos" => "Kasir / POS",
        "backup-data" => "Backup & Impor Data",
        "pengaturan" => "Pengaturan Bisnis",
        "pengaturan/akun" => "Tim & Akun",
        "login" => "Login",
        _ => "HPP Ultimate"
    };

    protected override void OnParametersSet()
    {
        if (RequiresAuthenticatedSession && Store.AuthSession is null)
        {
            Navigation.NavigateTo("/login", replace: true);
        }
    }
}
