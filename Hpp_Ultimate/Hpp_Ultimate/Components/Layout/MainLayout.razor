@inherits LayoutComponentBase
@inject NavigationManager Navigation

<div class="shell-background">
    <div class="ambient ambient-a"></div>
    <div class="ambient ambient-b"></div>
    <div class="ambient ambient-c"></div>
</div>

@if (IsLoginPage)
{
    <div class="auth-shell">
        <div class="auth-shell-brand">
            <a href="/login" class="auth-shell-link">
                <span class="auth-shell-mark">+</span>
                <span>
                    <strong>HPP Ultimate</strong>
                    <small>Material catalog workspace.</small>
                </span>
            </a>
        </div>

        <main class="auth-main">
            @Body
        </main>
    </div>
}
else
{
    <div class="app-shell">
        <aside class="app-sidebar">
            <NavMenu />
        </aside>

        <main class="app-main">
            <header class="app-topbar">
                <div class="topbar-copy">
                    <span class="topbar-label">@CurrentSection</span>
                    <strong>@CurrentHeadline</strong>
                </div>
            </header>

            <article class="app-content">
                @Body
            </article>
        </main>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

@code {
    private bool IsLoginPage => CurrentPath.Equals("login", StringComparison.OrdinalIgnoreCase);

    private string CurrentPath
    {
        get
        {
            var path = Navigation.ToBaseRelativePath(Navigation.Uri);
            return string.IsNullOrWhiteSpace(path) ? "/" : path.Trim('/');
        }
    }

    private string CurrentSection => CurrentPath switch
    {
        "/" => "Login",
        "produk" => "Katalog Material",
        "resep" => "Resep",
        "hpp-calculator" => "HPP Calculator",
        "pengaturan" => "Pengaturan",
        "pengaturan/akun" => "Pengaturan Akun",
        "login" => "Login",
        _ => "HPP Ultimate"
    };

    private string CurrentHeadline => CurrentPath switch
    {
        "/" or "login" => "Masuk ke workspace material",
        "produk" => "Kelola bahan baku, harga, dan konversi unit",
        "resep" => "Rancang formula bahan, kelompok material, dan biaya produksi",
        "hpp-calculator" => "Tarik resep aktif, breakdown biaya, dan tentukan HPP final",
        "pengaturan" => "Atur preferensi dasar bisnis dan jalur akun",
        "pengaturan/akun" => "Kelola identitas, keamanan, akses, dan data tim",
        _ => "Halaman ini tidak tersedia di workspace aktif"
    };
}
