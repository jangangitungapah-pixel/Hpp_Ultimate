@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject SeededBusinessDataStore Store

<div class="shell-background">
    <div class="ambient ambient-a"></div>
    <div class="ambient ambient-b"></div>
    <div class="ambient ambient-c"></div>
</div>

@if (IsLoginPage)
{
    <div class="auth-shell">
        <div class="auth-shell-brand">
            <a href="/login" class="auth-shell-link">
                <span class="auth-shell-mark">+</span>
                <span>
                    <strong>HPP Ultimate</strong>
                    <small>Operational workspace.</small>
                </span>
            </a>
        </div>

        <main class="auth-main">
            @Body
        </main>
    </div>
}
else
{
    <div class="app-shell">
        <aside class="app-sidebar">
            <NavMenu />
        </aside>

        <main class="app-main">
            <header class="app-topbar">
                <div class="topbar-copy">
                    <span class="topbar-label">@CurrentSection</span>
                    <strong>@CurrentHeadline</strong>
                </div>

                <div class="topbar-tools">
                    <label class="topbar-search">
                        <span class="search-glyph">&#9906;</span>
                        <input value="@TopbarUserLabel" readonly aria-label="Current user" />
                    </label>

                    <div class="topbar-avatar" aria-hidden="true">@CurrentUserInitials</div>
                </div>
            </header>

            <article class="app-content">
                @Body
            </article>
        </main>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

@code {
    private bool IsLoginPage => CurrentPath.Equals("login", StringComparison.OrdinalIgnoreCase);
    private bool RequiresAuthenticatedSession => !IsLoginPage;

    private string CurrentPath
    {
        get
        {
            var path = Navigation.ToBaseRelativePath(Navigation.Uri);
            return string.IsNullOrWhiteSpace(path) ? "/" : path.Trim('/');
        }
    }

    private string CurrentSection => CurrentPath switch
    {
        "/" => "Login",
        "produk" => "Katalog Material",
        "gudang" => "Gudang",
        "produksi" => "Produksi",
        "belanja" => "Belanja",
        "pembukuan" => "Pembukuan",
        "resep" => "Resep",
        "pos" => "Point of Sales",
        "backup-data" => "Backup & Data Ops",
        "pengaturan" => "Pengaturan",
        "pengaturan/akun" => "Pengaturan Akun",
        "login" => "Login",
        _ => "HPP Ultimate"
    };

    private string CurrentHeadline => CurrentPath switch
    {
        "/" or "login" => "Masuk ke workspace operasional",
        "produk" => "Kelola bahan baku, harga, dan konversi unit",
        "gudang" => "Catat saldo bahan, minimum stock, dan mutasi gudang",
        "produksi" => "Eksekusi batch produksi dan konsumsi bahan baku",
        "belanja" => "Catat belanja material, penerimaan barang, dan masuk stok gudang",
        "pembukuan" => "Gabungkan pemasukan, pengeluaran, dan saldo berjalan ke satu ledger",
        "resep" => "Rancang formula bahan, kelompok material, dan biaya produksi",
        "pos" => "Layani checkout persisten dan kurangi stok produk jadi secara otomatis",
        "backup-data" => "Backup penuh, restore, export, dan import data operasional",
        "pengaturan" => "Atur preferensi dasar bisnis dan jalur akun",
        "pengaturan/akun" => "Kelola identitas, keamanan, akses, dan data tim",
        _ => "Halaman ini tidak tersedia di workspace aktif"
    };

    private string TopbarUserLabel => Store.AuthSession?.FullName ?? "Search workspace";

    private string CurrentUserInitials
    {
        get
        {
            var name = Store.AuthSession?.FullName;
            if (string.IsNullOrWhiteSpace(name))
            {
                return "HU";
            }

            var parts = name
                .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Take(2)
                .Select(part => char.ToUpperInvariant(part[0]));

            return string.Concat(parts);
        }
    }

    protected override void OnParametersSet()
    {
        if (RequiresAuthenticatedSession && Store.AuthSession is null)
        {
            Navigation.NavigateTo("/login", replace: true);
        }
    }
}
