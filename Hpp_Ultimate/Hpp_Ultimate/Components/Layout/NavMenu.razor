@inject SeededBusinessDataStore Store

<div class="nav-shell">
    <div class="nav-head">
        <a class="brand" href="/">
            <span class="brand-mark">
                <span></span>
                <span></span>
                <span></span>
            </span>
            <span class="brand-copy">
                <strong>HPP Ultimate</strong>
                <small>Workspace operasional</small>
            </span>
        </a>

        <label for="nav-toggle" class="nav-toggle-button">
            <span></span>
            <span></span>
            <span></span>
        </label>
    </div>

    <input id="nav-toggle" type="checkbox" title="Navigation menu" class="nav-toggle" />

    <div class="nav-scrollable" onclick="document.getElementById('nav-toggle').checked = false">
        @foreach (var group in VisibleGroups)
        {
            <section class="nav-group">
                <span class="nav-group-label">@group.Label</span>

                @foreach (var item in group.Items)
                {
                    <NavLink class="nav-link" href="@item.Href" Match="@item.Match">
                        <span class="nav-icon">
                            <AppIcon Name="@item.Icon" Class="nav-icon-svg" />
                        </span>
                        <strong>@item.Title</strong>
                    </NavLink>
                }
            </section>
        }

        <div class="nav-footer">
            <div class="nav-user-card">
                <div class="nav-user-avatar">@CurrentUserInitials</div>
                <div class="nav-user-copy">
                    <strong>@(Store.AuthSession?.FullName ?? "Pengguna workspace")</strong>
                    <small>@(Store.AuthSession is null ? "Operator" : FormatRole(Store.AuthSession.Role))</small>
                </div>
            </div>
            <a class="nav-logout" href="/logout">
                <AppIcon Name="logout" Class="nav-logout-icon" />
                <span>Logout</span>
            </a>
        </div>
    </div>
</div>

@code {
    private bool IsAdmin => Store.AuthSession?.Role == UserRole.Admin;

    private static string FormatRole(UserRole role) => role switch
    {
        UserRole.Admin => "Admin",
        UserRole.Staff => "Staf",
        _ => role.ToString()
    };
    private string CurrentUserInitials
    {
        get
        {
            var name = Store.AuthSession?.FullName;
            if (string.IsNullOrWhiteSpace(name))
            {
                return "HU";
            }

            var parts = name
                .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Take(2)
                .Select(part => char.ToUpperInvariant(part[0]));

            return string.Concat(parts);
        }
    }

    private IReadOnlyList<NavGroup> VisibleGroups
        => IsAdmin
            ? AdminGroups
            : StaffGroups;

    private static readonly IReadOnlyList<NavGroup> StaffGroups =
    [
        new("Ringkasan", [
            new("/", "home", "Dashboard", NavLinkMatch.All)
        ]),
        new("Master Data", [
            new("/produk", "materials", "Katalog Material"),
            new("/resep", "recipe", "Resep")
        ]),
        new("Operasional", [
            new("/gudang", "warehouse", "Stok Gudang"),
            new("/belanja", "shopping", "Pembelian Material"),
            new("/produksi", "production", "Produksi"),
            new("/pos", "pos", "Kasir / POS")
        ]),
        new("Keuangan", [
            new("/pembukuan", "bookkeeping", "Pembukuan")
        ]),
        new("Admin", [
            new("/pengaturan", "settings", "Pengaturan Bisnis"),
            new("/pengaturan/akun", "account", "Tim & Akun")
        ])
    ];

    private static readonly IReadOnlyList<NavGroup> AdminGroups =
    [
        new("Ringkasan", [
            new("/", "home", "Dashboard", NavLinkMatch.All)
        ]),
        new("Master Data", [
            new("/produk", "materials", "Katalog Material"),
            new("/resep", "recipe", "Resep")
        ]),
        new("Operasional", [
            new("/gudang", "warehouse", "Stok Gudang"),
            new("/belanja", "shopping", "Pembelian Material"),
            new("/produksi", "production", "Produksi"),
            new("/pos", "pos", "Kasir / POS")
        ]),
        new("Keuangan", [
            new("/pembukuan", "bookkeeping", "Pembukuan")
        ]),
        new("Admin", [
            new("/pengaturan", "settings", "Pengaturan Bisnis"),
            new("/pengaturan/akun", "account", "Tim & Akun"),
            new("/backup-data", "backup", "Backup & Impor Data")
        ])
    ];

    private sealed record NavGroup(string Label, IReadOnlyList<NavItem> Items);
    private sealed record NavItem(string Href, string Icon, string Title, NavLinkMatch Match = NavLinkMatch.Prefix);
}
