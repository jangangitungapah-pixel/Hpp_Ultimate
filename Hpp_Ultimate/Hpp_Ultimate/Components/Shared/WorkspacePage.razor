<section class="workspace-page">
    <div class="workspace-hero">
        <div class="hero-copy">
            <span class="hero-eyebrow">@Eyebrow</span>
            <h1>@Title</h1>
            <p>@Description</p>
        </div>

        <div class="hero-stat">
            <span>@HeroLabel</span>
            <strong>@HeroValue</strong>
            <small>@HeroDetail</small>
        </div>
    </div>

    @if (Metrics.Count > 0)
    {
        <div class="metric-grid">
            @foreach (var metric in Metrics)
            {
                <section class="metric-card">
                    <span>@metric.Label</span>
                    <strong>@metric.Value</strong>
                    <small>@metric.Note</small>
                </section>
            }
        </div>
    }

    @if (Actions.Count > 0)
    {
        <div class="action-strip">
            @foreach (var action in Actions)
            {
                <article class="action-pill">
                    <strong>@action.Label</strong>
                    <small>@action.Detail</small>
                </article>
            }
        </div>
    }

    <div class="workspace-grid">
        <div class="workspace-stack">
            @foreach (var panel in PrimaryPanels)
            {
                <section class="panel-card panel-primary @($"tone-{panel.Tone}")">
                    <div class="panel-head">
                        <div>
                            <span>@panel.Eyebrow</span>
                            <h2>@panel.Title</h2>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(panel.Badge))
                        {
                            <strong class="panel-badge">@panel.Badge</strong>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(panel.Description))
                    {
                        <p>@panel.Description</p>
                    }

                    @if (panel.Points.Count > 0)
                    {
                        <div class="point-list">
                            @foreach (var point in panel.Points.Take(3))
                            {
                                <div class="point-item">
                                    <span class="point-bullet"></span>
                                    <small>@point</small>
                                </div>
                            }
                        </div>
                    }
                </section>
            }
        </div>

        @if (SecondaryPanels.Count > 0)
        {
            <aside class="workspace-side">
                @foreach (var panel in SecondaryPanels)
                {
                    <section class="panel-card side-card">
                        <div class="panel-head">
                            <div>
                                <span>@panel.Eyebrow</span>
                                <h2>@panel.Title</h2>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(panel.Badge))
                            {
                                <strong class="panel-badge">@panel.Badge</strong>
                            }
                        </div>

                        @if (panel.Points.Count > 0)
                        {
                            <div class="point-list compact">
                                @foreach (var point in panel.Points.Take(3))
                                {
                                    <div class="point-item">
                                        <span class="point-bullet"></span>
                                        <small>@point</small>
                                    </div>
                                }
                            </div>
                        }
                    </section>
                }
            </aside>
        }
    </div>
</section>

@code {
    [Parameter, EditorRequired] public string Eyebrow { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Description { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string HeroLabel { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string HeroValue { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string HeroDetail { get; set; } = string.Empty;
    [Parameter] public IReadOnlyList<WorkspaceMetric> Metrics { get; set; } = Array.Empty<WorkspaceMetric>();
    [Parameter] public IReadOnlyList<WorkspaceAction> Actions { get; set; } = Array.Empty<WorkspaceAction>();
    [Parameter] public IReadOnlyList<WorkspacePanel> PrimaryPanels { get; set; } = Array.Empty<WorkspacePanel>();
    [Parameter] public IReadOnlyList<WorkspacePanel> SecondaryPanels { get; set; } = Array.Empty<WorkspacePanel>();
}
