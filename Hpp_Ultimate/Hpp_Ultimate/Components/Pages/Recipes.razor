    private static string GetSuggestedDraftUnit(RawMaterial material)
    {
        var units = RecipeCatalogMath.GetAvailableUnits(material);

        var preferred = units.FirstOrDefault(item =>
            item.Equals(material.NetUnit, StringComparison.OrdinalIgnoreCase));
        if (!string.IsNullOrWhiteSpace(preferred))
        {
            return preferred;
        }

        preferred = units.FirstOrDefault(item =>
            item.Equals(material.BaseUnit, StringComparison.OrdinalIgnoreCase));
        if (!string.IsNullOrWhiteSpace(preferred))
        {
            return preferred;
        }

        return units.FirstOrDefault() ?? material.BaseUnit;
    }

