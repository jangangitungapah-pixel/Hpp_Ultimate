@page "/resep"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject RecipeCatalogService RecipeCatalogService
@inject GeminiRecipeDraftService GeminiRecipeDraftService
@inject GeminiRecipeWeightEstimatorService GeminiRecipeWeightEstimatorService
@inject SeededBusinessDataStore Store

<PageTitle>Resep | HPP Ultimate</PageTitle>

<section class="recipes-page ds-page ds-page-stack theme-indigo">
    <header class="recipes-header ds-page-header">
        <div class="header-copy">
            <span class="section-tag">Resep</span>
            <h1>Resep produksi</h1>
            <p>Susun resep dari katalog aktif, cek detailnya di panel samping, lalu buka editor hanya saat perlu membuat atau mengubah formula.</p>
        </div>

        <div class="header-actions">
            <button type="button" class="primary-button" @onclick="OpenCreateModalAsync">+ Resep Baru</button>
        </div>
    </header>

    <div class="recipes-workspace ds-list-detail">
    <section class="recipes-panel list-panel catalog-datagrid">
        <div class="panel-head ds-card-header">
            <div>
                <span class="section-tag">Daftar resep</span>
                <h2>Resep yang sudah dibuat</h2>
                <p>Pilih satu resep untuk melihat komposisi bahan dan biaya batch tanpa pindah halaman.</p>
            </div>
        </div>

        <div class="table-toolbar">
            <div class="table-toolbar-primary">
                <input class="recipe-search-input" value="@_searchText" @oninput="OnSearchChangedAsync" placeholder="Cari nama resep atau kode" />

                <div class="table-toolbar-filters">
                    <select value="@_recipeDisplayCount" @onchange="OnRecipeDisplayCountChanged">
                        @foreach (var option in GridDisplayOptions)
                        {
                            <option value="@option">@option baris</option>
                        }
                    </select>
                </div>
            </div>
        </div>

        @if (ActiveMaterials.Count == 0)
        {
            <div class="inline-note">
                Katalog material masih kosong. Tambah material dulu di <a href="/produk">Katalog Material</a>.
            </div>
        }

        @if (_isLoading && _result is null)
        {
            <div class="recipe-skeleton"></div>
        }
        else if ((_result?.Items.Count ?? 0) == 0)
        {
            <div class="empty-state">
                <h2>Belum ada resep</h2>
                <p>Buat resep baru untuk mulai menyusun bahan dan biaya batch.</p>
                <button type="button" class="primary-button" @onclick="OpenCreateModalAsync">Buat Resep</button>
            </div>
        }
        else
        {
            <div class="table-shell">
                <table class="recipe-table">
                    <thead>
                        <tr>
                            <th>Resep</th>
                            <th>HPP / Satuan</th>
                            <th>Margin</th>
                            <th>Harga Jual / Satuan</th>
                            <th>Kelompok</th>
                            <th>Material</th>
                            <th>Status</th>
                            <th>Update</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var recipe in VisibleRecipes)
                        {
                            <tr class="@(recipe.Id == _selectedRecipeId ? "active" : null)" @onclick="() => SelectRecipeAsync(recipe.Id)">
                                <td>
                                    <div class="table-primary">
                                        <strong>@recipe.Name</strong>
                                        <small>@recipe.Code</small>
                                    </div>
                                </td>
                                <td>@FormatCurrency(recipe.CostPerPortion)</td>
                                <td>@FormatPercent(recipe.TargetMarginPercent)</td>
                                <td>@FormatCurrency(recipe.SuggestedSellingPrice)</td>
                                <td>@recipe.GroupCount kelompok</td>
                                <td>@recipe.MaterialCount material</td>
                                <td>
                                    <span class="badge @(recipe.Status == RecipeStatus.Active ? "active" : "inactive")">
                                        @(recipe.Status == RecipeStatus.Active ? "Aktif" : "Draft")
                                    </span>
                                </td>
                                <td>@recipe.UpdatedAt.ToString("dd MMM yy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="recipe-card-list">
                @foreach (var recipe in VisibleRecipes)
                {
                    <article class="recipe-card @(recipe.Id == _selectedRecipeId ? "active" : null)" @onclick="() => SelectRecipeAsync(recipe.Id)">
                        <div class="recipe-card-head">
                            <div class="table-primary recipe-card-title">
                                <strong>@recipe.Name</strong>
                                <small>@recipe.Code</small>
                            </div>

                            <span class="badge @(recipe.Status == RecipeStatus.Active ? "active" : "inactive")">
                                @(recipe.Status == RecipeStatus.Active ? "Aktif" : "Draft")
                            </span>
                        </div>

                        <div class="recipe-card-grid">
                            <article>
                                <small>HPP / Satuan</small>
                                <strong>@FormatCurrency(recipe.CostPerPortion)</strong>
                            </article>
                            <article>
                                <small>Harga Jual / Satuan</small>
                                <strong>@FormatCurrency(recipe.SuggestedSellingPrice)</strong>
                            </article>
                            <article>
                                <small>Material</small>
                                <strong>@recipe.MaterialCount material</strong>
                            </article>
                        </div>

                        <div class="recipe-card-footer">
                            <div class="recipe-card-update">
                                <small>Update</small>
                                <strong>@recipe.UpdatedAt.ToString("dd MMM yyyy HH:mm")</strong>
                            </div>

                            <div class="recipe-card-actions" @onclick:stopPropagation="true">
                                <button type="button" class="icon-action-button" title="Edit" aria-label="Edit" @onclick="() => OpenEditModalAsync(recipe.Id)">
                                    <AppIcon Name="edit" Class="icon-glyph" />
                                </button>
                                <button type="button" class="icon-action-button danger" title="Hapus" aria-label="Hapus" @onclick="() => AskDelete(recipe)">
                                    <AppIcon Name="delete" Class="icon-glyph" />
                                </button>
                            </div>
                        </div>
                    </article>
                }
            </div>

            <div class="table-footer">
                <small>@(_result?.TotalCount ?? 0) resep</small>
                <div class="pager">
                    <button type="button" @onclick="PrevRecipePage" disabled="@(CurrentRecipePage <= 1)">Prev</button>
                    <label class="pager-select" aria-label="Pilih halaman resep">
                        <select value="@CurrentRecipePage" @onchange="OnRecipePageChanged">
                            @for (var pageNumber = 1; pageNumber <= RecipeTotalPages; pageNumber++)
                            {
                                <option value="@pageNumber">Halaman @pageNumber</option>
                            }
                        </select>
                    </label>
                    <span>@CurrentRecipePage / @RecipeTotalPages</span>
                    <button type="button" @onclick="NextRecipePage" disabled="@(CurrentRecipePage >= RecipeTotalPages)">Next</button>
                </div>
                <div class="table-footer-spacer" aria-hidden="true"></div>
            </div>
        }
    </section>

    <section class="recipes-panel detail-panel">
        @if (_selectedRecipe is null || _selectedDraft is null)
        {
            <div class="empty-state">
                <h2>Pilih satu resep</h2>
                <p>Pilih resep dari tabel di atas untuk melihat struktur bahan, total batch, dan biaya tambahannya.</p>
            </div>
        }
        else
        {
            var selectedRecipe = _selectedRecipe;
            var selectedDraft = _selectedDraft;
            var selectedEffectivePortionYield = GetEffectivePortionYield(selectedDraft, _selectedWeightEstimate);
            var selectedTotals = RecipeCatalogService.CalculateTotals(selectedDraft, selectedEffectivePortionYield);
            var visibleCosts = selectedDraft.Costs
                .Where(item => !string.IsNullOrWhiteSpace(item.Name) && item.Amount > 0)
                .ToList();

            <div class="detail-header">
                <div class="recipe-title">
                    <span>@selectedRecipe.Code</span>
                    <h2>@selectedRecipe.Name</h2>
                    @if (!string.IsNullOrWhiteSpace(selectedRecipe.Description))
                    {
                        <p>@selectedRecipe.Description</p>
                    }
                </div>

                <div class="detail-actions">
                    <span class="badge @(selectedRecipe.Status == RecipeStatus.Active ? "active" : "inactive")">
                        @(selectedRecipe.Status == RecipeStatus.Active ? "Aktif" : "Draft")
                    </span>
                    <button type="button" class="icon-action-button" title="Edit resep" aria-label="Edit resep" @onclick="() => OpenEditModalAsync(selectedRecipe.Id)">
                        <AppIcon Name="edit" Class="icon-glyph" />
                    </button>
                    <button type="button" class="icon-action-button danger" title="Hapus resep" aria-label="Hapus resep" @onclick="() => AskDelete(selectedRecipe)">
                        <AppIcon Name="delete" Class="icon-glyph" />
                    </button>
                </div>
            </div>

            <div class="detail-summary-strip">
                <article><small>Total Batch</small><strong>@FormatCurrency(selectedTotals.TotalCost)</strong></article>
                <article><small>HPP / Satuan</small><strong>@FormatCurrency(selectedTotals.CostPerPortion)</strong></article>
                <article><small>Harga Jual / Satuan</small><strong>@FormatCurrency(selectedRecipe.SuggestedSellingPrice)</strong></article>
                <article>
                    <small>Porsi / Batch</small>
                    <strong>@GetPortionYieldValueLabel(selectedDraft, _selectedWeightEstimate, selectedEffectivePortionYield)</strong>
                    <span>@GetPortionYieldMetaLabel(selectedDraft, _selectedWeightEstimate, selectedEffectivePortionYield)</span>
                </article>
                <article class="@GetDoughWeightCardClass(_selectedWeightEstimate, _isSelectedWeightLoading)">
                    <small>Total Berat Adonan</small>
                    <strong>@GetDoughWeightValueLabel(_selectedWeightEstimate, _isSelectedWeightLoading)</strong>
                    <span>@GetDoughWeightMetaLabel(_selectedWeightEstimate, _isSelectedWeightLoading)</span>
                </article>
            </div>

            <div class="detail-stack">
                <section class="detail-section">
                    <div class="section-head">
                        <div>
                            <span class="section-tag">Kelompok bahan</span>
                            <h3>Struktur formula resep</h3>
                            <p>Buka kelompok yang diperlukan untuk audit komposisi dan subtotal materialnya.</p>
                        </div>
                    </div>

                    <div class="group-detail-stack">
                        @for (var groupIndex = 0; groupIndex < selectedDraft.Groups.Count; groupIndex++)
                        {
                            var group = selectedDraft.Groups[groupIndex];
                            var groupWeightEstimate = GetGroupDoughWeightEstimate(_selectedWeightEstimate, group);
                            <details class="group-detail-card" open="@(selectedDraft.Groups.Count == 1 || groupIndex == 0)">
                                <summary class="group-detail-summary">
                                    <div class="group-summary-copy">
                                        <small>@group.Materials.Count material</small>
                                        <strong>@group.Name</strong>
                                        @if (!string.IsNullOrWhiteSpace(group.Notes))
                                        {
                                            <span>@group.Notes</span>
                                        }
                                    </div>

                                    <div class="group-summary-totals">
                                        <div class="group-total-stack">
                                            <small>Subtotal</small>
                                            <strong class="group-total">@FormatCurrency(GetGroupTotal(group))</strong>
                                        </div>
                                        <div class="@GetInlineWeightClass(groupWeightEstimate, _isSelectedWeightLoading)">
                                            <small>Berat kelompok</small>
                                            <strong>@GetGroupWeightValueLabel(groupWeightEstimate, _isSelectedWeightLoading)</strong>
                                            <span>@GetGroupWeightMetaLabel(groupWeightEstimate, _isSelectedWeightLoading)</span>
                                        </div>
                                    </div>
                                </summary>

                                @if (group.Materials.Count == 0)
                                {
                                    <div class="empty-mini">Kelompok ini belum memiliki material.</div>
                                }
                                else
                                {
                                    <div class="group-lines-head">
                                        <span>Material</span>
                                        <span>Pemakaian</span>
                                        <span>Konversi</span>
                                        <span>Modal</span>
                                    </div>

                                    <div class="group-lines">
                                        @foreach (var item in group.Materials)
                                        {
                                            var lineWeightEstimate = GetLineDoughWeightEstimate(_selectedWeightEstimate, item);
                                            <div class="line-row">
                                                <div class="line-main">
                                                    <strong>@GetMaterialShortLabel(item)</strong>
                                                    <small>@GetMaterialBrandLabel(item)</small>
                                                </div>
                                                <div class="line-meta">
                                                    <strong>@GetMaterialQuantityLabel(item)</strong>
                                                    <span>Waste @item.WastePercent.ToString("0.##")%</span>
                                                </div>
                                                <div class="line-meta">
                                                    <strong>@GetConversionLabel(item)</strong>
                                                    <span>@GetMaterialNettoLabel(item)</span>
                                                    <div class="line-weight-stack @GetInlineWeightClass(lineWeightEstimate, _isSelectedWeightLoading)">
                                                        <strong>@GetLineWeightValueLabel(lineWeightEstimate, _isSelectedWeightLoading)</strong>
                                                        <span>@GetLineWeightMetaLabel(lineWeightEstimate, _isSelectedWeightLoading)</span>
                                                    </div>
                                                </div>
                                                <div class="line-meta emphasis">
                                                    <strong>@FormatCurrency(GetLineCost(item))</strong>
                                                    <span>@GetMaterialPricePerPackLabel(item) / pack</span>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </details>
                        }
                    </div>
                </section>

                <section class="detail-section">
                    <div class="section-head">
                        <div>
                            <span class="section-tag">Overhead</span>
                            <h3>Biaya non-material</h3>
                            <p>Biaya tambahan di luar material utama resep.</p>
                        </div>
                    </div>

                    @if (visibleCosts.Count == 0)
                    {
                        <div class="empty-mini">Belum ada overhead atau biaya produksi tambahan.</div>
                    }
                    else
                    {
                        <div class="cost-detail-list">
                            @foreach (var cost in visibleCosts)
                            {
                                <article class="cost-detail-card">
                                    <div>
                                        <small>@(cost.Type == RecipeCostType.Overhead ? "Overhead" : "Biaya Produksi")</small>
                                        <strong>@cost.Name</strong>
                                        @if (!string.IsNullOrWhiteSpace(cost.Notes))
                                        {
                                            <p>@cost.Notes</p>
                                        }
                                    </div>

                                    <strong>@FormatCurrency(cost.Amount)</strong>
                                </article>
                            }
                        </div>
                    }
                </section>

                <section class="detail-section financial-section">
                    <div class="section-head">
                        <div>
                            <span class="section-tag">Ringkasan biaya</span>
                            <h3>Angka inti resep</h3>
                        </div>
                    </div>

                    <div class="detail-financial-strip">
                        <article><small>Margin Target</small><strong>@FormatPercent(selectedRecipe.TargetMarginPercent)</strong></article>
                        <article><small>Total Material</small><strong>@FormatCurrency(selectedTotals.MaterialCost)</strong></article>
                        <article><small>Operasional</small><strong>@FormatCurrency(selectedTotals.OperationalCost)</strong></article>
                        <article><small>Update</small><strong>@selectedRecipe.UpdatedAt.ToString("dd MMM yyyy HH:mm")</strong></article>
                    </div>
                </section>
            </div>
        }
    </section>
    </div>
</section>

@if (_showEditor)
{
    <div class="overlay">
        <div class="studio-shell modal-card form-modal-card recipe-form-modal" @onclick:stopPropagation="true">
            <EditForm Model="_formModel" OnValidSubmit="SaveAsync" class="studio-form">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="studio-head modal-head form-modal-head">
                    <div class="studio-head-copy">
                        <div class="studio-head-kicker">
                            <span class="section-tag">@(_editingId is null ? "Resep Baru" : "Edit Resep")</span>

                            <div class="studio-head-badges">
                                <span class="studio-head-badge subtle">@(!string.IsNullOrWhiteSpace(_formModel.Code) ? _formModel.Code : "Kode otomatis")</span>
                                <span class="studio-head-badge @(_formModel.Status == RecipeStatus.Active ? "active" : "inactive")">
                                    @(_formModel.Status == RecipeStatus.Active ? "Aktif" : "Draft")
                                </span>
                            </div>
                        </div>

                        <div class="studio-head-mainline">
                            <div>
                                <h2>@(_editingId is null ? "Rakit resep" : "Perbarui resep")</h2>
                                <p>Lengkapi identitas, susun kelompok bahan, lalu finalkan biaya dan margin dalam satu panel.</p>
                            </div>

                            <div class="studio-head-glance">
                                <article>
                                    <small>Kelompok</small>
                                    <strong>@_formModel.Groups.Count</strong>
                                </article>
                                <article>
                                    <small>Material</small>
                                    <strong>@CurrentTotals.MaterialCount</strong>
                                </article>
                            </div>
                        </div>
                    </div>

                    <button type="button" class="close-button" @onclick="RequestCloseEditor" aria-label="Tutup form">
                        <AppIcon Name="close" Class="icon-glyph" />
                    </button>
                </div>

                @if (!string.IsNullOrWhiteSpace(_formMessage))
                {
                    <div class="form-message">@_formMessage</div>
                }

                <div class="editor-summary-strip">
                    <article><small>Total Batch</small><strong>@FormatCurrency(CurrentTotals.TotalCost)</strong></article>
                    <article><small>HPP / Satuan</small><strong>@FormatCurrency(CurrentTotals.CostPerPortion)</strong></article>
                    <article><small>Harga Jual / Satuan</small><strong>@FormatCurrency(CurrentSuggestedSellingPrice)</strong></article>
                    <article>
                        <small>Porsi / Batch</small>
                        <strong>@GetPortionYieldValueLabel(_formModel, _editorWeightEstimate, CurrentEffectivePortionYield)</strong>
                        <span>@GetPortionYieldMetaLabel(_formModel, _editorWeightEstimate, CurrentEffectivePortionYield)</span>
                    </article>
                    <article class="@GetDoughWeightCardClass(_editorWeightEstimate, _isEditorWeightLoading)">
                        <small>Total Berat Adonan</small>
                        <strong>@GetDoughWeightValueLabel(_editorWeightEstimate, _isEditorWeightLoading)</strong>
                        <span>@GetDoughWeightMetaLabel(_editorWeightEstimate, _isEditorWeightLoading)</span>
                    </article>
                </div>

                <div class="editor-stage-strip" aria-label="Tahapan editor resep">
                    <button type="button" class="editor-stage-pill @(_editorStage == 1 ? "active" : null)" @onclick="() => GoToEditorStage(1)">1. Detail</button>
                    <button type="button" class="editor-stage-pill @(_editorStage == 2 ? "active" : null)" @onclick="() => GoToEditorStage(2)">2. Bahan</button>
                    <button type="button" class="editor-stage-pill @(_editorStage == 3 ? "active" : null)" @onclick="() => GoToEditorStage(3)">3. Biaya & Harga</button>
                </div>

                <div class="studio-layout">
                    <div class="studio-main form-stack">
                        @if (_editorStage == 1)
                        {
                        <section class="studio-card form-section recipe-entry-card">
                            <div class="section-head section-inline-head">
                                <div>
                                    <span class="section-tag">Detail resep</span>
                                    <h3>Identitas utama resep</h3>
                                    <p>Isi data inti resep sebelum masuk ke komposisi bahan.</p>
                                </div>
                            </div>

                            <div class="recipe-detail-grid">
                                <label class="wide-field">
                                    <span>Nama resep</span>
                                    <InputText @bind-Value="_formModel.Name" class="recipe-name-input" />
                                    <ValidationMessage For="@(() => _formModel.Name)" />
                                </label>
                                <label><span>Kode / nomor resep</span><InputText @bind-Value="_formModel.Code" /></label>
                                <label>
                                    <span>Porsi / batch</span>
                                    @if (_formModel.PortioningMode == RecipePortioningMode.WeightBased)
                                    {
                                        <div class="readonly-field">
                                            <strong>@GetPortionYieldValueLabel(_formModel, _editorWeightEstimate, CurrentEffectivePortionYield)</strong>
                                            <span>Jumlah porsi dihitung otomatis dari berat acuan dan berat per porsi.</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <InputNumber @bind-Value="_formModel.PortionYield" />
                                        <ValidationMessage For="@(() => _formModel.PortionYield)" />
                                    }
                                </label>
                                <label>
                                    <span>Satuan porsi</span>
                                    <InputSelect @bind-Value="_formModel.PortionUnit">
                                        @foreach (var unit in RecipePortionUnitCatalog.Options)
                                        {
                                            <option value="@unit">@unit</option>
                                        }
                                    </InputSelect>
                                    <ValidationMessage For="@(() => _formModel.PortionUnit)" />
                                </label>
                                <label>
                                    <span>Status</span>
                                    <InputSelect @bind-Value="_formModel.Status">
                                        <option value="@RecipeStatus.Active">Aktif</option>
                                        <option value="@RecipeStatus.Draft">Draft</option>
                                    </InputSelect>
                                </label>
                                <label>
                                    <span>Mode hitung porsi</span>
                                    <InputSelect @bind-Value="_formModel.PortioningMode">
                                        <option value="@RecipePortioningMode.Manual">Manual</option>
                                        <option value="@RecipePortioningMode.WeightBased">Berdasarkan berat adonan</option>
                                    </InputSelect>
                                </label>
                                @if (_formModel.PortioningMode == RecipePortioningMode.WeightBased)
                                {
                                    <label>
                                        <span>Acuan berat</span>
                                        <select value="@GetSelectedPortionWeightBasisValue(_formModel)" @onchange="OnPortionWeightBasisChanged">
                                            <option value="total">Total seluruh berat adonan</option>
                                            @foreach (var group in _formModel.Groups)
                                            {
                                                <option value="@GetPortionWeightBasisGroupValue(group.Id)">@GetPortionWeightBasisGroupLabel(group)</option>
                                            }
                                        </select>
                                    </label>
                                    <label>
                                        <span>Berat per porsi (gr)</span>
                                        <InputNumber @bind-Value="_formModel.PortionWeightGr" />
                                    </label>
                                    <div class="portion-weight-preview inline-weight full @GetPortionWeightPreviewClass(_formModel, _editorWeightEstimate, _isEditorWeightLoading)">
                                        <small>Hasil pembagian porsi</small>
                                        <strong>@GetPortionYieldValueLabel(_formModel, _editorWeightEstimate, CurrentEffectivePortionYield)</strong>
                                        <span>@GetPortionYieldMetaLabel(_formModel, _editorWeightEstimate, CurrentEffectivePortionYield)</span>
                                    </div>
                                }
                                <label class="full"><span>Deskripsi</span><InputTextArea @bind-Value="_formModel.Description" /></label>
                            </div>
                        </section>
                        }

                        @if (_editorStage == 2)
                        {
                        <section class="studio-card form-section recipe-entry-card">
                            <div class="section-head section-inline-head">
                                <div>
                                    <span class="section-tag">Kelompok bahan</span>
                                    <h3>Struktur formula</h3>
                                    <p>Pilih kelompok aktif untuk target input material.</p>
                                </div>

                                <button type="button" class="ghost-button" @onclick="AddGroup">Tambah Kelompok</button>
                            </div>

                            @for (var groupIndex = 0; groupIndex < _formModel.Groups.Count; groupIndex++)
                            {
                                var group = _formModel.Groups[groupIndex];
                                var groupWeightEstimate = GetGroupDoughWeightEstimate(_editorWeightEstimate, group);
                                <section class="group-card @(_activeGroupId == group.Id ? "active" : null)">
                                    <div class="group-row-main">
                                        <div class="group-index">@((groupIndex + 1).ToString("00"))</div>

                                        <div class="group-meta-grid">
                                            <label><span>Nama kelompok bahan</span><InputText @bind-Value="group.Name" /></label>
                                            <label><span>Catatan kelompok</span><InputText @bind-Value="group.Notes" /></label>
                                        </div>
                                    </div>

                                    <div class="group-row-side">
                                        <div class="group-footer-copy">
                                            <strong>@group.Materials.Count material</strong>
                                            <span>@GetGroupSummary(group)</span>
                                            <span class="@GetInlineWeightClass(groupWeightEstimate, _isEditorWeightLoading)">
                                                Berat kelompok: @GetGroupWeightValueLabel(groupWeightEstimate, _isEditorWeightLoading)
                                            </span>
                                        </div>

                                        <div class="group-actions">
                                            <button type="button" class="ghost-button" disabled="@(_activeGroupId == group.Id)" @onclick="() => OpenMaterialWorkspaceAsync(group)">
                                                @(_activeGroupId == group.Id ? "Sedang Aktif" : "Kelola Material")
                                            </button>
                                            <button type="button" class="icon-action-button danger" title="Hapus kelompok" aria-label="Hapus kelompok" disabled="@(_formModel.Groups.Count == 1)" @onclick="() => RemoveGroup(group)">
                                                <AppIcon Name="delete" Class="icon-glyph" />
                                            </button>
                                        </div>
                                    </div>
                                </section>
                            }
                        </section>

                        <section class="studio-card form-section recipe-entry-card material-studio-card catalog-datagrid">
                            <div class="section-head section-inline-head">
                                <div>
                                    <span class="section-tag">Material</span>
                                    <h3>Input dan list material</h3>
                                    <p>Input singkat di atas, review material terpilih di datagrid bawah.</p>
                                </div>

                                <label class="display-count-control compact">
                                    <span>Baris tampil</span>
                                    <select value="@_materialDisplayCount" @onchange="OnMaterialDisplayCountChanged">
                                        @foreach (var option in GridDisplayOptions)
                                        {
                                            <option value="@option">@option baris</option>
                                        }
                                    </select>
                                </label>
                            </div>

                            @if (ActiveEditingGroup is null)
                            {
                                <div class="empty-state compact-empty">
                                    <h2>Pilih kelompok bahan</h2>
                                    <p>Pilih satu kelompok bahan terlebih dahulu sebelum menambah material.</p>
                                </div>
                            }
                            else
                            {
                                var activeGroup = ActiveEditingGroup;
                                var activeGroupWeightEstimate = GetGroupDoughWeightEstimate(_editorWeightEstimate, activeGroup);
                                <div class="material-workspace-head">
                                    <div>
                                        <span class="section-tag">Kelompok aktif</span>
                                        <h4>@(string.IsNullOrWhiteSpace(activeGroup.Name) ? "Kelompok baru" : activeGroup.Name)</h4>
                                        <p>@GetGroupSummary(activeGroup)</p>
                                    </div>

                                    <div class="material-workspace-tools">
                                        <div class="header-pills">
                                            <span>@activeGroup.Materials.Count material</span>
                                            <span>@FormatCurrency(GetGroupTotal(activeGroup))</span>
                                            <span class="@GetInlineWeightClass(activeGroupWeightEstimate, _isEditorWeightLoading)">
                                                Berat @GetGroupWeightValueLabel(activeGroupWeightEstimate, _isEditorWeightLoading)
                                            </span>
                                        </div>
                                        <button type="button" class="ghost-button compact" @onclick="OpenMaterialCatalogAsync">Buka Katalog Material</button>
                                    </div>
                                </div>

                                <div class="material-entry-card">
                                    <div class="material-entry-summary">
                                        <div>
                                            <small>Input material</small>
                                            <strong>@(_editingMaterialId is null ? "Tambah bahan ke kelompok aktif" : "Edit bahan yang dipilih")</strong>
                                        </div>
                                        <span>@(_editingMaterialId is null ? "Mode tambah" : "Mode edit")</span>
                                    </div>

                                    <div class="material-entry-grid">
                                        <label class="material-entry-material">
                                            <span>Pilih material</span>
                                            <input class="material-picker-input"
                                                   list="recipe-material-options"
                                                   value="@_materialLookupText"
                                                   @oninput="OnDraftMaterialChangedAsync"
                                                   placeholder="Ketik nama atau kode material katalog" />
                                            <datalist id="recipe-material-options">
                                                @foreach (var material in ActiveMaterials)
                                                {
                                                    <option value="@GetMaterialOptionLabel(material)"></option>
                                                }
                                            </datalist>
                                        </label>
                                        <label>
                                            <span>Kuantitas</span>
                                            <InputNumber @bind-Value="_materialDraft.Quantity" class="material-quantity-input" />
                                        </label>
                                        <label>
                                            <span>Pilih satuan</span>
                                            <select value="@_materialDraft.Unit" @onchange="args => _materialDraft.Unit = args.Value?.ToString() ?? string.Empty">
                                                <option value="">Pilih unit</option>
                                                @foreach (var unit in GetUnits(_materialDraft))
                                                {
                                                    <option value="@unit">@unit</option>
                                                }
                                            </select>
                                        </label>
                                        <label>
                                            <span>Waste %</span>
                                            <InputNumber @bind-Value="_materialDraft.WastePercent" />
                                        </label>
                                        <label class="wide-field">
                                            <span>Catatan</span>
                                            <InputText @bind-Value="_materialDraft.Notes" />
                                        </label>
                                        <div class="material-form-actions">
                                            @if (_editingMaterialId is not null)
                                            {
                                                <button type="button" class="ghost-button" @onclick="ResetMaterialDraftAndFocusAsync">Reset</button>
                                            }

                                            <button type="button" class="primary-button material-submit-button" @onclick="AddDraftMaterialToActiveGroupAsync">
                                                @(_editingMaterialId is null ? "\u2713 Masukkan" : "\u2713 Update")
                                            </button>
                                        </div>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(MaterialAvailabilityWarning))
                                    {
                                        <div class="material-warning-note">@MaterialAvailabilityWarning</div>
                                    }
                                </div>

                                @if (activeGroup.Materials.Count == 0)
                                {
                                    <div class="empty-state compact-empty">
                                        <h2>Belum ada material</h2>
                                        <p>Material yang dimasukkan dari form di atas akan muncul di datagrid ini.</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="material-grid-shell">
                                        <QuickGrid Items="VisibleActiveGroupMaterials.AsQueryable()" Class="material-quickgrid">
                                            <TemplateColumn Title="Nama Material" Context="item">
                                                <div class="material-name-cell">
                                                    <strong>@GetMaterialDisplayName(item)</strong>
                                                    <small>@GetMaterialMetaSummary(item)</small>
                                                </div>
                                            </TemplateColumn>
                                            <TemplateColumn Title="Kuantitas bahan" Context="item">
                                                <div class="material-meta-cell">
                                                    <strong>@GetMaterialQuantityLabel(item)</strong>
                                                    <small>@GetMaterialUsageHint(item)</small>
                                                </div>
                                            </TemplateColumn>
                                            <TemplateColumn Title="Berat ke gram" Context="item">
                                                <div class="material-meta-cell">
                                                    <strong>@GetLineWeightValueLabel(GetLineDoughWeightEstimate(_editorWeightEstimate, item), _isEditorWeightLoading)</strong>
                                                    <small>@GetLineWeightMetaLabel(GetLineDoughWeightEstimate(_editorWeightEstimate, item), _isEditorWeightLoading)</small>
                                                </div>
                                            </TemplateColumn>
                                            <TemplateColumn Title="Modal" Context="item">
                                                <div class="material-cost-cell">
                                                    <strong>@FormatCurrency(GetLineCost(item))</strong>
                                                    <small>@GetMaterialCostHint(item)</small>
                                                </div>
                                            </TemplateColumn>
                                            <TemplateColumn Title="Aksi" Context="item">
                                                <div class="material-row-actions">
                                                    <button type="button" class="icon-action-button" title="Edit" aria-label="Edit" @onclick="() => EditMaterialRowAsync(activeGroup, item)">
                                                        <AppIcon Name="edit" Class="icon-glyph" />
                                                    </button>
                                                    <button type="button" class="icon-action-button danger" title="Hapus" aria-label="Hapus" @onclick="() => RemoveMaterialRow(activeGroup, item)">
                                                        <AppIcon Name="delete" Class="icon-glyph" />
                                                    </button>
                                                </div>
                                            </TemplateColumn>
                                    </QuickGrid>
                                    </div>

                                    <div class="table-footer">
                                        <small>@(ActiveEditingGroup?.Materials.Count ?? 0) material</small>
                                        <div class="pager">
                                            <button type="button" @onclick="PrevMaterialPage" disabled="@(CurrentMaterialPage <= 1)">Prev</button>
                                            <label class="pager-select" aria-label="Pilih halaman material resep">
                                                <select value="@CurrentMaterialPage" @onchange="OnMaterialPageChanged">
                                                    @for (var pageNumber = 1; pageNumber <= MaterialTotalPages; pageNumber++)
                                                    {
                                                        <option value="@pageNumber">Halaman @pageNumber</option>
                                                    }
                                                </select>
                                            </label>
                                            <span>@CurrentMaterialPage / @MaterialTotalPages</span>
                                            <button type="button" @onclick="NextMaterialPage" disabled="@(CurrentMaterialPage >= MaterialTotalPages)">Next</button>
                                        </div>
                                        <div class="table-footer-spacer" aria-hidden="true"></div>
                                    </div>
                                }
                            }
                        </section>

                        }

                        @if (_editorStage == 3)
                        {
                        <section class="studio-card form-section recipe-entry-card">
                            <div class="section-head section-inline-head">
                                <div>
                                    <span class="section-tag">Overhead</span>
                                    <h3>Biaya non-material</h3>
                                    <p>Tambahkan overhead atau biaya produksi yang ikut membentuk total batch.</p>
                                </div>

                                <div class="group-actions">
                                    <button type="button" class="ghost-button" @onclick="() => AddCost(RecipeCostType.Overhead)">+ Overhead</button>
                                    <button type="button" class="ghost-button" @onclick="() => AddCost(RecipeCostType.Production)">+ Produksi</button>
                                </div>
                            </div>

                            @if (_formModel.Costs.Count == 0)
                            {
                                <div class="empty-mini">Belum ada biaya tambahan.</div>
                            }
                            else
                            {
                                <div class="cost-stack">
                                    @foreach (var cost in _formModel.Costs)
                                    {
                                        <article class="cost-card">
                                            <div class="cost-grid">
                                                <label>
                                                    <span>Tipe</span>
                                                    <InputSelect @bind-Value="cost.Type">
                                                        <option value="@RecipeCostType.Overhead">Overhead</option>
                                                        <option value="@RecipeCostType.Production">Biaya Produksi</option>
                                                    </InputSelect>
                                                </label>
                                                <label><span>Nama</span><InputText @bind-Value="cost.Name" /></label>
                                                <label><span>Nominal</span><InputNumber @bind-Value="cost.Amount" /></label>
                                                <label><span>Catatan</span><InputText @bind-Value="cost.Notes" /></label>
                                            </div>

                                            <div class="cost-card-footer">
                                                <strong>@FormatCurrency(cost.Amount)</strong>
                                                <button type="button" class="icon-action-button danger" title="Hapus biaya" aria-label="Hapus biaya" @onclick="() => RemoveCost(cost)">
                                                    <AppIcon Name="delete" Class="icon-glyph" />
                                                </button>
                                            </div>
                                        </article>
                                    }
                                </div>
                            }
                        </section>

                        <section class="studio-card form-section recipe-entry-card pricing-section">
                            <div class="section-head section-inline-head">
                                <div>
                                    <span class="section-tag">Harga jual</span>
                                    <h3>Atur harga jual berdasarkan margin</h3>
                                    <p>Margin dihitung dari HPP per satuan porsi agar harga jual resep langsung terbentuk saat resep disimpan.</p>
                                </div>
                            </div>

                            <div class="pricing-grid">
                                <label>
                                    <span>Margin target (%)</span>
                                    <InputNumber @bind-Value="_formModel.TargetMarginPercent" />
                                    <ValidationMessage For="@(() => _formModel.TargetMarginPercent)" />
                                </label>
                                <article class="pricing-output-card">
                                    <small>HPP / Satuan</small>
                                    <strong>@FormatCurrency(CurrentTotals.CostPerPortion)</strong>
                                </article>
                                <article class="pricing-output-card">
                                    <small>Harga Jual / Satuan</small>
                                    <strong>@FormatCurrency(CurrentSuggestedSellingPrice)</strong>
                                </article>
                            </div>
                        </section>
                        }

                    </div>

                </div>

                <div class="modal-actions modal-actions-between editor-footer recipe-editor-footer">
                    <div class="editor-status-panel">
                        <div class="editor-status-copy">
                            <span class="section-tag">Ringkas</span>
                            <p>Pastikan kelompok bahan dan material sudah lengkap sebelum simpan resep.</p>
                        </div>
                    </div>

                    <div class="modal-action-group editor-submit-panel">
                        <button type="button" class="ghost-button" @onclick="RequestCloseEditor">Batal</button>
                        @if (_editorStage > 1)
                        {
                            <button type="button" class="ghost-button" @onclick="PrevEditorStage">Kembali</button>
                        }

                        @if (_editorStage < 3)
                        {
                            <button type="button" class="primary-button" @onclick="NextEditorStage">Lanjut</button>
                        }
                        else
                        {
                            <button type="submit" class="primary-button">Simpan Resep</button>
                        }
                    </div>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (_showCloseConfirm)
{
    <div class="overlay" @onclick="ContinueEditing">
        <div class="confirm-card" @onclick:stopPropagation="true">
            <span class="section-tag">Perubahan belum disimpan</span>
            <h2>Tutup editor resep?</h2>
            <p>Perubahan pada resep ini akan hilang jika editor ditutup sekarang.</p>

            <div class="confirm-actions">
                <button type="button" class="ghost-button" @onclick="ContinueEditing">Lanjut Edit</button>
                <button type="button" class="danger-button" @onclick="DiscardEditorChanges">Buang Perubahan</button>
            </div>
        </div>
    </div>
}

@if (_pendingDelete is not null)
{
    <div class="overlay" @onclick="CancelDelete">
        <div class="confirm-card" @onclick:stopPropagation="true">
            <span class="section-tag">Konfirmasi</span>
            <h2>Hapus resep ini?</h2>
            <p>@_pendingDelete.Name akan dihapus dari daftar resep.</p>

            <div class="confirm-actions">
                <button type="button" class="ghost-button" @onclick="CancelDelete">Batal</button>
                <button type="button" class="danger-button" @onclick="DeleteAsync">Ya, hapus</button>
            </div>
        </div>
    </div>
}

@code {
    private RecipeQueryResult? _result;
    private static readonly int[] GridDisplayOptions = [8, 12, 20, 50];
    private bool _isLoading = true;
    private string _statusMessage = "Memuat resep...";
    private string _searchText = string.Empty;
    private bool _showEditor;
    private Guid? _editingId;
    private int _editorStage = 1;
    private RecipeUpsertRequest _formModel = new();
    private string _formMessage = string.Empty;
    private RecipeListItem? _pendingDelete;
    private bool _focusEditorRequested;
    private Guid? _selectedRecipeId;
    private RecipeUpsertRequest? _selectedDraft;
    private Guid? _activeGroupId;
    private Guid? _editingMaterialId;
    private RecipeMaterialInput _materialDraft = CreateMaterialInput();
    private string _materialLookupText = string.Empty;
    private int _recipeDisplayCount = 12;
    private int _recipePage = 1;
    private int _materialDisplayCount = 10;
    private int _materialPage = 1;
    private string _aiRecipePrompt = string.Empty;
    private string _aiRecipeMessage = string.Empty;
    private bool _showCloseConfirm;
    private string _editorSnapshot = string.Empty;
    private IReadOnlyList<RawMaterial> _activeMaterials = Array.Empty<RawMaterial>();
    private HashSet<Guid> _warehouseMaterialIds = [];
    private RecipeDoughWeightEstimateResult _selectedWeightEstimate = RecipeDoughWeightEstimateResult.Empty;
    private RecipeDoughWeightEstimateResult _editorWeightEstimate = RecipeDoughWeightEstimateResult.Empty;
    private bool _isSelectedWeightLoading;
    private bool _isEditorWeightLoading;
    private string _selectedWeightSignature = string.Empty;
    private string _editorWeightSignature = string.Empty;
    private CancellationTokenSource? _selectedWeightEstimateCts;
    private CancellationTokenSource? _editorWeightEstimateCts;

    private IReadOnlyList<RawMaterial> ActiveMaterials => _activeMaterials;
    private HashSet<Guid> WarehouseMaterialIds => _warehouseMaterialIds;
    private decimal CurrentEffectivePortionYield => GetEffectivePortionYield(_formModel, _editorWeightEstimate);
    private RecipeSummaryTotals CurrentTotals => RecipeCatalogService.CalculateTotals(_formModel, CurrentEffectivePortionYield);
    private decimal CurrentSuggestedSellingPrice => CurrentTotals.SuggestedSellingPrice;
    private int RecipeTotalPages => CalculateTotalPages(_result?.Items.Count ?? 0, _recipeDisplayCount);
    private int CurrentRecipePage => ClampPage(_recipePage, RecipeTotalPages);
    private IReadOnlyList<RecipeListItem> VisibleRecipes
        => (_result?.Items ?? Array.Empty<RecipeListItem>())
            .Skip((CurrentRecipePage - 1) * _recipeDisplayCount)
            .Take(_recipeDisplayCount)
            .ToArray();
    private RecipeListItem? _selectedRecipe => _selectedRecipeId is null ? null : _result?.Items.FirstOrDefault(item => item.Id == _selectedRecipeId);
    private RecipeGroupInput? ActiveEditingGroup => _activeGroupId is null ? null : _formModel.Groups.FirstOrDefault(item => item.Id == _activeGroupId);
    private int MaterialTotalPages => CalculateTotalPages(ActiveEditingGroup?.Materials.Count ?? 0, _materialDisplayCount);
    private int CurrentMaterialPage => ClampPage(_materialPage, MaterialTotalPages);
    private IReadOnlyList<RecipeMaterialInput> VisibleActiveGroupMaterials
        => ActiveEditingGroup?.Materials
            .Skip((CurrentMaterialPage - 1) * _materialDisplayCount)
            .Take(_materialDisplayCount)
            .ToArray() ?? Array.Empty<RecipeMaterialInput>();
    private string? MaterialAvailabilityWarning => GetMaterialAvailabilityWarning(_materialDraft.MaterialId);

    protected override async Task OnInitializedAsync()
    {
        Store.Changed += HandleStoreChanged;
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusEditorRequested)
        {
            _focusEditorRequested = false;
            await JS.InvokeVoidAsync("recipeEditor.focusFirst", ".recipe-name-input");
        }

        await RefreshDoughWeightEstimatesIfNeededAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        RefreshMaterialCaches();
        _result = await RecipeCatalogService.QueryAsync(_searchText);
        _recipePage = CurrentRecipePage;
        _materialPage = CurrentMaterialPage;
        _statusMessage = $"{_result.TotalCount} resep";
        await SyncSelectionAsync();
        _isLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private Task ReloadAsync() => LoadAsync();

    private async Task OnSearchChangedAsync(ChangeEventArgs args)
    {
        _searchText = args.Value?.ToString() ?? string.Empty;
        _recipePage = 1;
        await LoadAsync();
    }

    private void OnRecipeDisplayCountChanged(ChangeEventArgs args)
    {
        _recipeDisplayCount = ParseDisplayCount(args.Value?.ToString(), _recipeDisplayCount);
        _recipePage = 1;
    }

    private void OnRecipePageChanged(ChangeEventArgs args)
        => _recipePage = ParsePage(args.Value?.ToString(), CurrentRecipePage, RecipeTotalPages);

    private void PrevRecipePage()
        => _recipePage = Math.Max(1, CurrentRecipePage - 1);

    private void NextRecipePage()
        => _recipePage = Math.Min(RecipeTotalPages, CurrentRecipePage + 1);

    private void OnMaterialDisplayCountChanged(ChangeEventArgs args)
    {
        _materialDisplayCount = ParseDisplayCount(args.Value?.ToString(), _materialDisplayCount);
        _materialPage = 1;
    }

    private void OnMaterialPageChanged(ChangeEventArgs args)
        => _materialPage = ParsePage(args.Value?.ToString(), CurrentMaterialPage, MaterialTotalPages);

    private void PrevMaterialPage()
        => _materialPage = Math.Max(1, CurrentMaterialPage - 1);

    private void NextMaterialPage()
        => _materialPage = Math.Min(MaterialTotalPages, CurrentMaterialPage + 1);

    private async Task SyncSelectionAsync()
    {
        if (_result is null || _result.Items.Count == 0)
        {
            _selectedRecipeId = null;
            _selectedDraft = null;
            _selectedWeightSignature = string.Empty;
            _selectedWeightEstimate = RecipeDoughWeightEstimateResult.Empty;
            return;
        }

        if (_selectedRecipeId is null || !_result.Items.Any(item => item.Id == _selectedRecipeId))
        {
            _selectedRecipeId = _result.Items[0].Id;
        }

        await LoadSelectedRecipeAsync();
    }

    private async Task SelectRecipeAsync(Guid id)
    {
        _selectedRecipeId = id;
        await LoadSelectedRecipeAsync();
    }

    private async Task LoadSelectedRecipeAsync()
    {
        if (_selectedRecipeId is not Guid id)
        {
            _selectedDraft = null;
            _selectedWeightSignature = string.Empty;
            _selectedWeightEstimate = RecipeDoughWeightEstimateResult.Empty;
            return;
        }

        _selectedDraft = await RecipeCatalogService.GetDraftAsync(id);
    }

    private async Task OpenCreateModalAsync()
    {
        var draft = new RecipeUpsertRequest
        {
            Code = await RecipeCatalogService.GenerateNextCodeAsync(),
            OutputQuantity = 1m,
            OutputUnit = "pcs",
            PortionYield = 1m,
            PortionUnit = "pcs",
            TargetMarginPercent = 35m,
            Status = RecipeStatus.Active,
            Groups = [CreateGroup("Bahan utama")]
        };

        BeginEditing(draft, null);
    }

    private async Task OpenEditModalAsync(Guid id)
    {
        var draft = await RecipeCatalogService.GetDraftAsync(id);
        if (draft is null)
        {
            _statusMessage = "Resep tidak ditemukan.";
            return;
        }

        BeginEditing(draft, id);
    }

    private bool HasUnsavedEditorChanges => _showEditor && !string.IsNullOrWhiteSpace(_editorSnapshot) && _editorSnapshot != SerializeRecipeSnapshot(_formModel);

    private void RequestCloseEditor()
    {
        if (HasUnsavedEditorChanges)
        {
            _showCloseConfirm = true;
            return;
        }

        ResetEditorState();
    }

    private void ContinueEditing()
        => _showCloseConfirm = false;

    private void DiscardEditorChanges()
        => ResetEditorState();

    private void ResetEditorState()
    {
        CancelEstimate(ref _editorWeightEstimateCts);
        _showCloseConfirm = false;
        _showEditor = false;
        _editingId = null;
        _editorStage = 1;
        _activeGroupId = null;
        _formMessage = string.Empty;
        _aiRecipePrompt = string.Empty;
        _aiRecipeMessage = string.Empty;
        ResetMaterialDraft();
        _editorSnapshot = string.Empty;
        _editorWeightSignature = string.Empty;
        _editorWeightEstimate = RecipeDoughWeightEstimateResult.Empty;
        _isEditorWeightLoading = false;
    }

    private void AddGroup()
    {
        var group = CreateGroup($"Kelompok {_formModel.Groups.Count + 1}");
        _formModel.Groups.Add(group);
        _activeGroupId = group.Id;
        ResetMaterialDraft();
    }

    private void RemoveGroup(RecipeGroupInput group)
    {
        if (_formModel.Groups.Count > 1)
        {
            var removedActive = _activeGroupId == group.Id;
            _formModel.Groups.Remove(group);
            if (_formModel.PortionWeightGroupId == group.Id)
            {
                _formModel.PortionWeightGroupId = null;
            }

            if (removedActive)
            {
                _activeGroupId = _formModel.Groups.FirstOrDefault()?.Id;
            }

            _materialPage = CurrentMaterialPage;
        }
    }

    private void RemoveMaterialRow(RecipeGroupInput group, RecipeMaterialInput item)
    {
        if (group.Materials.Contains(item))
        {
            group.Materials.Remove(item);
            if (_editingMaterialId == item.Id)
            {
                ResetMaterialDraft();
            }

            _materialPage = CurrentMaterialPage;
        }
    }

    private async Task OpenMaterialWorkspaceAsync(RecipeGroupInput group)
    {
        _activeGroupId = group.Id;
        _materialPage = 1;
        ResetMaterialDraft();
        await FocusMaterialPickerAsync();
    }

    private async Task OnDraftMaterialChangedAsync(ChangeEventArgs args)
    {
        _materialLookupText = args.Value?.ToString() ?? string.Empty;
        var material = ResolveMaterialLookup(_materialLookupText);
        if (material is null)
        {
            _materialDraft.MaterialId = null;
            _materialDraft.Unit = string.Empty;
            return;
        }

        var shouldShiftFocus = _materialDraft.MaterialId != material.Id;
        _materialDraft.MaterialId = material.Id;
        _materialDraft.Unit = GetSuggestedDraftUnit(material);
        if (shouldShiftFocus)
        {
            await FocusMaterialQuantityAsync();
        }
    }

    private async Task AddDraftMaterialToActiveGroupAsync()
    {
        var activeGroup = ActiveEditingGroup;
        if (activeGroup is null)
        {
            _formMessage = "Pilih kelompok bahan terlebih dahulu.";
            return;
        }

        if (_materialDraft.MaterialId is null)
        {
            _formMessage = "Pilih material terlebih dahulu.";
            return;
        }

        if (_materialDraft.Quantity <= 0)
        {
            _formMessage = "Kuantitas material harus lebih besar dari 0.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_materialDraft.Unit))
        {
            _formMessage = "Pilih satuan material.";
            return;
        }

        if (_editingMaterialId is Guid editingId)
        {
            var existing = activeGroup.Materials.FirstOrDefault(item => item.Id == editingId);
            if (existing is not null)
            {
                existing.MaterialId = _materialDraft.MaterialId;
                existing.Quantity = _materialDraft.Quantity;
                existing.Unit = _materialDraft.Unit;
                existing.WastePercent = _materialDraft.WastePercent;
                existing.Notes = _materialDraft.Notes;
            }
        }
        else
        {
            activeGroup.Materials.Add(new RecipeMaterialInput
            {
                MaterialId = _materialDraft.MaterialId,
                Quantity = _materialDraft.Quantity,
                Unit = _materialDraft.Unit,
                WastePercent = _materialDraft.WastePercent,
                Notes = _materialDraft.Notes
            });
        }

        _formMessage = string.Empty;
        ResetMaterialDraft();
        await FocusMaterialPickerAsync();
    }

    private async Task EditMaterialRowAsync(RecipeGroupInput group, RecipeMaterialInput item)
    {
        _activeGroupId = group.Id;
        _editingMaterialId = item.Id;
        _materialDraft = new RecipeMaterialInput
        {
            Id = item.Id,
            MaterialId = item.MaterialId,
            Quantity = item.Quantity,
            Unit = item.Unit,
            WastePercent = item.WastePercent,
            Notes = item.Notes
        };
        var material = FindMaterial(item.MaterialId);
        _materialLookupText = material is null
            ? string.Empty
            : GetMaterialOptionLabel(material);

        await FocusMaterialQuantityAsync();
    }

    private void ResetMaterialDraft()
    {
        _editingMaterialId = null;
