    private static string GetDoughWeightValueLabel(RecipeDoughWeightEstimateResult estimate, bool isLoading)
    {
        if (isLoading)
        {
            return "Menghitung...";
        }

        if (estimate.TotalWeightGr <= 0 && estimate.UnresolvedLineCount > 0)
        {
            return "Belum lengkap";
        }

        var prefix = estimate.UsedAi ? "~ " : string.Empty;
        return $"{prefix}{FormatWeight(estimate.TotalWeightGr)}";
