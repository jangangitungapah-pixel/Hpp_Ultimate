    private async Task GenerateRecipeDraftWithAiAsync()
    {
        _aiRecipeMessage = string.Empty;

        try
        {
            var materialContexts = ActiveMaterials
                .Select(material => new RecipeAiMaterialContext(
                    material.Code,
                    material.Name,
                    material.Brand,
                    material.BaseUnit,
                    RecipeCatalogMath.GetAvailableUnits(material).ToArray(),
                    WarehouseMaterialIds.Contains(material.Id)))
                .ToArray();

            var result = await GeminiRecipeDraftService.GenerateDraftAsync(new RecipeAiDraftRequest(
                _aiRecipePrompt,
                materialContexts));

            _aiRecipeMessage = result.Message;
            if (!result.Success || result.Draft is null)
            {
                return;
            }

            ApplyAiRecipeDraft(result.Draft);
        }
        finally
        {
        }
    }

