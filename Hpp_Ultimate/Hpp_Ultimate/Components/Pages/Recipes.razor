    }

    private void RefreshMaterialCaches()
    {
        _activeMaterials = Store.RawMaterials
            .Where(item => item.Status == MaterialStatus.Active)
            .OrderBy(item => item.Name)
            .ToArray();

        _warehouseMaterialIds = Store.StockMovements
            .Select(item => item.MaterialId)
            .ToHashSet();
    }

    private void HandleStoreChanged()
    {
        _ = InvokeAsync(LoadAsync);
    }

    public ValueTask DisposeAsync()
    {
        Store.Changed -= HandleStoreChanged;
        CancelEstimate(ref _selectedWeightEstimateCts);
        CancelEstimate(ref _editorWeightEstimateCts);
        return ValueTask.CompletedTask;
    }
