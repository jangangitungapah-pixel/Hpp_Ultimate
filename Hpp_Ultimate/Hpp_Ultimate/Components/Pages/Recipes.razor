    {
        if (isLoading)
        {
            return "inline-weight pending";
        }

        if (request.PortionWeightGroupId is Guid)
        {
            return GetInlineWeightClass(GetSelectedPortionWeightGroupEstimate(request, estimate), isLoading);
        }

        if (!estimate.IsComplete)
        {
            return "inline-weight warning";
        }

        return estimate.UsedAi
            ? "inline-weight ai"
            : "inline-weight";
    }

    private static string GetPortionYieldValueLabel(RecipeUpsertRequest request, RecipeDoughWeightEstimateResult estimate, decimal effectivePortionYield)
    {
        if (request.PortioningMode == RecipePortioningMode.WeightBased)
        {
            return effectivePortionYield > 0
                ? $"{effectivePortionYield.ToString("0")} {request.PortionUnit}"
                : "Belum lengkap";
        }

        return $"{request.PortionYield.ToString("0.##")} {request.PortionUnit}";
    }

    private static string GetPortionYieldMetaLabel(RecipeUpsertRequest request, RecipeDoughWeightEstimateResult estimate, decimal effectivePortionYield)
    {
        if (request.PortioningMode != RecipePortioningMode.WeightBased)
        {
            return "Porsi manual dipakai sebagai acuan HPP.";
        }

        var referenceWeightGr = GetSelectedPortionWeightGr(request, estimate);
        var referenceLabel = GetPortionWeightReferenceLabel(request);
        if (request.PortionWeightGr <= 0)
        {
            return "Isi berat target per porsi untuk menghitung jumlah pcs.";
        }

        if (referenceWeightGr <= 0)
        {
            return $"Berat acuan {referenceLabel.ToLowerInvariant()} belum lengkap.";
        }

        if (effectivePortionYield <= 0)
        {
            return $"Berat acuan {FormatWeight(referenceWeightGr)} belum cukup untuk 1 {request.PortionUnit} @ {FormatWeight(request.PortionWeightGr)}.";
        }

        return $"{referenceLabel}: {FormatWeight(referenceWeightGr)} / {FormatWeight(request.PortionWeightGr)} per {request.PortionUnit}.";
    }

