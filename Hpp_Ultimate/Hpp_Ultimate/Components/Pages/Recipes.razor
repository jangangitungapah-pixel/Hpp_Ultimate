    private async Task RefreshDoughWeightEstimatesIfNeededAsync()
    {
        var selectedSignature = BuildDoughWeightSignature(_selectedDraft);
        if (!string.Equals(_selectedWeightSignature, selectedSignature, StringComparison.Ordinal))
        {
            _selectedWeightSignature = selectedSignature;
            await RefreshSelectedDoughWeightAsync();
        }

        var editorSignature = _showEditor ? BuildDoughWeightSignature(_formModel) : string.Empty;
        if (!string.Equals(_editorWeightSignature, editorSignature, StringComparison.Ordinal))
        {
            _editorWeightSignature = editorSignature;
            await RefreshEditorDoughWeightAsync();
        }
    }

    private async Task RefreshSelectedDoughWeightAsync()
    {
        CancelEstimate(ref _selectedWeightEstimateCts);

        if (_selectedDraft is null)
        {
            _selectedWeightEstimate = RecipeDoughWeightEstimateResult.Empty;
            _isSelectedWeightLoading = false;
            return;
        }

        var cts = new CancellationTokenSource();
        _selectedWeightEstimateCts = cts;
        _isSelectedWeightLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var result = await GeminiRecipeWeightEstimatorService.EstimateAsync(_selectedDraft, cts.Token);
            if (!ReferenceEquals(_selectedWeightEstimateCts, cts) || cts.IsCancellationRequested)
            {
                return;
            }

            _selectedWeightEstimate = result;
        }
        catch (OperationCanceledException)
        {
        }
        finally
        {
            if (ReferenceEquals(_selectedWeightEstimateCts, cts))
            {
                _selectedWeightEstimateCts = null;
                _isSelectedWeightLoading = false;
                await InvokeAsync(StateHasChanged);
            }

            cts.Dispose();
        }
    }

    private async Task RefreshEditorDoughWeightAsync()
    {
        CancelEstimate(ref _editorWeightEstimateCts);

        if (!_showEditor)
        {
            _editorWeightEstimate = RecipeDoughWeightEstimateResult.Empty;
            _isEditorWeightLoading = false;
            return;
        }

        var cts = new CancellationTokenSource();
        _editorWeightEstimateCts = cts;
        _isEditorWeightLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(260, cts.Token);
            var result = await GeminiRecipeWeightEstimatorService.EstimateAsync(_formModel, cts.Token);
            if (!ReferenceEquals(_editorWeightEstimateCts, cts) || cts.IsCancellationRequested)
            {
                return;
            }

            _editorWeightEstimate = result;
        }
        catch (OperationCanceledException)
        {
        }
        finally
        {
            if (ReferenceEquals(_editorWeightEstimateCts, cts))
            {
                _editorWeightEstimateCts = null;
                _isEditorWeightLoading = false;
                await InvokeAsync(StateHasChanged);
            }

            cts.Dispose();
        }
    }

    private void GoToEditorStage(int stage)
        => _editorStage = Math.Min(3, Math.Max(1, stage));

    private void NextEditorStage()
        => GoToEditorStage(_editorStage + 1);

    private void PrevEditorStage()
        => GoToEditorStage(_editorStage - 1);

    private void ApplyAiRecipeDraft(RecipeAiDraft draft)
    {
        _formModel.Name = draft.Name;
        _formModel.Description = draft.Description;
        _formModel.PortionYield = draft.PortionYield;
        _formModel.PortionUnit = RecipePortionUnitCatalog.Normalize(draft.PortionUnit);
        _formModel.TargetMarginPercent = draft.TargetMarginPercent;
        _formModel.Costs = draft.Costs
            .Select(item => new RecipeCostInput
            {
                Type = item.Type,
                Name = item.Name,
                Amount = item.Amount,
                Notes = item.Notes
            })
            .ToList();

        _formModel.Groups = draft.Groups
            .Select(group => new RecipeGroupInput
            {
                Name = group.Name,
                Notes = group.Notes,
                Materials = group.Materials
                    .Select(material => new RecipeMaterialInput
                    {
                        MaterialId = ActiveMaterials.FirstOrDefault(item => item.Code.Equals(material.MaterialCode, StringComparison.OrdinalIgnoreCase))?.Id,
                        Quantity = material.Quantity,
                        Unit = material.Unit,
                        WastePercent = material.WastePercent,
                        Notes = material.Notes
                    })
                    .Where(item => item.MaterialId is not null)
                    .ToList()
            })
            .Where(group => group.Materials.Count > 0)
            .ToList();

        EnsureEditorHasGroup();
        _activeGroupId = _formModel.Groups[0].Id;
        _materialPage = 1;
        ResetMaterialDraft();

        if (draft.Warnings.Count > 0)
        {
            _aiRecipeMessage = $"{_aiRecipeMessage} {string.Join(" ", draft.Warnings)}".Trim();
        }
    }

    private void EnsureEditorHasGroup()
    {
        if (_formModel.Groups.Count == 0)
        {
            _formModel.Groups.Add(CreateGroup("Bahan utama"));
        }
    }

    private RawMaterial? FindMaterial(RecipeMaterialInput item)
        => FindMaterial(item.MaterialId);

    private RawMaterial? FindMaterial(Guid? materialId)
        => materialId is Guid id ? Store.FindRawMaterial(id) : null;

    private RawMaterial? ResolveMaterialLookup(string? lookup)
    {
        if (string.IsNullOrWhiteSpace(lookup))
        {
            return null;
        }

        var normalized = lookup.Trim();
        return ActiveMaterials.FirstOrDefault(item =>
            GetMaterialOptionLabel(item).Equals(normalized, StringComparison.OrdinalIgnoreCase) ||
            item.Code.Equals(normalized, StringComparison.OrdinalIgnoreCase) ||
            item.Name.Equals(normalized, StringComparison.OrdinalIgnoreCase));
    }

    private string? GetMaterialAvailabilityWarning(Guid? materialId)
    {
        if (materialId is not Guid id)
        {
            return null;
        }

        var material = FindMaterial(id);
        if (material is null)
        {
            return "Material tidak ditemukan di katalog.";
        }

        if (!WarehouseMaterialIds.Contains(id))
        {
            return "Material ini belum ada di list gudang.";
        }

        var onHand = Store.StockMovements
            .Where(item => item.MaterialId == id)
            .Sum(item => item.Quantity);

        return onHand <= 0
            ? $"Stok {material.Name} saat ini kosong di gudang."
            : null;
    }

    private static RecipeGroupInput CreateGroup(string name) => new() { Name = name };
    private static RecipeMaterialInput CreateMaterialInput() => new() { Quantity = 1m };
    private static string FormatCurrency(decimal value) => string.Create(new System.Globalization.CultureInfo("id-ID"), $"Rp {value:N0}");
    private static string FormatPercent(decimal value) => $"{value:0.##}%";
    private static string FormatWeight(decimal value) => string.Create(new System.Globalization.CultureInfo("id-ID"), $"{decimal.Round(value, 0, MidpointRounding.AwayFromZero):N0} gr");
    private static int ParseDisplayCount(string? value, int fallback) => int.TryParse(value, out var parsed) && parsed > 0 ? parsed : fallback;
    private static int ParsePage(string? value, int fallback, int totalPages) => int.TryParse(value, out var parsed) && parsed > 0 ? Math.Min(parsed, Math.Max(1, totalPages)) : fallback;
    private static int CalculateTotalPages(int totalItems, int pageSize) => Math.Max(1, (int)Math.Ceiling(totalItems / (double)Math.Max(1, pageSize)));
    private static int ClampPage(int page, int totalPages) => Math.Min(Math.Max(1, page), Math.Max(1, totalPages));
    private static string SerializeRecipeSnapshot(RecipeUpsertRequest draft) => System.Text.Json.JsonSerializer.Serialize(draft);

    private static string BuildDoughWeightSignature(RecipeUpsertRequest? draft)
    {
        if (draft is null)
        {
            return string.Empty;
        }

        var builder = new System.Text.StringBuilder();
        foreach (var group in draft.Groups)
        {
            builder.Append(group.Id.ToString("N"));
            builder.Append(':');
            foreach (var item in group.Materials)
            {
                builder.Append(item.MaterialId?.ToString("N") ?? "-");
                builder.Append('|');
                builder.Append(decimal.Round(item.Quantity, 4, MidpointRounding.AwayFromZero).ToString("0.####", System.Globalization.CultureInfo.InvariantCulture));
                builder.Append('|');
                builder.Append(item.Unit?.Trim().ToLowerInvariant() ?? string.Empty);
                builder.Append(';');
            }

            builder.Append('#');
        }

        return builder.ToString();
    }

    private static void CancelEstimate(ref CancellationTokenSource? source)
    {
        if (source is null)
        {
            return;
        }

        source.Cancel();
        source.Dispose();
        source = null;
    }

