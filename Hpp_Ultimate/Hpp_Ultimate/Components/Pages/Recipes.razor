    private static decimal GetEffectivePortionYield(RecipeUpsertRequest request, RecipeDoughWeightEstimateResult estimate)
    {
        if (request.PortioningMode != RecipePortioningMode.WeightBased)
        {
            return request.PortionYield;
        }

        if (request.PortionWeightGr <= 0)
        {
            return 0m;
        }

        var referenceWeightGr = GetSelectedPortionWeightGr(request, estimate);
        if (referenceWeightGr <= 0)
        {
            return 0m;
        }

        return decimal.Floor(referenceWeightGr / request.PortionWeightGr);
    }

    private static decimal GetSelectedPortionWeightGr(RecipeUpsertRequest request, RecipeDoughWeightEstimateResult estimate)
    {
        if (request.PortionWeightGroupId is Guid groupId)
        {
            return estimate.Groups.FirstOrDefault(item => item.GroupId == groupId)?.TotalWeightGr ?? 0m;
        }

        return estimate.TotalWeightGr;
    }

    private static RecipeDoughWeightGroupEstimate? GetSelectedPortionWeightGroupEstimate(RecipeUpsertRequest request, RecipeDoughWeightEstimateResult estimate)
        => request.PortionWeightGroupId is Guid groupId
            ? estimate.Groups.FirstOrDefault(item => item.GroupId == groupId)
            : null;

