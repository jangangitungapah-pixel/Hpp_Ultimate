@page "/pengaturan"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject SettingsService SettingsService
@inject SeededBusinessDataStore Store

<PageTitle>Pengaturan | HPP Ultimate</PageTitle>

<section class="settings-page ds-page ds-admin-layout theme-indigo">
    @if (_isLoading && _snapshot is null)
    {
        <div class="skeleton-card"></div>
    }
    else if (_snapshot is not null)
    {
        <header class="settings-hero ds-page-header">
            <div class="hero-copy">
                <span class="section-tag">Pengaturan bisnis</span>
                <h1>Pengaturan workspace bisnis</h1>
                <p>Kelola identitas usaha, default operasional, dan aturan harga dari satu workspace yang lebih rapi dan cepat dibaca.</p>

                <div class="hero-meta-strip">
                    <span class="status-chip">@_statusMessage</span>
                    <span class="hero-meta-pill">@(_snapshot.CanManageSettings ? "Mode admin" : "Mode lihat saja")</span>
                    <span class="hero-meta-pill">@_snapshot.Settings.Timezone</span>
                </div>
            </div>

            <article class="hero-business-card">
                <div class="hero-business-mark">@BusinessInitials</div>
                <div class="hero-business-copy">
                    <small>Workspace aktif</small>
                    <strong>@_snapshot.Settings.BusinessName</strong>
                    <span>@(string.IsNullOrWhiteSpace(_snapshot.Settings.LegalName) ? "Identitas usaha belum dilengkapi" : _snapshot.Settings.LegalName)</span>
                </div>

                <div class="hero-actions">
                    <a class="ghost-button account-link secondary-link" href="/pengaturan/akun">Akun & akses</a>
                </div>
            </article>
        </header>

        <div class="settings-layout ds-list-detail">
            <section class="settings-primary-shell">
                <div class="primary-shell-head ds-card-header">
                    <div>
                        <span class="section-tag">Form pengaturan</span>
                        <h2>Konfigurasi inti bisnis</h2>
                        <p>Fokus utama halaman ini ada di identitas usaha, default transaksi, dan aturan harga. Panel lain hanya menjadi konteks pendukung.</p>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(_formMessage))
                {
                    <div class="form-message">@_formMessage</div>
                }

                @if (!_snapshot.CanManageSettings)
                {
                    <div class="read-only-banner">Akun staff hanya dapat melihat pengaturan. Ubah konfigurasi usaha dan clear data lewat akun admin.</div>
                }

                <EditForm Model="_formModel" OnValidSubmit="SaveAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="settings-form-stack ds-workspace-main">
                        <section class="settings-module">
                            <div class="module-head">
                                <div class="module-icon-wrap"><AppIcon Name="settings" Class="module-icon" /></div>
                                <div>
                                    <span class="module-eyebrow">Profil usaha</span>
                                    <h3>Identitas dan kontak bisnis</h3>
                                    <p>Area ini mengontrol nama usaha, legal entity, kontak, dan alamat yang dipakai di seluruh workspace.</p>
                                </div>
                            </div>

                            <div class="form-grid">
                                <label>
                                    <span>Nama Usaha</span>
                                    <InputText @bind-Value="_formModel.BusinessName" disabled="@(!_snapshot.CanManageSettings)" />
                                    <ValidationMessage For="@(() => _formModel.BusinessName)" />
                                </label>
                                <label>
                                    <span>Legal Entity</span>
                                    <InputText @bind-Value="_formModel.LegalName" disabled="@(!_snapshot.CanManageSettings)" />
                                </label>
                                <label>
                                    <span>Telepon</span>
                                    <InputText @bind-Value="_formModel.Phone" disabled="@(!_snapshot.CanManageSettings)" />
                                </label>
                                <label>
                                    <span>Email</span>
                                    <InputText @bind-Value="_formModel.Email" disabled="@(!_snapshot.CanManageSettings)" />
                                    <ValidationMessage For="@(() => _formModel.Email)" />
                                </label>
                                <label>
                                    <span>Timezone</span>
                                    <InputText @bind-Value="_formModel.Timezone" disabled="@(!_snapshot.CanManageSettings)" />
                                </label>
                                <label class="full">
                                    <span>Alamat</span>
                                    <InputTextArea @bind-Value="_formModel.Address" disabled="@(!_snapshot.CanManageSettings)" />
                                </label>
                            </div>
                        </section>

                        <section class="settings-module">
                            <div class="module-head">
                                <div class="module-icon-wrap"><AppIcon Name="materials" Class="module-icon" /></div>
                                <div>
                                    <span class="module-eyebrow">Default operasional</span>
                                    <h3>Mata uang, satuan, dan pembulatan</h3>
                                    <p>Default ini dipakai saat membuat master, menyusun resep, dan menghitung harga jual di halaman operasional lain.</p>
                                </div>
                            </div>

                            <div class="form-grid">
                                <label>
                                    <span>Mata Uang</span>
                                    <select @bind="_formModel.CurrencyCode" disabled="@(!_snapshot.CanManageSettings)">
                                        @foreach (var currency in _snapshot.Currencies)
                                        {
                                            <option value="@currency">@currency</option>
                                        }
                                    </select>
                                </label>
                                <label>
                                    <span>Default Satuan Produk</span>
                                    <select @bind="_formModel.DefaultProductUnit" disabled="@(!_snapshot.CanManageSettings)">
                                        @foreach (var unit in _snapshot.ProductUnits)
                                        {
                                            <option value="@unit">@unit</option>
                                        }
                                    </select>
                                </label>
                                <label>
                                    <span>Default Satuan Bahan</span>
                                    <select @bind="_formModel.DefaultMaterialUnit" disabled="@(!_snapshot.CanManageSettings)">
                                        @foreach (var unit in _snapshot.MaterialUnits)
                                        {
                                            <option value="@unit">@unit</option>
                                        }
                                    </select>
                                </label>
                                <label>
                                    <span>Pembulatan Harga</span>
                                    <InputNumber @bind-Value="_formModel.DefaultPriceRounding" disabled="@(!_snapshot.CanManageSettings)" />
                                    <ValidationMessage For="@(() => _formModel.DefaultPriceRounding)" />
                                </label>
                            </div>
                        </section>

                        <section class="settings-module pricing-module">
                            <div class="module-head">
                                <div class="module-icon-wrap"><AppIcon Name="bookkeeping" Class="module-icon" /></div>
                                <div>
                                    <span class="module-eyebrow">Pajak & harga</span>
                                    <h3>Aturan dasar transaksi</h3>
                                    <p>Gunakan area ini untuk menentukan persentase pajak dan apakah harga jual yang muncul di POS sudah termasuk pajak.</p>
                                </div>
                            </div>

                            <div class="pricing-module-grid">
                                <div class="form-grid compact-form-grid">
                                    <label>
                                        <span>Pajak %</span>
                                        <InputNumber @bind-Value="_formModel.TaxPercent" disabled="@(!_snapshot.CanManageSettings)" />
                                        <ValidationMessage For="@(() => _formModel.TaxPercent)" />
                                    </label>
                                    <label class="toggle-row">
                                        <span>Harga Sudah Include Pajak</span>
                                        <InputCheckbox @bind-Value="_formModel.TaxIncluded" disabled="@(!_snapshot.CanManageSettings)" />
                                    </label>
                                </div>

                                <article class="pricing-preview-card">
                                    <small>Preview aturan aktif</small>
                                    <strong>@_snapshot.Settings.TaxPercent.ToString("0.#")% pajak</strong>
                                    <span>@(_snapshot.Settings.TaxIncluded ? "Harga jual publik dibaca sebagai harga final termasuk pajak." : "Harga jual publik masih berada di luar pajak.")</span>
                                </article>
                            </div>
                        </section>

                        <section class="settings-module ai-module">
                            <div class="module-head">
                                <div class="module-icon-wrap"><AppIcon Name="settings" Class="module-icon" /></div>
                                <div>
                                    <span class="module-eyebrow">Fitur bantu</span>
                                    <h3>Gemini API key</h3>
                                    <p>API key disimpan di level workspace agar fitur bantu yang benar-benar dipakai tim, seperti baca struk belanja dan rapikan draft pembukuan, tetap membaca konfigurasi yang sama.</p>
                                </div>
                            </div>

                            <div class="pricing-module-grid">
                                <div class="form-grid compact-form-grid">
                                    <label class="full">
                                        <span>Gemini API Key</span>
                                        <input type="password"
                                               value="@_formModel.GeminiApiKey"
                                               @oninput="OnGeminiApiKeyChanged"
                                               disabled="@(!_snapshot.CanManageSettings)"
                                               placeholder="Tempel API key Gemini di sini" />
                                    </label>
                                </div>

                                <article class="pricing-preview-card ai-preview-card">
                                    <small>Status AI workspace</small>
                                    <strong>@(string.IsNullOrWhiteSpace(_snapshot.Settings.GeminiApiKey) ? "Belum aktif" : "Gemini aktif")</strong>
                                    <span>@(string.IsNullOrWhiteSpace(_snapshot.Settings.GeminiApiKey)
                                        ? "Tambahkan API key hanya jika fitur bantu AI memang ingin dipakai."
                                        : "API key sudah tersimpan di workspace ini dan siap dipakai oleh fitur bantu yang masih aktif.")</span>
                                </article>
                            </div>
                        </section>
                    </div>

                    <div class="form-actions settings-form-actions">
                        <button type="button" class="ghost-button" @onclick="ResetForm">Reset</button>
                        <button type="submit" class="primary-button" disabled="@(!_snapshot.CanManageSettings)">Simpan Pengaturan</button>
                    </div>
                </EditForm>
            </section>

            <aside class="settings-side-rail ds-side-rail">
                <section class="account-entry-card">
                    <div class="section-head">
                        <div>
                            <span>Account hub</span>
                            <h2>Akses tim dan sesi aktif</h2>
                        </div>
                    </div>

                    <div class="account-entry-grid">
                        <article>
                            <small>Sesi aktif</small>
                            <strong>@(Store.AuthSession?.FullName ?? "Belum login")</strong>
                            <p>@(Store.AuthSession is null ? "Masuk terlebih dulu untuk mengelola profil akun." : $"{FormatRole(Store.AuthSession.Role)} aktif sejak {Store.AuthSession.SignedInAt:dd MMM HH:mm}")</p>
                        </article>
                        <article>
                            <small>Total akun</small>
                            <strong>@Store.Users.Count</strong>
                            <p>Semua data akun, akses admin/staff, dan password dipusatkan di halaman akun terpisah.</p>
                        </article>
                    </div>

                    <div class="account-entry-actions">
                        <a class="primary-button account-link" href="/pengaturan/akun">Buka Tim & Akun</a>
                    </div>
                </section>

                <section class="audit-card">
                    <div class="section-head">
                        <div>
                            <span>Audit workspace</span>
                            <h2>Perubahan terbaru</h2>
                        </div>
                    </div>

                    @if (_snapshot.CanViewAuditTrail)
                    {
                        @if (_snapshot.RecentAuditEntries.Count > 0)
                        {
                            <div class="audit-list">
                                @foreach (var entry in _snapshot.RecentAuditEntries.Take(4))
                                {
                                    <article>
                                        <div class="audit-head">
                                            <span class="audit-pill">@entry.Area</span>
                                            <strong>@entry.Action</strong>
                                            <small>@entry.OccurredAt.ToString("dd MMM yyyy HH:mm")</small>
                                        </div>
                                        <p>@entry.Detail</p>
                                        <div class="audit-meta">
                                            <span>@entry.ActorName</span>
                                            <span>@entry.Subject</span>
                                        </div>
                                    </article>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="audit-restricted">Belum ada jejak perubahan yang tersimpan.</div>
                        }
                    }
                    else
                    {
                        <div class="audit-restricted">Audit trail hanya terlihat untuk admin aktif.</div>
                    }
                </section>

            </aside>
        </div>
    }
</section>

@code {
    private BusinessSettingsSnapshot? _snapshot;
    private BusinessSettingsRequest _formModel = new();
    private bool _isLoading = true;
    private string _statusMessage = "Memuat...";
    private string _formMessage = string.Empty;
    private string BusinessInitials
    {
        get
        {
            var name = _snapshot?.Settings.BusinessName;
            if (string.IsNullOrWhiteSpace(name))
            {
                return "HU";
            }

            var parts = name
                .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Take(2)
                .Select(part => char.ToUpperInvariant(part[0]));

            return string.Concat(parts);
        }
    }

    private static string FormatRole(UserRole role) => role switch
    {
        UserRole.Admin => "Admin",
        UserRole.Staff => "Staf",
        _ => role.ToString()
    };

    protected override async Task OnInitializedAsync()
    {
        Store.Changed += HandleStoreChanged;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _snapshot = await SettingsService.GetSnapshotAsync();
        _statusMessage = $"Update {_snapshot.Settings.UpdatedAt:dd MMM yyyy HH:mm}";
        SyncForm();
        _isLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveAsync()
    {
        var result = await SettingsService.SaveAsync(_formModel);
        _formMessage = result.Message;
        if (!result.Success)
        {
            return;
        }

        await LoadAsync();
    }

    private void OnGeminiApiKeyChanged(ChangeEventArgs args)
        => _formModel.GeminiApiKey = args.Value?.ToString() ?? string.Empty;

    private void ResetForm()
    {
        SyncForm();
        _formMessage = "Form dikembalikan ke nilai yang tersimpan.";
    }

    private void SyncForm()
    {
        if (_snapshot is null)
        {
            return;
        }

        _formModel = new BusinessSettingsRequest
        {
            BusinessName = _snapshot.Settings.BusinessName,
            LegalName = _snapshot.Settings.LegalName,
            Phone = _snapshot.Settings.Phone,
            Email = _snapshot.Settings.Email,
            Address = _snapshot.Settings.Address,
            CurrencyCode = _snapshot.Settings.CurrencyCode,
            DefaultProductUnit = _snapshot.Settings.DefaultProductUnit,
            DefaultMaterialUnit = _snapshot.Settings.DefaultMaterialUnit,
            DefaultPriceRounding = _snapshot.Settings.DefaultPriceRounding,
            TaxPercent = _snapshot.Settings.TaxPercent,
            TaxIncluded = _snapshot.Settings.TaxIncluded,
            Timezone = _snapshot.Settings.Timezone,
            GeminiApiKey = _snapshot.Settings.GeminiApiKey
        };
    }

    private async void HandleStoreChanged()
    {
        await InvokeAsync(async () => await LoadAsync());
    }

    public ValueTask DisposeAsync()
    {
        Store.Changed -= HandleStoreChanged;
        return ValueTask.CompletedTask;
    }
}
