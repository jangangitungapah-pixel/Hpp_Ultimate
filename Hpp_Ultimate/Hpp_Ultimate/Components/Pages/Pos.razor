        await LoadAsync();
    }

    private void OnPosAiPromptChanged(ChangeEventArgs args)
        => _posAiPrompt = args.Value?.ToString() ?? string.Empty;

    private void ResetDraft()
        => ResetCheckoutFlow();

    private void FillPosAiExamplePrompt()
    {
        var productName = _snapshot?.Products.FirstOrDefault(item => item.CanSell)?.ProductName
            ?? _snapshot?.Products.FirstOrDefault()?.ProductName
            ?? "menu aktif";
        _posAiPrompt = $"2 {productName} atas nama Dita bayar transfer bank untuk jam 18:30";
    }

    private void TogglePosAiPanel()
        => _showPosAiPanel = !_showPosAiPanel;

    private void DismissPosAiSuggestion()
    {
        _posAiSuggestion = null;
        _posAiMessage = string.Empty;
    }

    private async Task ParsePosOrderWithAiAsync()
    {
        if (_snapshot is null)
        {
            return;
        }

        _showPosAiPanel = true;
        _posAiSuggestion = null;
        _posAiMessage = "Gemini sedang membaca draft pesanan dan memilih menu yang paling cocok...";

        try
        {
            var result = await GeminiPosOrderParserService.ParseOrderAsync(new PosAiOrderRequest(
                _posAiPrompt,
                ResolveCheckoutSoldAt(),
                _snapshot.Products));

            _posAiMessage = result.Message;
            _posAiSuggestion = result.Suggestion;
        }
        finally
        {
        }
    }

    private async Task ApplyPosAiSuggestionAsync()
    {
        if (_snapshot is null || _posAiSuggestion is null || string.IsNullOrWhiteSpace(_posAiSuggestion.ProductCode))
        {
            return;
        }

        var product = _snapshot.Products.FirstOrDefault(item => string.Equals(item.ProductCode, _posAiSuggestion.ProductCode, StringComparison.OrdinalIgnoreCase));
        if (product is null)
        {
            _posAiMessage = "Menu hasil AI sudah tidak ada di daftar POS aktif.";
            return;
        }

        await SelectProductAsync(product.ProductId);
        _selectedLineQuantity = Math.Max(1, _posAiSuggestion.Quantity);
        _checkoutForm.CustomerName = _posAiSuggestion.CustomerName ?? string.Empty;
        _checkoutForm.PaymentMethod = PaymentMethods.Contains(_posAiSuggestion.PaymentMethod, StringComparer.OrdinalIgnoreCase)
            ? _posAiSuggestion.PaymentMethod
            : PaymentMethods[0];
        _checkoutForm.MarkAsPaid = _checkoutForm.PaymentMethod == "Cash";
        _checkoutForm.SoldAtInput = FormatDateTimeLocal(_posAiSuggestion.SoldAt ?? DateTime.Now);
        AddSelectedProductToDraft();
        SetMessage($"Draft checkout diisi dari AI untuk {product.ProductName}.", "success");
    }

    private async Task CompleteTransactionAsync()
    {
        if (_draftLines.Count == 0)
        {
            return;
        }

        if (!_checkoutEditContext.Validate())
        {
            SetMessage("Periksa lagi field checkout yang masih belum valid.", "error");
            return;
        }

        if (!DateTime.TryParse(_checkoutForm.SoldAtInput, CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out var soldAt))
        {
            SetMessage("Format tanggal dan jam pesanan belum valid.", "error");
            return;
        }

        _isSubmitting = true;

        try
        {
            var result = await SalesService.CheckoutAsync(new PosCheckoutRequest
            {
                CustomerName = _checkoutForm.CustomerName,
                PaymentMethod = _checkoutForm.PaymentMethod,
                MarkAsPaid = _checkoutForm.MarkAsPaid,
                AmountReceived = _checkoutForm.PaymentMethod == "Cash" || _checkoutForm.MarkAsPaid ? OrderTotal : 0m,
                SoldAt = soldAt,
                Lines = _draftLines
                    .Select(line => new PosCheckoutLineRequest
                    {
                        ProductId = line.ProductId,
                        RecipeId = line.ProductId,
                        ProductCode = line.ProductCode,
                        ProductName = line.ProductName,
                        UnitLabel = line.UnitLabel,
                        Quantity = line.Quantity,
                        UnitPrice = line.UnitPrice,
                        HppPerUnit = line.HppPerUnit
                    })
                    .ToList()
            });

            SetMessage(result.Message, result.Success ? "success" : "error");
            if (!result.Success)
            {
                return;
            }

            ResetCheckoutFlow(clearMessage: false);
            _showPosAiPanel = false;
            await LoadAsync();
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task MarkSalePaidAsync(Guid saleId)
    {
        _markingSalePaidId = saleId;

        try
        {
            var result = await SalesService.MarkSalePaidAsync(saleId);
            SetMessage(result.Message, result.Success ? "success" : "error");
            await LoadAsync();
