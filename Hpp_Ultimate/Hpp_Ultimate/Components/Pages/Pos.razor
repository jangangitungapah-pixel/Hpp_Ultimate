@page "/pos"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using System.Globalization
@inject SalesService SalesService
@inject SeededBusinessDataStore Store

<PageTitle>POS | HPP Ultimate</PageTitle>

<section class="pos-page">
    <header class="pos-header">
        <div class="header-copy">
            <span class="section-tag">POS</span>
            <h1>Kasir menu dari stok produksi yang sudah selesai.</h1>
            <p>Menu diambil dari resep yang sudah selesai diproduksi. Stok yang tampil adalah total porsi siap jual di kasir.</p>
        </div>

        <div class="header-actions">
            <div class="status-chip">@_statusMessage</div>
            <button type="button" class="ghost-button" @onclick="ReloadAsync">Refresh</button>
        </div>
    </header>

    @if (_isLoading && _snapshot is null)
    {
        <div class="table-skeleton"></div>
    }
    else if ((_snapshot?.Products.Count ?? 0) == 0)
    {
        <section class="empty-state">
            <span class="section-tag">Belum ada menu siap jual</span>
            <h2>POS belum punya stok menu</h2>
            <p>Selesaikan produksi resep lebih dulu agar jumlah porsinya masuk ke halaman POS sebagai stok menu.</p>
            <a class="primary-button action-link" href="/produksi">Buka Halaman Produksi</a>
        </section>
    }
    else if (_snapshot is not null)
    {
        <div class="workspace-grid">
            <section class="menu-panel">
                <div class="panel-head">
                    <div>
                        <span class="section-tag">List menu</span>
                        <h2>Menu dan jumlah stok</h2>
                        <p>Pilih menu dari daftar kanan untuk menyiapkan pesanan.</p>
                    </div>

                    <label class="display-count-control">
                        <span>Menu tampil</span>
                        <select value="@_menuDisplayCount" @onchange="OnMenuDisplayCountChanged">
                            @foreach (var option in GridDisplayOptions)
                            {
                                <option value="@option">@option menu</option>
                            }
                        </select>
                    </label>
                    <label class="display-count-control">
                        <span>Halaman</span>
                        <select value="@CurrentMenuPage" @onchange="OnMenuPageChanged">
                            @for (var pageNumber = 1; pageNumber <= MenuTotalPages; pageNumber++)
                            {
                                <option value="@pageNumber">Halaman @pageNumber</option>
                            }
                        </select>
                    </label>
                </div>

                <div class="search-row">
                    <input value="@_searchText" @oninput="OnSearchChangedAsync" placeholder="Cari kode atau nama menu" />
                </div>

                <div class="menu-toolbar">
                    <span>@_snapshot.Products.Count menu termuat</span>
                    <span>@_snapshot.Products.Count(item => item.CanSell) siap jual</span>
                    @if (_snapshot.SelectedProduct is not null)
                    {
                        <span>Aktif: @_snapshot.SelectedProduct.Recipe.Name</span>
                    }
                </div>

                <div class="menu-list-shell">
                    <div class="menu-list">
                        @foreach (var item in VisibleProducts)
                        {
                            <button type="button" class="menu-card @(item.ProductId == _selectedProductId ? "active" : null)" @onclick="() => SelectProductAsync(item.ProductId)">
                                <div class="menu-card-head">
                                    <div class="table-primary">
                                        <small>@item.ProductCode</small>
                                        <strong>@item.ProductName</strong>
                                    </div>
                                    <span class="badge @(item.CanSell ? "ok" : "warn")">@(item.CanSell ? "Ready" : "Kosong")</span>
                                </div>

                                <div class="menu-card-grid">
                                    <article>
                                        <small>Stok</small>
                                        <strong>@FormatDecimal(item.OnHandQuantity) @item.UnitLabel</strong>
                                    </article>
                                    <article>
                                        <small>Harga jual</small>
                                        <strong>@FormatCurrency(item.SuggestedPrice)</strong>
                                    </article>
                                </div>

                                <p class="menu-card-copy">@item.AvailabilityMessage</p>
                            </button>
                        }
                    </div>
                </div>
            </section>

            <section class="order-panel">
                @if (_snapshot.SelectedProduct is null)
                {
                    <div class="empty-state compact">
                        <h2>Pilih menu</h2>
                        <p>Pilih salah satu menu di panel kiri untuk mulai membuat pesanan.</p>
                    </div>
                }
                else
                {
                    <div class="panel-head">
                        <div>
                            <span class="section-tag">Pesanan aktif</span>
                            <h2>Detail pesanan sebelum checkout</h2>
                            <p>Atur jumlah pesanan, nama pembeli, dan metode pembayaran dari satu panel.</p>
                        </div>
                    </div>

                    <article class="selected-menu-card">
                        <div class="selected-head">
                            <div>
                                <span class="section-tag">@_snapshot.SelectedProduct.Recipe.Code</span>
                                <h3>@_snapshot.SelectedProduct.Recipe.Name</h3>
                                <p>@(string.IsNullOrWhiteSpace(_snapshot.SelectedProduct.Recipe.Description) ? "Menu aktif siap dijual dari hasil produksi terakhir." : _snapshot.SelectedProduct.Recipe.Description)</p>
                            </div>

                            <span class="badge @(_snapshot.SelectedProduct.OnHandQuantity > 0 ? "ok" : "warn")">
                                @(_snapshot.SelectedProduct.OnHandQuantity > 0 ? "Siap jual" : "Stok kosong")
                            </span>
                        </div>

                        <div class="selected-metrics">
                            <article>
                                <small>Stok menu</small>
                                <strong>@FormatDecimal(_snapshot.SelectedProduct.OnHandQuantity) @_snapshot.SelectedProduct.Recipe.PortionUnit</strong>
                            </article>
                            <article>
                                <small>HPP / satuan</small>
                                <strong>@FormatCurrency(_snapshot.SelectedProduct.HppPerUnit)</strong>
                            </article>
                            <article>
                                <small>Harga jual</small>
                                <strong>@FormatCurrency(_snapshot.SelectedProduct.SuggestedPrice)</strong>
                            </article>
                            <article>
                                <small>Margin</small>
                                <strong>@FormatPercent(_snapshot.SelectedProduct.SuggestedPrice <= 0 ? 0m : Math.Max(0m, (_snapshot.SelectedProduct.SuggestedPrice - _snapshot.SelectedProduct.HppPerUnit) / _snapshot.SelectedProduct.SuggestedPrice) * 100m)</strong>
                            </article>
                        </div>
                    </article>

                    @if (!string.IsNullOrWhiteSpace(_message))
                    {
                        <div class="form-message">@_message</div>
                    }

                    @if (_snapshot.SelectedProduct.OnHandQuantity <= 0)
                    {
                        <div class="inline-note">Stok menu ini kosong. Selesaikan produksi dulu sebelum melakukan checkout.</div>
                    }
                    else if (_draftQuantity > _snapshot.SelectedProduct.OnHandQuantity)
                    {
                        <div class="inline-note">Jumlah pesanan melebihi stok yang tersedia.</div>
                    }

                    <section class="checkout-card">
                        <div class="form-grid">
                            <label>
                                <span>Jumlah pesanan</span>
                                <input type="number" min="1" step="1" value="@_draftQuantity" @oninput="OnDraftQuantityChanged" />
                            </label>

                            <label>
                                <span>Nama pembeli / pemesan</span>
                                <input type="text" value="@_customerName" @oninput="OnCustomerNameChanged" placeholder="Contoh: Bapak Andi" />
                            </label>

                            <label class="wide-field">
                                <span>Tanggal & jam pesanan</span>
                                <input type="datetime-local" value="@FormatDateTimeLocal(_soldAt)" @onchange="OnSoldAtChanged" />
                            </label>
                        </div>

                        <div class="payment-section">
                            <span class="field-label">Pembayaran</span>
                            <div class="method-row">
                                @foreach (var method in PaymentMethods)
                                {
                                    <button type="button" class="method-chip @(_paymentMethod == method ? "active" : null)" @onclick="() => SelectPaymentMethod(method)">@method</button>
                                }
                            </div>
                        </div>

                        <div class="summary-card">
                            <div class="summary-row">
                                <span>Total porsi</span>
                                <strong>@_draftQuantity @_snapshot.SelectedProduct.Recipe.PortionUnit</strong>
                            </div>
                            <div class="summary-row">
                                <span>Total bayar</span>
                                <strong>@FormatCurrency(OrderTotal)</strong>
                            </div>
                            <div class="summary-row">
                                <span>Estimasi profit</span>
                                <strong>@FormatCurrency(OrderProfit)</strong>
                            </div>
                            <div class="summary-row">
                                <span>Status pembayaran</span>
                                <strong>@(_paymentMethod == "Cash" ? "Lunas otomatis" : "Menunggu pelunasan")</strong>
                            </div>
                        </div>

                        <div class="checkout-actions">
                            <button type="button" class="ghost-button" @onclick="ResetDraft">Reset</button>
                            <button type="button" class="primary-button" disabled="@(!CanCheckout)" @onclick="CompleteTransactionAsync">Check Out</button>
                        </div>
                    </section>
                }
            </section>
        </div>

        <section class="history-card">
            <div class="panel-head">
                <div>
                    <span class="section-tag">History pesanan</span>
                    <h2>Datagrid pesanan dan penjualan</h2>
                    <p>Pesanan yang sudah checkout akan muncul di sini. Gunakan checklist untuk menandai pembayaran transfer sudah lunas.</p>
                </div>

                <label class="display-count-control">
                    <span>Baris tampil</span>
                    <select value="@_historyDisplayCount" @onchange="OnHistoryDisplayCountChanged">
                        @foreach (var option in GridDisplayOptions)
                        {
                            <option value="@option">@option baris</option>
                        }
                    </select>
                </label>
                <label class="display-count-control">
                    <span>Halaman</span>
                    <select value="@CurrentHistoryPage" @onchange="OnHistoryPageChanged">
                        @for (var pageNumber = 1; pageNumber <= HistoryTotalPages; pageNumber++)
                        {
                            <option value="@pageNumber">Halaman @pageNumber</option>
                        }
                    </select>
                </label>
            </div>

            @if (_snapshot.RecentSales.Count == 0)
            {
                <div class="empty-state compact">
                    <h2>Belum ada pesanan</h2>
                    <p>Checkout pertama akan langsung masuk ke datagrid history ini.</p>
                </div>
            }
            else
            {
                <div class="history-grid-shell">
                    <QuickGrid Items="VisibleRecentSales.AsQueryable()" Class="history-quickgrid">
                        <TemplateColumn Title="Pesanan" Context="item">
                            <div class="table-primary">
                                <strong>@item.MenuSummary</strong>
                                <small>@item.ReceiptNumber</small>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Pembeli" Context="item">
                            <div class="table-primary">
                                <strong>@item.CustomerName</strong>
                                <small>@item.CashierName</small>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Qty" Context="item">
                            <div class="history-meta-cell">
                                <strong>@item.TotalQuantity</strong>
                                <small>@item.PaymentMethod</small>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Total" Context="item">
                            <div class="history-meta-cell">
                                <strong>@FormatCurrency(item.GrossRevenue)</strong>
                                <small>Profit @FormatCurrency(item.GrossProfit)</small>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Lunas" Context="item">
                            <span class="badge @(item.IsPaid ? "ok" : "warn")">
                                @(item.IsPaid ? "Lunas" : "Pending")
                            </span>
                        </TemplateColumn>
                        <TemplateColumn Title="Waktu" Context="item">
                            <div class="history-meta-cell">
                                <strong>@item.SoldAt.ToString("dd MMM yyyy")</strong>
                                <small>@item.SoldAt.ToString("HH:mm")</small>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Aksi" Context="item">
                            <div class="history-actions">
                                @if (!item.IsPaid && item.Status == SaleStatus.Completed)
                                {
                                    <button type="button" class="icon-button success" @onclick="() => MarkSalePaidAsync(item.Id)" title="Tandai lunas">
                                        <span class="icon-glyph">&#10003;</span>
                                    </button>
                                }
                                else
                                {
                                    <span class="history-done-text">Selesai</span>
                                }
                            </div>
                        </TemplateColumn>
                    </QuickGrid>
                </div>

                <div class="history-card-list">
                    @foreach (var item in VisibleRecentSales)
                    {
                        <article class="history-mobile-card">
                            <div class="history-mobile-head">
                                <div class="table-primary">
                                    <strong>@item.MenuSummary</strong>
                                    <small>@item.ReceiptNumber</small>
                                </div>

                                <span class="badge @(item.IsPaid ? "ok" : "warn")">
                                    @(item.IsPaid ? "Lunas" : "Pending")
                                </span>
                            </div>

                            <div class="history-mobile-grid">
                                <article>
                                    <small>Pembeli</small>
                                    <strong>@item.CustomerName</strong>
                                    <span>@item.CashierName</span>
                                </article>
                                <article>
                                    <small>Qty</small>
                                    <strong>@item.TotalQuantity</strong>
                                    <span>@item.PaymentMethod</span>
                                </article>
                                <article>
                                    <small>Total</small>
                                    <strong>@FormatCurrency(item.GrossRevenue)</strong>
                                    <span>Profit @FormatCurrency(item.GrossProfit)</span>
                                </article>
                                <article>
                                    <small>Waktu</small>
                                    <strong>@item.SoldAt.ToString("dd MMM yyyy")</strong>
                                    <span>@item.SoldAt.ToString("HH:mm")</span>
                                </article>
                            </div>

                            <div class="history-mobile-actions">
                                @if (!item.IsPaid && item.Status == SaleStatus.Completed)
                                {
                                    <button type="button" class="icon-button success" @onclick="() => MarkSalePaidAsync(item.Id)" title="Tandai lunas">
                                        <span class="icon-glyph">&#10003;</span>
                                    </button>
                                }
                                else
                                {
                                    <span class="history-done-text">Selesai</span>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    }
</section>

@code {
    private static readonly string[] PaymentMethods = ["Cash", "Transfer Bank"];
    private static readonly int[] GridDisplayOptions = [8, 12, 20, 50];

    private PosSnapshot? _snapshot;
    private bool _isLoading = true;
    private string _statusMessage = "Memuat POS...";
    private string _searchText = string.Empty;
    private Guid? _selectedProductId;
    private int _draftQuantity = 1;
    private string _customerName = string.Empty;
    private string _paymentMethod = PaymentMethods[0];
    private DateTime _soldAt = DateTime.Now;
    private string _message = string.Empty;
    private int _menuDisplayCount = 12;
    private int _menuPage = 1;
    private int _historyDisplayCount = 12;
    private int _historyPage = 1;

    private decimal OrderTotal => _snapshot?.SelectedProduct is null ? 0m : _snapshot.SelectedProduct.SuggestedPrice * _draftQuantity;
    private decimal OrderProfit => _snapshot?.SelectedProduct is null ? 0m : (_snapshot.SelectedProduct.SuggestedPrice - _snapshot.SelectedProduct.HppPerUnit) * _draftQuantity;
    private int MenuTotalPages => CalculateTotalPages(_snapshot?.Products.Count ?? 0, _menuDisplayCount);
    private int CurrentMenuPage => ClampPage(_menuPage, MenuTotalPages);
    private IReadOnlyList<PosProductOption> VisibleProducts
        => (_snapshot?.Products ?? Array.Empty<PosProductOption>())
            .Skip((CurrentMenuPage - 1) * _menuDisplayCount)
            .Take(_menuDisplayCount)
            .ToArray();
    private int HistoryTotalPages => CalculateTotalPages(_snapshot?.RecentSales.Count ?? 0, _historyDisplayCount);
    private int CurrentHistoryPage => ClampPage(_historyPage, HistoryTotalPages);
    private IReadOnlyList<PosSalesHistoryItem> VisibleRecentSales
        => (_snapshot?.RecentSales ?? Array.Empty<PosSalesHistoryItem>())
            .Skip((CurrentHistoryPage - 1) * _historyDisplayCount)
            .Take(_historyDisplayCount)
            .ToArray();
    private bool CanCheckout
        => _snapshot?.SelectedProduct is not null
            && _draftQuantity > 0
            && !string.IsNullOrWhiteSpace(_customerName)
            && _snapshot.SelectedProduct.OnHandQuantity >= _draftQuantity;

    protected override async Task OnInitializedAsync()
    {
        Store.Changed += HandleStoreChanged;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _snapshot = await SalesService.GetPosSnapshotAsync(_searchText, _selectedProductId);
        _menuPage = CurrentMenuPage;
        _historyPage = CurrentHistoryPage;
        _selectedProductId = _snapshot.SelectedProductId;
        _statusMessage = _snapshot.Products.Count == 0
            ? "Belum ada menu aktif."
            : $"{_snapshot.Products.Count} menu termuat";
        _isLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private Task ReloadAsync() => LoadAsync();

    private async Task OnSearchChangedAsync(ChangeEventArgs args)
    {
        _searchText = args.Value?.ToString() ?? string.Empty;
        _menuPage = 1;
        await LoadAsync();
    }

    private void OnMenuDisplayCountChanged(ChangeEventArgs args)
    {
        _menuDisplayCount = ParseDisplayCount(args.Value?.ToString(), _menuDisplayCount);
        _menuPage = 1;
    }

    private void OnMenuPageChanged(ChangeEventArgs args)
        => _menuPage = ParsePage(args.Value?.ToString(), CurrentMenuPage, MenuTotalPages);

    private void OnHistoryDisplayCountChanged(ChangeEventArgs args)
    {
        _historyDisplayCount = ParseDisplayCount(args.Value?.ToString(), _historyDisplayCount);
        _historyPage = 1;
    }

    private void OnHistoryPageChanged(ChangeEventArgs args)
        => _historyPage = ParsePage(args.Value?.ToString(), CurrentHistoryPage, HistoryTotalPages);

    private async Task SelectProductAsync(Guid productId)
    {
        _selectedProductId = productId;
        _draftQuantity = 1;
        _message = string.Empty;
        await LoadAsync();
    }

    private void OnDraftQuantityChanged(ChangeEventArgs args)
        => _draftQuantity = int.TryParse(args.Value?.ToString(), NumberStyles.Integer, CultureInfo.InvariantCulture, out var value) && value > 0 ? value : 1;

    private void OnCustomerNameChanged(ChangeEventArgs args)
        => _customerName = args.Value?.ToString() ?? string.Empty;

    private void OnSoldAtChanged(ChangeEventArgs args)
        => _soldAt = ParseDateTimeLocal(args.Value?.ToString(), _soldAt);

    private void SelectPaymentMethod(string method)
        => _paymentMethod = method;

    private void ResetDraft()
    {
        _draftQuantity = 1;
        _customerName = string.Empty;
        _paymentMethod = PaymentMethods[0];
        _soldAt = DateTime.Now;
        _message = string.Empty;
    }

    private async Task CompleteTransactionAsync()
    {
        if (_snapshot?.SelectedProduct is null)
        {
            return;
        }

        var result = await SalesService.CheckoutAsync(new PosCheckoutRequest
        {
            CustomerName = _customerName,
            PaymentMethod = _paymentMethod,
            AmountReceived = _paymentMethod == "Cash" ? OrderTotal : 0m,
            SoldAt = _soldAt,
            Lines =
            [
                new PosCheckoutLineRequest
                {
                    ProductId = _snapshot.SelectedProduct.Recipe.Id,
                    RecipeId = _snapshot.SelectedProduct.Recipe.Id,
                    ProductCode = _snapshot.SelectedProduct.Recipe.Code,
                    ProductName = _snapshot.SelectedProduct.Recipe.Name,
                    UnitLabel = _snapshot.SelectedProduct.Recipe.PortionUnit,
                    Quantity = _draftQuantity,
                    UnitPrice = _snapshot.SelectedProduct.SuggestedPrice,
                    HppPerUnit = _snapshot.SelectedProduct.HppPerUnit
                }
            ]
        });

        _message = result.Message;
        if (!result.Success)
        {
            return;
        }

        ResetDraft();
        await LoadAsync();
    }

    private async Task MarkSalePaidAsync(Guid saleId)
    {
        var result = await SalesService.MarkSalePaidAsync(saleId);
        _message = result.Message;
        await LoadAsync();
    }

    private static string FormatCurrency(decimal value)
        => string.Create(new CultureInfo("id-ID"), $"Rp {value:N0}");

    private static string FormatDecimal(decimal value)
        => value.ToString("0.##", CultureInfo.InvariantCulture);

    private static string FormatPercent(decimal value)
        => $"{decimal.Round(value, 1, MidpointRounding.AwayFromZero).ToString("0.#", CultureInfo.InvariantCulture)}%";

    private static string FormatDateTimeLocal(DateTime value)
        => value.ToString("yyyy-MM-ddTHH:mm", CultureInfo.InvariantCulture);

    private static DateTime ParseDateTimeLocal(string? value, DateTime fallback)
        => DateTime.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out var parsed)
            ? parsed
            : fallback;

    private static int ParseDisplayCount(string? value, int fallback)
        => int.TryParse(value, out var parsed) && parsed > 0 ? parsed : fallback;

    private static int ParsePage(string? value, int fallback, int totalPages)
        => int.TryParse(value, out var parsed) && parsed > 0
            ? Math.Min(parsed, Math.Max(1, totalPages))
            : fallback;

    private static int CalculateTotalPages(int totalItems, int pageSize)
        => Math.Max(1, (int)Math.Ceiling(totalItems / (double)Math.Max(1, pageSize)));

    private static int ClampPage(int page, int totalPages)
        => Math.Min(Math.Max(1, page), Math.Max(1, totalPages));

    private async void HandleStoreChanged()
        => await InvokeAsync(LoadAsync);

    public ValueTask DisposeAsync()
    {
        Store.Changed -= HandleStoreChanged;
        return ValueTask.CompletedTask;
    }
}
