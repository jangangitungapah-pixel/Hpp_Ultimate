@page "/pos"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using System.ComponentModel.DataAnnotations
@using System.Globalization
@using Microsoft.JSInterop
@inject SalesService SalesService
@inject GeminiPosOrderParserService GeminiPosOrderParserService
@inject SeededBusinessDataStore Store
@inject IJSRuntime JS

<PageTitle>Kasir / POS | HPP Ultimate</PageTitle>

<section class="pos-page ds-page ds-page-stack theme-amber">
    <header class="pos-header ds-page-header">
        <div class="header-copy">
            <span class="section-tag">Kasir / POS</span>
            <h1>Checkout kasir</h1>
            <p>Pilih menu siap jual, masukkan ke pesanan, lalu selesaikan pembayaran dari workspace yang sama.</p>
        </div>
    </header>

    @if (_isLoading && _snapshot is null)
    {
        <div class="table-skeleton"></div>
    }
    else if (_snapshot is not null && _snapshot.Products.Count == 0 && string.IsNullOrWhiteSpace(_searchText))
    {
        <section class="empty-state">
            <span class="section-tag">Belum ada menu siap jual</span>
            <h2>Kasir / POS belum punya stok menu</h2>
            <p>Selesaikan produksi resep lebih dulu agar jumlah porsinya masuk ke halaman kasir / POS sebagai stok menu.</p>
            <a class="primary-button action-link" href="/produksi">Buka Halaman Produksi</a>
        </section>
    }
    else if (_snapshot is not null)
    {
        <div class="workspace-grid @(_draftLines.Count == 0 ? "menu-first-layout" : null)">
            <section class="menu-panel catalog-datagrid">
                <div class="panel-head ds-card-header">
                    <div>
                        <span class="section-tag">List menu</span>
                        <h2>Pilih menu siap jual</h2>
                        <p>Daftar kiri dipadatkan untuk scan cepat. Pilih satu menu untuk mengisi panel checkout.</p>
                    </div>
                </div>

                <div class="menu-toolbar-row">
                    <label class="search-row search-field">
                        <span>Cari menu</span>
                        <input value="@_searchText" @oninput="OnSearchChangedAsync" placeholder="Cari kode atau nama menu" aria-label="Cari kode atau nama menu kasir / POS" />
                    </label>

                    <label class="display-count-control compact">
                        <span>Menu tampil</span>
                        <select value="@_menuDisplayCount" @onchange="OnMenuDisplayCountChanged">
                            @foreach (var option in GridDisplayOptions)
                            {
                                <option value="@option">@option menu</option>
                            }
                        </select>
                    </label>
                </div>

                <div class="menu-toolbar-meta">
                    <p class="panel-summary">@MenuInventorySummary</p>

                    @if (!string.IsNullOrWhiteSpace(_searchText))
                    {
                        <span class="toolbar-note">Filter aktif: "@_searchText"</span>
                    }
                </div>

                @if (_snapshot.Products.Count == 0)
                {
                    <div class="empty-state compact">
                        <h2>Tidak ada menu yang cocok</h2>
                        <p>Ubah kata kunci pencarian atau reset filter untuk melihat menu yang siap dijual.</p>
                    </div>
                }
                else
                {
                    <div class="menu-list">
                        @foreach (var item in VisibleProducts)
                        {
                            <button type="button"
                                    class="menu-card @(item.ProductId == _selectedProductId ? "active" : null)"
                                    @onclick="() => SelectProductAsync(item.ProductId)"
                                    aria-pressed="@(item.ProductId == _selectedProductId)">
                                <div class="menu-card-head">
                                    <div class="table-primary">
                                        <small>@item.ProductCode</small>
                                        <strong>@item.ProductName</strong>
                                    </div>
                                    <span class="badge @(item.CanSell ? "ok" : "warn")">@(item.CanSell ? "Ready" : "Kosong")</span>
                                </div>

                                <div class="menu-card-grid">
                                    <article>
                                        <small>Stok</small>
                                        <strong>@FormatDecimal(item.OnHandQuantity) @item.UnitLabel</strong>
                                    </article>
                                    <article>
                                        <small>Harga jual</small>
                                        <strong>@FormatCurrency(item.SuggestedPrice)</strong>
                                    </article>
                                </div>
                            </button>
                        }
                    </div>

                    <div class="table-footer">
                        <small>@_snapshot.Products.Count menu</small>
                        <div class="pager">
                            <button type="button" @onclick="PrevMenuPage" disabled="@(CurrentMenuPage <= 1)">Prev</button>
                            <label class="pager-select">
                                <select value="@CurrentMenuPage" aria-label="Pilih halaman menu kasir / POS" @onchange="OnMenuPageChanged">
                                    @for (var pageNumber = 1; pageNumber <= MenuTotalPages; pageNumber++)
                                    {
                                        <option value="@pageNumber">Halaman @pageNumber</option>
                                    }
                                </select>
                            </label>
                            <span>@CurrentMenuPage / @MenuTotalPages</span>
                            <button type="button" @onclick="NextMenuPage" disabled="@(CurrentMenuPage >= MenuTotalPages)">Next</button>
                        </div>
                        <div class="table-footer-spacer" aria-hidden="true"></div>
                    </div>
                }
            </section>

            <section class="order-panel @(_draftLines.Count == 0 ? "compact-order-panel" : null)">
                <div class="panel-head order-panel-head ds-card-header">
                    <div>
                        <span class="section-tag">Pesanan aktif</span>
                        <h2>Bangun pesanan lalu checkout</h2>
                        <p>Pilih menu dari panel kiri, masukkan item ke pesanan aktif, lalu selesaikan pembayaran dalam satu checkout.</p>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(_message))
                {
                    <div class="@GetMessageClass()" aria-live="polite">@_message</div>
                }

                @if (_snapshot.SelectedProduct is null && _draftLines.Count == 0)
                {
                    <div class="empty-state compact">
                        <h2>Pilih menu dulu</h2>
                        <p>Pilih salah satu menu dari panel kiri untuk mulai membangun pesanan aktif.</p>
                    </div>
                }
                else
                {
                    @if (_snapshot.SelectedProduct is not null)
                    {
                        <article class="selected-menu-card">
                            <div class="selected-head">
                                <div>
                                    <span class="section-tag">@_snapshot.SelectedProduct.Recipe.Code</span>
                                    <h3>@_snapshot.SelectedProduct.Recipe.Name</h3>
                                    <p>@(string.IsNullOrWhiteSpace(_snapshot.SelectedProduct.Recipe.Description) ? "Menu aktif siap ditambahkan ke pesanan." : _snapshot.SelectedProduct.Recipe.Description)</p>
                                </div>
                            </div>

                            <div class="selected-metrics compact">
                                <article>
                                    <small>Stok menu</small>
                                    <strong>@FormatDecimal(_snapshot.SelectedProduct.OnHandQuantity) @_snapshot.SelectedProduct.Recipe.PortionUnit</strong>
                                </article>
                                <article>
                                    <small>HPP / satuan</small>
                                    <strong>@FormatCurrency(_snapshot.SelectedProduct.HppPerUnit)</strong>
                                </article>
                                <article>
                                    <small>Harga jual</small>
                                    <strong>@FormatCurrency(_snapshot.SelectedProduct.SuggestedPrice)</strong>
                                </article>
                            </div>

                            <div class="selected-entry-row">
                                <label class="line-qty-field">
                                    <span>Qty masuk ke pesanan</span>
                                    <InputNumber TValue="int" @bind-Value="_selectedLineQuantity" />
                                </label>

                                <button type="button"
                                        class="primary-button"
                                        disabled="@(!CanAddSelectedProduct)"
                                        @onclick="AddSelectedProductToDraft">
                                    Masukkan ke Pesanan
                                </button>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(SelectedProductStockWarning))
                            {
                                <div class="inline-note warn-note">@SelectedProductStockWarning</div>
                            }
                        </article>
                    }

                    <section class="checkout-draft-card">
                        <div class="section-head ds-card-header">
                            <div>
                                <span class="section-tag">Item pesanan</span>
                                <h3>Ringkas menu yang akan di-checkout</h3>
                                <p>Jumlah item bisa diubah langsung di sini tanpa mengulang flow checkout per menu.</p>
                            </div>
                        </div>

                        @if (_draftLines.Count == 0)
                        {
                            <div class="empty-state compact">
                                <h2>Pesanan masih kosong</h2>
                                <p>Pilih menu dari panel kiri lalu masukkan ke pesanan aktif.</p>
                            </div>
                        }
                        else
                        {
                            <div class="checkout-draft-list">
                                @foreach (var line in _draftLines)
                                {
                                    <article class="checkout-draft-item">
                                        <div class="checkout-draft-main">
                                            <div class="table-primary">
                                                <strong>@line.ProductName</strong>
                                                <small>@line.ProductCode</small>
                                            </div>

                                            <div class="checkout-draft-price">
                                                <small>@FormatCurrency(line.UnitPrice) / item</small>
                                                <strong>@FormatCurrency(line.UnitPrice * line.Quantity)</strong>
                                            </div>
                                        </div>

                                        <div class="checkout-draft-controls">
                                            <div class="qty-stepper">
                                                <button type="button" class="icon-button" aria-label="Kurangi jumlah item" @onclick="() => DecreaseDraftLineQuantity(line.ProductId)">-</button>
                                                <strong>@line.Quantity @line.UnitLabel</strong>
                                                <button type="button" class="icon-button" aria-label="Tambah jumlah item" @onclick="() => IncreaseDraftLineQuantity(line.ProductId)">+</button>
                                            </div>

                                            <button type="button" class="icon-button" aria-label="Hapus item pesanan" @onclick="() => RemoveDraftLine(line.ProductId)">
                                                <AppIcon Name="delete" Class="icon-glyph" />
                                            </button>
                                        </div>

                                        @if (GetDraftLineWarning(line) is string draftWarning)
                                        {
                                            <div class="inline-note warn-note compact-note">@draftWarning</div>
                                        }
                                    </article>
                                }
                            </div>
                        }
                    </section>

                    @if (_draftLines.Count == 0)
                    {
                        <article class="order-empty-glance">
                            <small>Checkout aktif</small>
                            <strong>Pesanan masih kosong.</strong>
                            <span>@(_snapshot.SelectedProduct is null
                                ? "Pilih satu menu dari panel kiri untuk mulai membangun checkout."
                                : "Gunakan panel menu aktif di atas untuk menambahkan item pertama ke pesanan. Form checkout penuh baru muncul setelah ada item di cart.")</span>
                        </article>
                    }
                    else
                    {
                        <EditForm EditContext="_checkoutEditContext" OnValidSubmit="CompleteTransactionAsync" class="checkout-card">
                            <DataAnnotationsValidator />

                            <div class="form-grid compact-checkout-grid">
                                <label>
                                    <span>Nama pembeli / pemesan</span>
                                    <InputText @bind-Value="_checkoutForm.CustomerName" placeholder="Contoh: Bapak Andi" />
                                    <ValidationMessage For="@(() => _checkoutForm.CustomerName)" />
                                </label>

                                <label>
                                    <span>Tanggal & jam pesanan</span>
                                    <InputText @bind-Value="_checkoutForm.SoldAtInput" type="datetime-local" />
                                    <ValidationMessage For="@(() => _checkoutForm.SoldAtInput)" />
                                </label>
                            </div>

                            <div class="payment-section">
                                <div class="field-head">
                                    <span class="field-label">Metode pembayaran</span>
                                    <small>Pilih metode bayar, lalu tentukan apakah uangnya sudah benar-benar masuk saat checkout.</small>
                                </div>
                                <div class="method-row">
                                    @foreach (var method in PaymentMethods)
                                    {
                                        <button type="button"
                                                class="method-chip @(_checkoutForm.PaymentMethod == method ? "active" : null)"
                                                aria-pressed="@(_checkoutForm.PaymentMethod == method)"
                                                @onclick="() => SelectPaymentMethod(method)">
                                            @method
                                        </button>
                                    }
                                </div>
                                <ValidationMessage For="@(() => _checkoutForm.PaymentMethod)" />
                            </div>

                            @if (_checkoutForm.PaymentMethod == "Transfer Bank")
                            {
                                <div class="payment-section settlement-section">
                                    <div class="field-head">
                                        <span class="field-label">Status pelunasan</span>
                                        <small>Pilih <em>Sudah masuk</em> jika transfer sudah diterima saat checkout.</small>
                                    </div>
                                    <div class="method-row">
                                        <button type="button"
                                                class="method-chip @(_checkoutForm.MarkAsPaid ? "active" : null)"
                                                aria-pressed="@_checkoutForm.MarkAsPaid"
                                                @onclick="() => SetTransferSettlement(true)">
                                            Sudah masuk
                                        </button>
                                        <button type="button"
                                                class="method-chip @(!_checkoutForm.MarkAsPaid ? "active" : null)"
                                                aria-pressed="@(!_checkoutForm.MarkAsPaid)"
                                                @onclick="() => SetTransferSettlement(false)">
                                            Belum lunas
                                        </button>
                                    </div>
                                </div>
                            }

                            <div class="summary-card">
                                <div class="summary-row">
                                    <span>Item menu</span>
                                    <strong>@_draftLines.Count line</strong>
                                </div>
                                <div class="summary-row">
                                    <span>Total porsi</span>
                                    <strong>@TotalDraftQuantity item</strong>
                                </div>
                                <div class="summary-row">
                                    <span>Total bayar</span>
                                    <strong>@FormatCurrency(OrderTotal)</strong>
                                </div>
                                <div class="summary-row">
                                    <span>Status pembayaran</span>
                                    <strong>@PaymentStatusLabel</strong>
                                </div>
                            </div>

                            <div class="submit-confidence-note">
                                Checkout ini akan membuat transaksi penjualan untuk semua item di pesanan aktif. Jika metode bayar adalah transfer dan uang sudah diterima sekarang, pilih <em>Sudah masuk</em> supaya tidak perlu follow-up lagi di history.
                            </div>

                            <div class="checkout-actions">
                                <button type="button" class="ghost-button" @onclick="ResetDraft">Kosongkan Pesanan</button>
                                <button type="submit" class="primary-button" disabled="@(!CanCheckout)">
                                    @(_isSubmitting ? "Menyimpan..." : "Check Out")
                                </button>
                            </div>
                        </EditForm>
                    }
                }
            </section>
        </div>

        <section class="history-card catalog-datagrid" id="pos-history">
            <div class="panel-head ds-card-header">
                <div>
                    <span class="section-tag">History pesanan</span>
                    <h2>Datagrid pesanan dan penjualan</h2>
                    <p>Checkout yang selesai langsung masuk ke history. Transfer bank bisa ditandai lunas dari sini.</p>
                </div>

                <label class="display-count-control compact">
                    <span>Baris tampil</span>
                    <select value="@_historyDisplayCount" @onchange="OnHistoryDisplayCountChanged">
                        @foreach (var option in GridDisplayOptions)
                        {
                            <option value="@option">@option baris</option>
                        }
                    </select>
                </label>
            </div>

            <div class="menu-toolbar-meta history-toolbar-meta">
                <p class="panel-summary">@HistorySummary</p>
            </div>

            @if (_historyTotalCount == 0)
            {
                <div class="empty-state compact">
                    <h2>Belum ada pesanan</h2>
                    <p>Checkout pertama akan langsung masuk ke datagrid history ini.</p>
                </div>
            }
            else
            {
                @if (!_isCompactHistory)
                {
                <div class="history-grid-shell">
                    <QuickGrid Items="VisibleRecentSales.AsQueryable()" Class="history-quickgrid">
                        <TemplateColumn Title="Pesanan" Context="item">
                            <div class="table-primary">
                                <strong>@item.MenuSummary</strong>
                                <small>@item.ReceiptNumber</small>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Pembeli" Context="item">
                            <div class="table-primary">
                                <strong>@item.CustomerName</strong>
                                <small>@item.CashierName</small>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Qty" Context="item">
                            <div class="history-meta-cell">
                                <strong>@item.TotalQuantity</strong>
                                <small>@item.PaymentMethod</small>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Total" Context="item">
                            <div class="history-meta-cell">
                                <strong>@FormatCurrency(item.GrossRevenue)</strong>
                                <small>Profit @FormatCurrency(item.GrossProfit)</small>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Status" Context="item">
                            <span class="badge @(item.IsPaid ? "ok" : "warn")">
                                @(item.IsPaid ? "Lunas" : "Pending")
                            </span>
                        </TemplateColumn>
                        <TemplateColumn Title="Waktu" Context="item">
                            <div class="history-meta-cell">
                                <strong>@item.SoldAt.ToString("dd MMM yy")</strong>
                                <small>@item.SoldAt.ToString("HH:mm")</small>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Aksi" Context="item">
                            <div class="history-actions">
                                @if (!item.IsPaid && item.Status == SaleStatus.Completed)
                                {
                                    <button type="button"
                                            class="icon-button success"
                                            disabled="@(_markingSalePaidId == item.Id)"
                                            aria-label="Tandai lunas"
                                            title="Tandai lunas"
                                            @onclick="() => MarkSalePaidAsync(item.Id)">
                                        <AppIcon Name="check" Class="icon-glyph" />
                                    </button>
                                }
                            </div>
                        </TemplateColumn>
                    </QuickGrid>
                </div>
                }
                else
                {
                <div class="history-card-list">
                    @foreach (var item in VisibleRecentSales)
                    {
                        <article class="history-mobile-card">
                            <div class="history-mobile-head">
                                <div class="table-primary">
                                    <strong>@item.MenuSummary</strong>
                                    <small>@item.ReceiptNumber</small>
                                </div>

                                <span class="badge @(item.IsPaid ? "ok" : "warn")">
                                    @(item.IsPaid ? "Lunas" : "Pending")
                                </span>
                            </div>

                            <div class="history-mobile-grid">
                                <article>
                                    <small>Pembeli</small>
                                    <strong>@item.CustomerName</strong>
                                    <span>@item.CashierName</span>
                                </article>
                                <article>
                                    <small>Qty</small>
                                    <strong>@item.TotalQuantity</strong>
                                    <span>@item.PaymentMethod</span>
                                </article>
                                <article>
                                    <small>Total</small>
                                    <strong>@FormatCurrency(item.GrossRevenue)</strong>
                                    <span>Profit @FormatCurrency(item.GrossProfit)</span>
                                </article>
                                <article>
                                    <small>Waktu</small>
                                    <strong>@item.SoldAt.ToString("dd MMM yy")</strong>
                                    <span>@item.SoldAt.ToString("HH:mm")</span>
                                </article>
                            </div>

                            @if (!item.IsPaid && item.Status == SaleStatus.Completed)
                            {
                                <div class="history-mobile-actions">
                                    <button type="button"
                                            class="icon-button success"
                                            disabled="@(_markingSalePaidId == item.Id)"
                                            aria-label="Tandai lunas"
                                            title="Tandai lunas"
                                            @onclick="() => MarkSalePaidAsync(item.Id)">
                                        <AppIcon Name="check" Class="icon-glyph" />
                                    </button>
                                </div>
                            }
                        </article>
                    }
                </div>
                }

                <div class="table-footer">
                    <small>@_historyTotalCount pesanan</small>
                    <div class="pager">
                        <button type="button" @onclick="PrevPosHistoryPage" disabled="@(CurrentHistoryPage <= 1)">Prev</button>
                        <label class="pager-select">
                            <select value="@CurrentHistoryPage" aria-label="Pilih halaman history kasir / POS" @onchange="OnHistoryPageChanged">
                                @for (var pageNumber = 1; pageNumber <= HistoryTotalPages; pageNumber++)
                                {
                                    <option value="@pageNumber">Halaman @pageNumber</option>
                                }
                            </select>
                        </label>
                        <span>@CurrentHistoryPage / @HistoryTotalPages</span>
                        <button type="button" @onclick="NextPosHistoryPage" disabled="@(CurrentHistoryPage >= HistoryTotalPages)">Next</button>
                    </div>
                    <div class="table-footer-spacer" aria-hidden="true"></div>
                </div>
            }
        </section>
    }
</section>

@code {
    private static readonly string[] PaymentMethods = ["Cash", "Transfer Bank"];
    private static readonly int[] GridDisplayOptions = [8, 12, 20, 50];

    private PosSnapshot? _snapshot;
    private IReadOnlyList<PosSalesHistoryItem> _historyItems = Array.Empty<PosSalesHistoryItem>();
    private IReadOnlyList<PosProductOption> _visibleProducts = Array.Empty<PosProductOption>();
    private IReadOnlyList<PosSalesHistoryItem> _visibleRecentSales = Array.Empty<PosSalesHistoryItem>();
    private bool _isLoading = true;
    private bool _isSubmitting;
    private bool _showPosAiPanel;
    private bool _isCompactHistory;
    private Guid? _markingSalePaidId;
    private string _searchText = string.Empty;
    private Guid? _selectedProductId;
    private string _message = string.Empty;
    private string _messageTone = "info";
    private string _posAiPrompt = string.Empty;
    private string _posAiMessage = string.Empty;
    private PosAiOrderSuggestion? _posAiSuggestion;
    private readonly List<PosDraftLine> _draftLines = [];
    private int _menuDisplayCount = 12;
    private int _menuPage = 1;
    private int _historyDisplayCount = 12;
    private int _historyPage = 1;
    private int _selectedLineQuantity = 1;
    private int _historyTotalCount;
    private CancellationTokenSource? _searchDebounce;
    private DotNetObjectReference<Pos>? _viewportReference;
    private int? _viewportRegistrationId;
    private PosCheckoutFormModel _checkoutForm = default!;
    private EditContext _checkoutEditContext = default!;

    private decimal OrderTotal => _draftLines.Sum(item => item.UnitPrice * item.Quantity);
    private decimal OrderProfit => _draftLines.Sum(item => (item.UnitPrice - item.HppPerUnit) * item.Quantity);
    private int TotalDraftQuantity => _draftLines.Sum(item => item.Quantity);
    private int MenuTotalPages => CalculateTotalPages(_snapshot?.Products.Count ?? 0, _menuDisplayCount);
    private int CurrentMenuPage => ClampPage(_menuPage, MenuTotalPages);
    private IReadOnlyList<PosProductOption> VisibleProducts => _visibleProducts;
    private int HistoryTotalPages => CalculateTotalPages(_historyTotalCount, _historyDisplayCount);
    private int CurrentHistoryPage => ClampPage(_historyPage, HistoryTotalPages);
    private IReadOnlyList<PosSalesHistoryItem> VisibleRecentSales => _visibleRecentSales;
    private string MenuInventorySummary
        => _snapshot is null
            ? "Memuat menu..."
            : _snapshot.Products.Count == 0
                ? "Belum ada menu yang cocok dengan filter aktif."
                : $"{_snapshot.Products.Count(item => item.CanSell)} siap jual dari {_snapshot.Products.Count} menu";
    private string HistorySummary
        => _snapshot is null
            ? "Memuat history..."
            : $"{_historyTotalCount} pesanan tercatat, {VisibleRecentSales.Count} tampil di halaman ini";
    private bool CanAddSelectedProduct
        => _snapshot?.SelectedProduct is not null
            && _selectedLineQuantity > 0
            && GetRemainingStock(_snapshot.SelectedProduct.Recipe.Id) >= _selectedLineQuantity;
    private bool CanCheckout
        => !_isSubmitting
            && _draftLines.Count > 0
            && !string.IsNullOrWhiteSpace(_checkoutForm.CustomerName)
            && !string.IsNullOrWhiteSpace(_checkoutForm.PaymentMethod)
            && !string.IsNullOrWhiteSpace(_checkoutForm.SoldAtInput)
            && DateTime.TryParse(_checkoutForm.SoldAtInput, CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out _)
            && !_draftLines.Any(line => line.Quantity > GetAvailableStock(line.ProductId));
    private string PaymentStatusLabel
        => _checkoutForm.PaymentMethod == "Cash" || _checkoutForm.MarkAsPaid
            ? "Lunas"
            : "Belum lunas";
    private string? SelectedProductStockWarning
        => _snapshot?.SelectedProduct is null
            ? null
            : _snapshot.SelectedProduct.OnHandQuantity <= 0
                ? "Stok menu ini kosong. Selesaikan produksi dulu sebelum menambahkan ke pesanan."
                : GetRemainingStock(_snapshot.SelectedProduct.Recipe.Id) <= 0
                    ? "Stok menu ini sudah habis dipakai di pesanan aktif."
                    : _selectedLineQuantity > GetRemainingStock(_snapshot.SelectedProduct.Recipe.Id)
                        ? $"Jumlah yang dimasukkan melebihi sisa stok {FormatDecimal(GetRemainingStock(_snapshot.SelectedProduct.Recipe.Id))} {_snapshot.SelectedProduct.Recipe.PortionUnit}."
                        : null;

    protected override async Task OnInitializedAsync()
    {
        InitializeCheckoutForm();
        Store.Changed += HandleStoreChanged;
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _viewportReference = DotNetObjectReference.Create(this);
        _viewportRegistrationId = await JS.InvokeAsync<int>("viewportHelper.register", _viewportReference, nameof(HandleHistoryViewportChanged), 960);
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        var posTask = SalesService.GetPosSnapshotAsync(_searchText, _selectedProductId);
        var historyTask = SalesService.GetHistorySnapshotAsync();

        await Task.WhenAll(posTask, historyTask);

        _snapshot = posTask.Result;
        var historySnapshot = historyTask.Result;
        _historyItems = historySnapshot.Items;
        _historyTotalCount = historySnapshot.TotalCount;
        _selectedProductId = _snapshot.SelectedProductId;
        RefreshVisibleCollections();
        _isLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private Task ReloadAsync() => LoadAsync();

