    private void RefreshVisibleCollections()
    {
        RefreshVisibleProducts();
        RefreshVisibleRecentSales();
    }

    private void RefreshVisibleProducts()
    {
        var items = _snapshot?.Products ?? Array.Empty<PosProductOption>();
        _menuPage = ClampPage(_menuPage, CalculateTotalPages(items.Count, _menuDisplayCount));
        _visibleProducts = items
            .Skip((CurrentMenuPage - 1) * _menuDisplayCount)
            .Take(_menuDisplayCount)
            .ToArray();
    }

    private void RefreshVisibleRecentSales()
    {
        var items = _historyItems;
        _historyPage = ClampPage(_historyPage, CalculateTotalPages(items.Count, _historyDisplayCount));
        _visibleRecentSales = items
            .Skip((CurrentHistoryPage - 1) * _historyDisplayCount)
            .Take(_historyDisplayCount)
            .ToArray();
    }

    private void InitializeCheckoutForm()
    {
        _checkoutForm = CreateCheckoutForm();
        _checkoutEditContext = new EditContext(_checkoutForm);
    }

    private void ResetCheckoutForm(bool clearMessage = true)
    {
        InitializeCheckoutForm();
        _selectedLineQuantity = 1;
        if (clearMessage)
        {
            _message = string.Empty;
        }
    }

    private void ResetCheckoutFlow(bool clearMessage = true)
    {
        _draftLines.Clear();
        ResetCheckoutForm(clearMessage);
    }

    private void AddSelectedProductToDraft()
    {
        if (_snapshot?.SelectedProduct is null)
        {
            SetMessage("Pilih menu dulu sebelum menambah item ke pesanan.", "error");
            return;
        }

        if (_selectedLineQuantity <= 0)
        {
            SetMessage("Jumlah item yang dimasukkan harus minimal 1.", "error");
            return;
        }

        var product = _snapshot.SelectedProduct;
        var draftQuantity = GetDraftQuantity(product.Recipe.Id);
        var available = GetAvailableStock(product.Recipe.Id);
        if (draftQuantity + _selectedLineQuantity > available)
        {
            SetMessage($"Stok {product.Recipe.Name} tidak cukup. Sisa stok yang belum dipakai di pesanan aktif adalah {FormatDecimal(Math.Max(0m, available - draftQuantity))} {product.Recipe.PortionUnit}.", "error");
            return;
        }

        var existingIndex = _draftLines.FindIndex(item => item.ProductId == product.Recipe.Id);
        if (existingIndex >= 0)
        {
            var existing = _draftLines[existingIndex];
            _draftLines[existingIndex] = existing with { Quantity = existing.Quantity + _selectedLineQuantity };
        }
        else
        {
            _draftLines.Add(new PosDraftLine(
                product.Recipe.Id,
                product.Recipe.Code,
                product.Recipe.Name,
                product.Recipe.PortionUnit,
                _selectedLineQuantity,
                product.SuggestedPrice,
                product.HppPerUnit));
        }

        _selectedLineQuantity = 1;
        SetMessage($"{product.Recipe.Name} ditambahkan ke pesanan aktif.", "success");
    }

    private void IncreaseDraftLineQuantity(Guid productId)
    {
        var index = _draftLines.FindIndex(item => item.ProductId == productId);
        if (index < 0)
        {
            return;
        }

        var existing = _draftLines[index];
        var available = GetAvailableStock(productId);
        if (existing.Quantity >= available)
        {
            SetMessage($"Stok {existing.ProductName} tidak cukup untuk menambah item lagi.", "error");
            return;
        }

        _draftLines[index] = existing with { Quantity = existing.Quantity + 1 };
        _message = string.Empty;
    }

    private void DecreaseDraftLineQuantity(Guid productId)
    {
        var index = _draftLines.FindIndex(item => item.ProductId == productId);
        if (index < 0)
        {
            return;
        }

        var existing = _draftLines[index];
        if (existing.Quantity <= 1)
        {
            _draftLines.RemoveAt(index);
            return;
        }

        _draftLines[index] = existing with { Quantity = existing.Quantity - 1 };
        _message = string.Empty;
    }

    private void RemoveDraftLine(Guid productId)
    {
        _draftLines.RemoveAll(item => item.ProductId == productId);
        _message = string.Empty;
    }

    private int GetDraftQuantity(Guid productId)
        => _draftLines.FirstOrDefault(item => item.ProductId == productId)?.Quantity ?? 0;

    private decimal GetAvailableStock(Guid productId)
        => InventoryMath.GetRecipeMenuOnHand(Store, productId);

    private decimal GetRemainingStock(Guid productId)
        => GetAvailableStock(productId) - GetDraftQuantity(productId);

    private string? GetDraftLineWarning(PosDraftLine line)
        => line.Quantity > GetAvailableStock(line.ProductId)
            ? $"Qty {line.ProductName} melebihi stok aktif {FormatDecimal(GetAvailableStock(line.ProductId))} {line.UnitLabel}."
            : null;

    private void SetMessage(string message, string tone)
    {
        _message = message;
        _messageTone = tone;
    }

    private string GetMessageClass() => $"form-message {_messageTone}-message";

    private DateTime ResolveCheckoutSoldAt()
        => DateTime.TryParse(_checkoutForm.SoldAtInput, CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out var soldAt)
            ? soldAt
            : DateTime.Now;

    private static PosCheckoutFormModel CreateCheckoutForm()
        => new()
        {
            CustomerName = string.Empty,
            PaymentMethod = PaymentMethods[0],
            MarkAsPaid = true,
            SoldAtInput = FormatDateTimeLocal(DateTime.Now)
        };

    private static string FormatCurrency(decimal value)
        => string.Create(new CultureInfo("id-ID"), $"Rp {value:N0}");

    private static string FormatDecimal(decimal value)
        => value.ToString("0.##", CultureInfo.InvariantCulture);

    private string? ResolvePosAiProductName(string? productCode)
        => string.IsNullOrWhiteSpace(productCode)
            ? null
            : _snapshot?.Products.FirstOrDefault(item => string.Equals(item.ProductCode, productCode, StringComparison.OrdinalIgnoreCase))?.ProductName;

    private static string FormatDateTimeLocal(DateTime value)
        => value.ToString("yyyy-MM-ddTHH:mm", CultureInfo.InvariantCulture);

    private static int ParseDisplayCount(string? value, int fallback)
        => int.TryParse(value, out var parsed) && parsed > 0 ? parsed : fallback;

    private static int ParsePage(string? value, int fallback, int totalPages)
        => int.TryParse(value, out var parsed) && parsed > 0
            ? Math.Min(parsed, Math.Max(1, totalPages))
            : fallback;

    private static int CalculateTotalPages(int totalItems, int pageSize)
        => Math.Max(1, (int)Math.Ceiling(totalItems / (double)Math.Max(1, pageSize)));

    private static int ClampPage(int page, int totalPages)
        => Math.Min(Math.Max(1, page), Math.Max(1, totalPages));

    private void HandleStoreChanged()
        => _ = InvokeAsync(LoadAsync);

    [JSInvokable]
    public Task HandleHistoryViewportChanged(bool isCompact)
    {
        if (_isCompactHistory == isCompact)
        {
            return Task.CompletedTask;
        }

        _isCompactHistory = isCompact;
        StateHasChanged();
        return Task.CompletedTask;
    }

    public ValueTask DisposeAsync()
    {
        _searchDebounce?.Cancel();
        _searchDebounce?.Dispose();
        Store.Changed -= HandleStoreChanged;

        return DisposeViewportAsync();
    }

    private async ValueTask DisposeViewportAsync()
    {
        if (_viewportRegistrationId is int registrationId)
        {
            try
            {
                await JS.InvokeVoidAsync("viewportHelper.unregister", registrationId);
            }
            catch
            {
            }
        }

        _viewportReference?.Dispose();
    }

    private sealed class PosCheckoutFormModel
    {
        [Required(ErrorMessage = "Nama pembeli wajib diisi.")]
        public string CustomerName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Waktu pesanan wajib diisi.")]
        [ValidDateTimeLocal(ErrorMessage = "Format tanggal dan jam pesanan belum valid.")]
        public string SoldAtInput { get; set; } = string.Empty;

        [Required(ErrorMessage = "Pilih metode pembayaran.")]
        public string PaymentMethod { get; set; } = string.Empty;

        public bool MarkAsPaid { get; set; } = true;
    }

    private sealed record PosDraftLine(
        Guid ProductId,
        string ProductCode,
        string ProductName,
        string UnitLabel,
        int Quantity,
        decimal UnitPrice,
        decimal HppPerUnit);

    private sealed class ValidDateTimeLocalAttribute : ValidationAttribute
    {
        protected override ValidationResult? IsValid(object? value, ValidationContext validationContext)
        {
            var text = value?.ToString();
            if (string.IsNullOrWhiteSpace(text))
            {
                return ValidationResult.Success;
            }

            return DateTime.TryParse(text, CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out _)
                ? ValidationResult.Success
                : new ValidationResult(ErrorMessage ?? "Format tanggal dan jam pesanan belum valid.");
        }
    }
