@page "/riwayat-produksi"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject ProductionHistoryService ProductionHistoryService
@inject IBusinessDataStore DataStore

<PageTitle>Riwayat Produksi | HPP Ultimate</PageTitle>

<section class="history-page">
    <div class="history-toolbar">
        <div>
            <span>Production memory</span>
            <h1>Lacak batch lama, buka detail biaya, lalu bandingkan antar batch.</h1>
        </div>

        <div class="toolbar-stack">
            <div class="period-switch">
                @foreach (var preset in Presets)
                {
                    <button type="button"
                            class="@(preset == _preset ? "active" : null)"
                            @onclick="() => ApplyPresetAsync(preset)">
                        @GetPresetLabel(preset)
                    </button>
                }
            </div>

            <div class="filter-row">
                <input value="@_searchText" @oninput="OnSearchChanged" placeholder="Cari batch, produk, atau kode" />

                <select value="@(_selectedProductId?.ToString() ?? string.Empty)" @onchange="OnProductChangedAsync">
                    <option value="">Semua produk</option>
                    @foreach (var product in _snapshot?.Products ?? Array.Empty<ProductFilterOption>())
                    {
                        <option value="@product.Id">@product.Name</option>
                    }
                </select>

                @if (_preset == DashboardPeriodPreset.Custom)
                {
                    <InputDate @bind-Value="_customFrom" class="date-input" />
                    <InputDate @bind-Value="_customTo" class="date-input" />
                    <button type="button" class="ghost-button" @onclick="ApplyCustomRangeAsync">Terapkan</button>
                }

                <a class="ghost-button" href="@CsvDownloadHref" download="@($"{_snapshot?.ExportFileName}.csv")">Export CSV</a>
            </div>
        </div>
    </div>

    @if (_isLoading && _snapshot is null)
    {
        <div class="table-skeleton"></div>
    }
    else if (_snapshot is not null)
    {
        <div class="summary-grid">
            <article>
                <small>Total batch</small>
                <strong>@_snapshot.Summary.BatchCount</strong>
            </article>
            <article>
                <small>Total output</small>
                <strong>@_snapshot.Summary.TotalUnits.ToString("N0") unit</strong>
            </article>
            <article>
                <small>Total biaya</small>
                <strong>@FormatCurrency(_snapshot.Summary.TotalCost)</strong>
            </article>
            <article>
                <small>Biaya rata-rata / unit</small>
                <strong>@FormatCurrency(_snapshot.Summary.AverageCostPerUnit)</strong>
            </article>
        </div>

        <div class="history-layout">
            <section class="table-card">
                <div class="table-head">
                    <div>
                        <span>Arsip batch</span>
                        <h2>Riwayat batch untuk @_snapshot.Range.Label.ToLowerInvariant()</h2>
                    </div>
                    <div class="status-chip">@_statusMessage</div>
                </div>

                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th><button type="button" @onclick='() => SortByAsync("batch")'>Batch</button></th>
                                <th><button type="button" @onclick='() => SortByAsync("product")'>Produk</button></th>
                                <th><button type="button" @onclick='() => SortByAsync("date")'>Tanggal</button></th>
                                <th><button type="button" @onclick='() => SortByAsync("qty")'>Qty</button></th>
                                <th><button type="button" @onclick='() => SortByAsync("total")'>Total</button></th>
                                <th><button type="button" @onclick='() => SortByAsync("hpp")'>HPP</button></th>
                                <th><button type="button" @onclick='() => SortByAsync("profit")'>Profit</button></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (PagedRows.Count == 0)
                            {
                                <tr>
                                    <td colspan="7" class="empty-row">Belum ada batch pada filter ini.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var row in PagedRows)
                                {
                                    <tr class="@GetRowClass(row)" @onclick="() => SelectBatchAsync(row.BatchId)">
                                        <td>
                                            <strong>@row.BatchCode</strong>
                                            <small>@row.ProductCode</small>
                                        </td>
                                        <td>@row.ProductName</td>
                                        <td>@row.ProducedAt.ToString("dd MMM yyyy")</td>
                                        <td>@row.QuantityProduced.ToString("N0") unit</td>
                                        <td>@FormatCurrency(row.TotalCost)</td>
                                        <td>@FormatCurrency(row.HppPerUnit)</td>
                                        <td class="@(row.Profit >= 0 ? "profit-text" : "loss-text")">@FormatCurrency(row.Profit)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <div class="table-footer">
                    <small>@_snapshot.Rows.Count batch ditemukan</small>
                    <div class="pager">
                        <button type="button" @onclick="PrevPageAsync" disabled="@(_page <= 1)">Prev</button>
                        <span>Halaman @_page / @TotalPages</span>
                        <button type="button" @onclick="NextPageAsync" disabled="@(_page >= TotalPages)">Next</button>
                    </div>
                </div>
            </section>

            <aside class="detail-stack">
                <section class="detail-card">
                    @if (_detail is null)
                    {
                        <div class="detail-empty">
                            <span>Detail batch</span>
                            <h2>Pilih batch untuk melihat komposisi biaya dan analisis.</h2>
                        </div>
                    }
                    else
                    {
                        <div class="detail-head">
                            <div>
                                <span>@_detail.Current.BatchCode</span>
                                <h2>@_detail.Current.ProductName</h2>
                                <small>@_detail.Current.ProducedAt.ToString("dd MMM yyyy") - @_detail.Current.QuantityProduced.ToString("N0") unit</small>
                            </div>

                            <select value="@(_compareBatchId?.ToString() ?? string.Empty)" @onchange="OnCompareChangedAsync">
                                <option value="">Bandingkan dengan batch lain</option>
                                @foreach (var batch in CompareOptions)
                                {
                                    <option value="@batch.BatchId">@batch.BatchCode</option>
                                }
                            </select>
                        </div>

                        <div class="metric-grid">
                            <article>
                                <small>Biaya bahan</small>
                                <strong>@FormatCurrency(_detail.Current.MaterialCost)</strong>
                            </article>
                            <article>
                                <small>Tenaga kerja</small>
                                <strong>@FormatCurrency(_detail.Current.LaborCost)</strong>
                            </article>
                            <article>
                                <small>Overhead</small>
                                <strong>@FormatCurrency(_detail.Current.OverheadCost)</strong>
                            </article>
                            <article>
                                <small>HPP / Unit</small>
                                <strong>@FormatCurrency(_detail.Current.HppPerUnit)</strong>
                            </article>
                        </div>

                        <div class="note-list">
                            @foreach (var note in _detail.Notes)
                            {
                                <article>@note</article>
                            }
                        </div>

                        <div class="materials-card">
                            <div class="section-head">
                                <div>
                                    <span>Komposisi batch</span>
                                    <h3>Bahan yang terpakai</h3>
                                </div>
                            </div>

                            <div class="materials-list">
                                @foreach (var item in _detail.Materials)
                                {
                                    <article>
                                        <div>
                                            <strong>@item.MaterialName</strong>
                                            <small>@item.MaterialCode</small>
                                        </div>
                                        <div class="material-meta">
                                            <strong>@item.TotalQuantity.ToString("N2") @item.Unit</strong>
                                            <small>@FormatCurrency(item.LineCost)</small>
                                        </div>
                                    </article>
                                }
                            </div>
                        </div>
                    }
                </section>

                <section class="compare-card">
                    <div class="section-head">
                        <div>
                            <span>Compare batch</span>
                            <h2>Deviasi terhadap batch pembanding</h2>
                        </div>
                    </div>

                    @if (_detail?.Comparison is null)
                    {
                        <div class="detail-empty compact">
                            <span>Belum ada pembanding</span>
                            <h2>Pilih batch kedua untuk melihat deviasi biaya dan output.</h2>
                        </div>
                    }
                    else
                    {
                        <div class="comparison-grid">
                            <article>
                                <small>Delta output</small>
                                <strong class="@(_detail.Comparison.DeltaQuantity >= 0 ? "profit-text" : "loss-text")">@_detail.Comparison.DeltaQuantity.ToString("N0") unit</strong>
                            </article>
                            <article>
                                <small>Delta total biaya</small>
                                <strong class="@(_detail.Comparison.DeltaTotalCost <= 0 ? "profit-text" : "loss-text")">@FormatCurrency(_detail.Comparison.DeltaTotalCost)</strong>
                            </article>
                            <article>
                                <small>Delta HPP / unit</small>
                                <strong class="@(_detail.Comparison.DeltaHppPerUnit <= 0 ? "profit-text" : "loss-text")">@FormatCurrency(_detail.Comparison.DeltaHppPerUnit)</strong>
                            </article>
                            <article>
                                <small>Delta margin</small>
                                <strong class="@(_detail.Comparison.DeltaMarginPercentage >= 0 ? "profit-text" : "loss-text")">@_detail.Comparison.DeltaMarginPercentage.ToString("0.0")%</strong>
                            </article>
                        </div>

                        <div class="note-list">
                            @foreach (var note in _detail.Comparison.Notes)
                            {
                                <article>@note</article>
                            }
                        </div>
                    }
                </section>

                <section class="insight-card">
                    <div class="section-head">
                        <div>
                            <span>Insight batch</span>
                            <h2>Ringkasan pola biaya pada periode ini</h2>
                        </div>
                    </div>

                    <div class="note-list">
                        @foreach (var insight in _snapshot.Insights)
                        {
                            <article>@insight</article>
                        }
                    </div>
                </section>
            </aside>
        </div>
    }
</section>

@code {
    private readonly DashboardPeriodPreset[] Presets =
    [
        DashboardPeriodPreset.Today,
        DashboardPeriodPreset.ThisWeek,
        DashboardPeriodPreset.ThisMonth,
        DashboardPeriodPreset.Custom
    ];

    private const int PageSize = 8;

    private ProductionHistorySnapshot? _snapshot;
    private ProductionHistoryDetail? _detail;
    private bool _isLoading = true;
    private string _statusMessage = "Memuat data...";
    private string _searchText = string.Empty;
    private Guid? _selectedProductId;
    private Guid? _compareBatchId;
    private DashboardPeriodPreset _preset = DashboardPeriodPreset.ThisMonth;
    private DateOnly? _customFrom = DateOnly.FromDateTime(DateTime.Today.AddDays(-29));
    private DateOnly? _customTo = DateOnly.FromDateTime(DateTime.Today);
    private string _sortBy = "date";
    private bool _sortDescending = true;
    private int _page = 1;
    private CancellationTokenSource? _searchDebounce;

    private IReadOnlyList<ProductionHistoryRow> PagedRows =>
        (_snapshot?.Rows ?? Array.Empty<ProductionHistoryRow>())
            .Skip((_page - 1) * PageSize)
            .Take(PageSize)
            .ToArray();

    private int TotalPages => Math.Max(1, (int)Math.Ceiling((_snapshot?.Rows.Count ?? 0) / (double)PageSize));

    private IReadOnlyList<ProductionHistoryRow> CompareOptions =>
        (_snapshot?.Rows ?? Array.Empty<ProductionHistoryRow>())
            .Where(item => _detail is not null && item.BatchId != _detail.Current.BatchId && item.ProductId == _detail.Current.ProductId)
            .Take(12)
            .ToArray();

    private string CsvDownloadHref => _snapshot is null
        ? string.Empty
        : $"data:text/csv;charset=utf-8,{Uri.EscapeDataString(_snapshot.ExportCsv)}";

    protected override async Task OnInitializedAsync()
    {
        DataStore.Changed += HandleStoreChanged;
        await LoadAsync();
    }

    private async Task LoadAsync(bool keepSelection = true)
    {
        _isLoading = true;
        _snapshot = await ProductionHistoryService.QueryAsync(new ProductionHistoryQuery(_searchText, _selectedProductId, _preset, _customFrom, _customTo, _sortBy, _sortDescending));
        _statusMessage = $"{_snapshot.Rows.Count} batch - {_snapshot.Range.Label}";
        _isLoading = false;

        if (_page > TotalPages)
        {
            _page = TotalPages;
        }

        if (_snapshot.Rows.Count == 0)
        {
            _detail = null;
            await InvokeAsync(StateHasChanged);
            return;
        }

        var targetBatchId = keepSelection && _detail is not null && _snapshot.Rows.Any(item => item.BatchId == _detail.Current.BatchId)
            ? _detail.Current.BatchId
            : _snapshot.Rows[0].BatchId;

        await SelectBatchAsync(targetBatchId);
    }

    private async Task SelectBatchAsync(Guid batchId)
    {
        _detail = await ProductionHistoryService.GetDetailAsync(batchId, _compareBatchId);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ApplyPresetAsync(DashboardPeriodPreset preset)
    {
        _preset = preset;
        _compareBatchId = null;
        if (preset != DashboardPeriodPreset.Custom)
        {
            _customFrom = null;
            _customTo = null;
        }

        _page = 1;
        await LoadAsync(false);
    }

    private async Task ApplyCustomRangeAsync()
    {
        _preset = DashboardPeriodPreset.Custom;
        _compareBatchId = null;
        _page = 1;
        await LoadAsync(false);
    }

    private async Task OnProductChangedAsync(ChangeEventArgs args)
    {
        _selectedProductId = Guid.TryParse(args.Value?.ToString(), out var parsed) ? parsed : null;
        _compareBatchId = null;
        _page = 1;
        await LoadAsync(false);
    }

    private async Task OnSearchChanged(ChangeEventArgs args)
    {
        _searchText = args.Value?.ToString() ?? string.Empty;
        _page = 1;
        _searchDebounce?.Cancel();
        _searchDebounce?.Dispose();
        _searchDebounce = new CancellationTokenSource();

        try
        {
            await Task.Delay(350, _searchDebounce.Token);
            await LoadAsync(false);
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task SortByAsync(string column)
    {
        if (_sortBy.Equals(column, StringComparison.OrdinalIgnoreCase))
        {
            _sortDescending = !_sortDescending;
        }
        else
        {
            _sortBy = column;
            _sortDescending = column is "date" or "total" or "hpp" or "profit";
        }

        await LoadAsync();
    }

    private async Task OnCompareChangedAsync(ChangeEventArgs args)
    {
        _compareBatchId = Guid.TryParse(args.Value?.ToString(), out var parsed) ? parsed : null;
        if (_detail is not null)
        {
            await SelectBatchAsync(_detail.Current.BatchId);
        }
    }

    private async Task PrevPageAsync()
    {
        _page = Math.Max(1, _page - 1);
        await LoadAsync();
    }

    private async Task NextPageAsync()
    {
        _page = Math.Min(TotalPages, _page + 1);
        await LoadAsync();
    }

    private async void HandleStoreChanged()
    {
        await InvokeAsync(async () => await LoadAsync());
    }

    private string GetRowClass(ProductionHistoryRow row)
        => _detail?.Current.BatchId == row.BatchId ? "selected-row" : string.Empty;

    private static string GetPresetLabel(DashboardPeriodPreset preset) => preset switch
    {
        DashboardPeriodPreset.Today => "Hari ini",
        DashboardPeriodPreset.ThisWeek => "Minggu ini",
        DashboardPeriodPreset.ThisMonth => "Bulan ini",
        DashboardPeriodPreset.Custom => "Custom",
        _ => preset.ToString()
    };

    private static string FormatCurrency(decimal value)
        => string.Create(new System.Globalization.CultureInfo("id-ID"), $"Rp {value:N0}");

    public ValueTask DisposeAsync()
    {
        DataStore.Changed -= HandleStoreChanged;

        if (_searchDebounce is not null)
        {
            _searchDebounce.Cancel();
            _searchDebounce.Dispose();
        }

        return ValueTask.CompletedTask;
    }
}
