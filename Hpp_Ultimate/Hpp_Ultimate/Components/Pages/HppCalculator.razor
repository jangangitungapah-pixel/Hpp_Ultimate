@page "/hpp-calculator"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject HppCalculatorService HppCalculatorService
@inject SeededBusinessDataStore Store

<PageTitle>HPP Calculator | HPP Ultimate</PageTitle>

<section class="hpp-page">
    <header class="hpp-header">
        <div class="header-copy">
            <span class="section-tag">HPP Calculator</span>
            <h1>Hitung HPP resep dengan alur yang lebih singkat.</h1>
            <p>Pilih resep, atur output aktual dan margin, lalu audit sumber biayanya hanya jika memang perlu.</p>
        </div>

        <div class="header-actions">
            <div class="status-chip">@_statusMessage</div>
            <button type="button" class="ghost-button" @onclick="ReloadAsync">Refresh</button>
        </div>
    </header>

    @if (_isLoading && _snapshot is null)
    {
        <div class="skeleton-card"></div>
    }
    else if ((_snapshot?.Recipes.Count ?? 0) == 0)
    {
        <section class="empty-state">
            <span class="section-tag">Belum ada sumber</span>
            <h2>Resep masih kosong</h2>
            <p>Buat resep dulu di halaman resep supaya kalkulator punya formula untuk dihitung menjadi HPP.</p>
            <a class="primary-button action-link" href="/resep">Buka Halaman Resep</a>
        </section>
    }
    else if (_snapshot is not null && _snapshot.Breakdown is not null)
    {
        var breakdown = _snapshot.Breakdown;

        <div class="hpp-layout">
            <aside class="recipe-browser">
                <div class="browser-head">
                    <div>
                        <span class="section-tag">Sumber resep</span>
                        <h2>Pilih resep</h2>
                        <p>Gunakan pencarian untuk mempercepat pilih formula yang ingin dihitung.</p>
                    </div>

                    <input class="recipe-search-input" value="@_searchText" @oninput="OnSearchChangedAsync" placeholder="Cari kode atau nama resep" />
                </div>

                <div class="recipe-browser-list">
                    @foreach (var recipe in _snapshot.Recipes)
                    {
                        <button type="button" class="recipe-option @(recipe.Id == breakdown.RecipeId ? "active" : null)" @onclick="() => SelectRecipeAsync(recipe.Id)">
                            <div class="recipe-option-top">
                                <div>
                                    <small>@recipe.Code</small>
                                    <strong>@recipe.Name</strong>
                                </div>
                                <span class="badge @(recipe.Status == RecipeStatus.Active ? "active" : "inactive")">@GetStatusLabel(recipe.Status)</span>
                            </div>

                            <div class="recipe-option-kpis">
                                <span>@FormatCurrency(recipe.HppPerPortion) / porsi</span>
                                <span>@FormatDecimal(recipe.OutputQuantity) @recipe.OutputUnit</span>
                                <span>@recipe.MaterialCount material</span>
                            </div>

                            <div class="recipe-option-footer">
                                <span>@recipe.UpdatedAt.ToString("dd MMM yyyy HH:mm")</span>
                            </div>
                        </button>
                    }
                </div>
            </aside>

            <div class="hpp-workspace">
                <section class="recipe-summary-card">
                    <div class="recipe-summary-head">
                        <div class="recipe-summary-copy">
                            <span class="section-tag">@breakdown.Code</span>
                            <h2>@breakdown.Name</h2>
                            @if (!string.IsNullOrWhiteSpace(breakdown.Description))
                            {
                                <p>@breakdown.Description</p>
                            }
                        </div>

                        <div class="recipe-meta-chips">
                            <span>@GetStatusLabel(breakdown.Status)</span>
                            <span>@FormatDecimal(breakdown.Summary.PlannedOutputQuantity) @breakdown.Summary.OutputUnit</span>
                            <span>@FormatDecimal(breakdown.Summary.PortionYield) porsi</span>
                            <span>@breakdown.UpdatedAt.ToString("dd MMM yyyy HH:mm")</span>
                        </div>
                    </div>

                    <div class="primary-metrics">
                        <article>
                            <small>Total batch</small>
                            <strong>@FormatCurrency(breakdown.Summary.TotalBatchCost)</strong>
                        </article>
                        <article>
                            <small>HPP / porsi</small>
                            <strong>@FormatCurrency(breakdown.Summary.HppPerPortion)</strong>
                        </article>
                        <article>
                            <small>HPP final / porsi</small>
                            <strong>@FormatCurrency(breakdown.Summary.HppAfterTax)</strong>
                        </article>
                        <article class="highlight">
                            <small>Harga jual target</small>
                            <strong>@FormatCurrency(GetSuggestedSellingPrice(breakdown.Summary))</strong>
                        </article>
                    </div>
                </section>

                <section class="calculator-card">
                    <div class="calculator-layout">
                        <div class="control-stack">
                            <section class="control-card">
                                <div class="section-head">
                                    <div>
                                        <span class="section-tag">Simulasi output</span>
                                        <h3>Output aktual</h3>
                                    </div>
                                </div>

                                <div class="control-grid">
                                    <label>
                                        <span>Output resep</span>
                                        <input value="@($"{FormatDecimal(breakdown.Summary.PlannedOutputQuantity)} {breakdown.Summary.OutputUnit}")" readonly />
                                    </label>
                                    <label>
                                        <span>Porsi resep</span>
                                        <input value="@($"{FormatDecimal(breakdown.Summary.PortionYield)} porsi")" readonly />
                                    </label>
                                    <label>
                                        <span>Output aktual</span>
                                        <input type="number" step="0.01" min="0.0001" value="@GetRealizedOutputValue()" @oninput="OnRealizedOutputChangedAsync" />
                                    </label>
                                </div>

                                <div class="inline-note-card">
                                    <small>Catatan</small>
                                    <strong>@GetScenarioLabel(breakdown.Summary)</strong>
                                </div>
                            </section>

                            <section class="control-card">
                                <div class="section-head">
                                    <div>
                                        <span class="section-tag">Margin</span>
                                        <h3>Target margin</h3>
                                    </div>
                                </div>

                                <div class="margin-panel">
                                    <div class="margin-head">
                                        <div>
                                            <small>Margin target</small>
                                            <strong>@_marginPercent.ToString("0")%</strong>
                                        </div>
                                        <input class="margin-number" type="number" min="0" max="300" step="1" value="@_marginPercent.ToString("0")" @oninput="OnMarginChanged" />
                                    </div>

                                    <input class="margin-slider" type="range" min="0" max="300" step="1" value="@_marginPercent.ToString("0")" @oninput="OnMarginChanged" />

                                    <div class="slider-scale">
                                        <button type="button" @onclick="() => SetMargin(20m)">20%</button>
                                        <button type="button" @onclick="() => SetMargin(35m)">35%</button>
                                        <button type="button" @onclick="() => SetMargin(50m)">50%</button>
                                        <button type="button" @onclick="() => SetMargin(75m)">75%</button>
                                    </div>
                                </div>
                            </section>
                        </div>

                        <div class="decision-stack">
                            <article class="decision-card">
                                <small>Komposisi biaya</small>
                                <strong>@FormatCurrency(breakdown.Summary.MaterialCost)</strong>
                                <span>material</span>
                            </article>
                            <article class="decision-card">
                                <small>Overhead + produksi</small>
                                <strong>@FormatCurrency(breakdown.Summary.OperationalCost)</strong>
                                <span>biaya non-material</span>
                            </article>
                            <article class="decision-card">
                                <small>HPP / output aktual</small>
                                <strong>@FormatCurrency(breakdown.Summary.HppPerRealizedOutput)</strong>
                                <span>@FormatDecimal(breakdown.Summary.RealizedOutputQuantity) @breakdown.Summary.OutputUnit</span>
                            </article>
                            <article class="decision-card">
                                <small>Rounding & pajak</small>
                                <strong>@breakdown.Summary.RoundingIncrement.ToString("N0")</strong>
                                <span>@GetTaxLabel(breakdown.Summary)</span>
                            </article>
                        </div>
                    </div>
                </section>

                <section class="evidence-card">
                    <div class="evidence-top">
                        <div class="section-head">
                            <div>
                                <span class="section-tag">Komposisi biaya</span>
                                <h3>Ringkasan sumber biaya</h3>
                            </div>
                        </div>

                        <div class="composition-grid">
                            <article>
                                <small>Material</small>
                                <strong>@FormatCurrency(breakdown.Summary.MaterialCost)</strong>
                            </article>
                            <article>
                                <small>Overhead</small>
                                <strong>@FormatCurrency(breakdown.Summary.OverheadCost)</strong>
                            </article>
                            <article>
                                <small>Produksi</small>
                                <strong>@FormatCurrency(breakdown.Summary.ProductionCost)</strong>
                            </article>
                            <article>
                                <small>Total batch</small>
                                <strong>@FormatCurrency(breakdown.Summary.TotalBatchCost)</strong>
                            </article>
                        </div>
                    </div>

                    <div class="non-material-panel">
                        <div class="section-head">
                            <div>
                                <span class="section-tag">Biaya non-material</span>
                                <h3>Overhead dan produksi</h3>
                            </div>
                        </div>

                        @if (breakdown.Costs.Count == 0)
                        {
                            <div class="empty-mini">Resep ini belum memiliki overhead atau biaya produksi tambahan.</div>
                        }
                        else
                        {
                            <div class="cost-list">
                                @foreach (var cost in breakdown.Costs)
                                {
                                    <article class="cost-item">
                                        <div>
                                            <small>@GetCostTypeLabel(cost.Type)</small>
                                            <strong>@cost.Name</strong>
                                            @if (!string.IsNullOrWhiteSpace(cost.Notes))
                                            {
                                                <p>@cost.Notes</p>
                                            }
                                        </div>

                                        <strong>@FormatCurrency(cost.Amount)</strong>
                                    </article>
                                }
                            </div>
                        }
                    </div>

                    <div class="section-head breakdown-head">
                        <div>
                            <span class="section-tag">Breakdown resep</span>
                            <h3>Audit biaya material</h3>
                            <p>Kelompok ditutup default agar halaman tetap ringkas. Buka hanya saat perlu memeriksa sumber biaya.</p>
                        </div>
                    </div>

                    <div class="group-stack">
                        @foreach (var group in breakdown.Groups)
                        {
                            <details class="group-panel">
                                <summary class="group-summary">
                                    <div class="group-summary-copy">
                                        <small>@group.MaterialCount material</small>
                                        <strong>@group.Name</strong>
                                        @if (!string.IsNullOrWhiteSpace(group.Notes))
                                        {
                                            <span>@group.Notes</span>
                                        }
                                    </div>

                                    <div class="group-summary-total">
                                        <strong>@FormatCurrency(group.Subtotal)</strong>
                                    </div>
                                </summary>

                                <div class="material-table material-table-head">
                                    <span>Material</span>
                                    <span>Netto</span>
                                    <span>Pemakaian</span>
                                    <span>Biaya dasar</span>
                                    <span>Modal</span>
                                </div>

                                @foreach (var line in group.Materials)
                                {
                                    <div class="material-table">
                                        <div class="material-cell primary">
                                            <strong>@line.MaterialName</strong>
                                            <small>@line.MaterialCode - @(string.IsNullOrWhiteSpace(line.Brand) ? "Tanpa merk" : line.Brand)</small>
                                        </div>
                                        <div class="material-cell">
                                            <strong>@line.NetLabel</strong>
                                            <small>@FormatDecimal(line.BaseQuantity) @line.BaseUnit</small>
                                        </div>
                                        <div class="material-cell">
                                            <strong>@FormatDecimal(line.Quantity) @line.Unit</strong>
                                            <small>Waste @line.WastePercent.ToString("0.##")%</small>
                                        </div>
                                        <div class="material-cell">
                                            <strong>@FormatCurrency(line.CostPerBaseUnit)</strong>
                                            <small>per @line.BaseUnit</small>
                                        </div>
                                        <div class="material-cell emphasis">
                                            <strong>@FormatCurrency(line.LineCost)</strong>
                                            <small>@(string.IsNullOrWhiteSpace(line.Notes) ? "Tanpa catatan" : line.Notes)</small>
                                        </div>
                                    </div>
                                }
                            </details>
                        }
                    </div>
                </section>
            </div>
        </div>
    }
</section>

@code {
    private HppCalculatorSnapshot? _snapshot;
    private bool _isLoading = true;
    private string _statusMessage = "Memuat kalkulator...";
    private string _searchText = string.Empty;
    private Guid? _selectedRecipeId;
    private decimal? _realizedOutput;
    private decimal _marginPercent = 35m;

    protected override async Task OnInitializedAsync()
    {
        Store.Changed += HandleStoreChanged;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _snapshot = await HppCalculatorService.GetSnapshotAsync(_searchText, _selectedRecipeId, _realizedOutput);
        _selectedRecipeId = _snapshot.SelectedRecipeId;

        if (_snapshot.Breakdown is null)
        {
            _statusMessage = _snapshot.Recipes.Count == 0 ? "Belum ada resep." : "Pilih resep untuk dihitung.";
            _realizedOutput = null;
        }
        else
        {
            _realizedOutput = _snapshot.Breakdown.Summary.RealizedOutputQuantity;
            _statusMessage = $"{_snapshot.Recipes.Count} resep tersedia";
        }

        _isLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private Task ReloadAsync() => LoadAsync();

    private async Task OnSearchChangedAsync(ChangeEventArgs args)
    {
        _searchText = args.Value?.ToString() ?? string.Empty;
        await LoadAsync();
    }

    private async Task SelectRecipeAsync(Guid recipeId)
    {
        _selectedRecipeId = recipeId;
        _realizedOutput = null;
        await LoadAsync();
    }

    private async Task OnRealizedOutputChangedAsync(ChangeEventArgs args)
    {
        if (decimal.TryParse(args.Value?.ToString(), out var value) && value > 0)
        {
            _realizedOutput = value;
        }
        else
        {
            _realizedOutput = null;
        }

        await LoadAsync();
    }

    private string GetRealizedOutputValue()
        => _realizedOutput?.ToString("0.####") ?? string.Empty;

    private static string GetStatusLabel(RecipeStatus status)
        => status == RecipeStatus.Active ? "Aktif" : "Draft";

    private static string GetCostTypeLabel(RecipeCostType type)
        => type == RecipeCostType.Overhead ? "Overhead" : "Biaya produksi";

    private static string GetScenarioLabel(HppCalculatorSummary summary)
        => summary.RealizedOutputQuantity == summary.PlannedOutputQuantity
            ? "Output aktual sama dengan output resep."
            : $"{summary.RealizedOutputQuantity.ToString("0.##")} {summary.OutputUnit} dipakai sebagai pembagi HPP.";

    private static string GetTaxLabel(HppCalculatorSummary summary)
        => summary.TaxIncluded
            ? $"Include pajak {summary.TaxPercent.ToString("0.##")}%"
            : $"Pajak {summary.TaxPercent.ToString("0.##")}% ditambahkan di akhir";

    private void OnMarginChanged(ChangeEventArgs args)
    {
        if (decimal.TryParse(args.Value?.ToString(), out var value))
        {
            _marginPercent = Math.Clamp(value, 0m, 300m);
        }
    }

    private void SetMargin(decimal value)
        => _marginPercent = Math.Clamp(value, 0m, 300m);

    private decimal GetMarginValue(HppCalculatorSummary summary)
        => summary.HppAfterTax * (_marginPercent / 100m);

    private decimal GetSuggestedSellingPrice(HppCalculatorSummary summary)
        => summary.HppAfterTax + GetMarginValue(summary);

    private static string FormatCurrency(decimal value)
        => string.Create(new System.Globalization.CultureInfo("id-ID"), $"Rp {value:N0}");

    private static string FormatDecimal(decimal value)
        => value.ToString("0.####");

    private async void HandleStoreChanged()
    {
        await InvokeAsync(async () => await LoadAsync());
    }

    public ValueTask DisposeAsync()
    {
        Store.Changed -= HandleStoreChanged;
        return ValueTask.CompletedTask;
    }
}
