@page "/produksi"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using Microsoft.AspNetCore.Components.Forms
@inject IJSRuntime JS
@inject ProductionService ProductionService
@inject WarehouseService WarehouseService
@inject GeminiProductionRecommendationService GeminiProductionRecommendationService
@inject SeededBusinessDataStore Store

<PageTitle>Produksi | HPP Ultimate</PageTitle>

<section class="production-page ds-page ds-page-stack theme-indigo">
    <header class="production-header ds-page-header">
        <div class="header-copy">
            <span class="section-tag">Produksi</span>
            <h1>Workspace produksi</h1>
            <p>Gunakan tiga mode kerja ini untuk menyusun batch, menjalankan antrian, lalu memantau batch yang sedang atau sudah selesai.</p>
        </div>
    </header>

    @if (_isLoading && _snapshot is null)
    {
        <div class="table-skeleton"></div>
    }
    else if (_snapshot is not null)
    {
        <section class="production-flow-band">
            <div class="production-flow-copy">
                <span class="section-tag">Mode kerja</span>
                <h2>Rencana, antrian, lalu riwayat eksekusi</h2>
                <p>Panel atas sekarang hanya dipakai untuk orientasi cepat, bukan lagi wizard panjang sebelum masuk ke workspace inti.</p>
            </div>

            <div class="production-flow-meta">
                <span>@_snapshot.TotalRecipeCount resep tersedia</span>
                <span>@_snapshot.QueueCount batch dalam antrian</span>
                <span>@_snapshot.RunningCount batch sedang berjalan</span>
                <span>@_snapshot.CompletedCount batch selesai</span>
            </div>

            <nav class="production-stage-map" aria-label="Peta kerja produksi">
                <button type="button" class="stage-link" @onclick='() => ScrollToSectionAsync("production-plan")' aria-controls="production-plan">
                    <span>Rencana</span>
                    <strong>Susun batch</strong>
                    <small>Pilih resep, atur batch, dan cek kebutuhan bahan.</small>
                </button>
                <button type="button" class="stage-link" @onclick='() => ScrollToSectionAsync("production-queue")' aria-controls="production-queue">
                    <span>Antrian</span>
                    <strong>Jalankan queue</strong>
                    <small>Mulai batch yang sudah siap dan edit queue sebelum jalan.</small>
                </button>
                <button type="button" class="stage-link" @onclick='() => ScrollToSectionAsync("production-history")' aria-controls="production-history">
                    <span>Riwayat</span>
                    <strong>Pantau hasil</strong>
                    <small>Pantau timer, batch berjalan, dan batch yang sudah selesai.</small>
                </button>
            </nav>
        </section>

        <div class="page-layout">
            <div class="draft-column">
                <section class="production-entry-card" id="production-plan">
                    <div class="section-head draft-head ds-card-header">
                        <div>
                            <span class="section-tag">Susun batch</span>
                            <h2>@(_snapshot.Draft?.RecipeName ?? "Pilih resep untuk mulai menyusun batch produksi")</h2>
                            <p>@(_snapshot.Draft is null ? "Mulai dari lookup resep. Setelah resep aktif dipilih, batch, timer, dan kebutuhan bahan langsung muncul di workspace yang sama." : $"{_snapshot.Draft.RecipeCode} - {_snapshot.Draft.PortionYieldPerBatch.ToString("0.##")} {_snapshot.Draft.PortionUnit} per batch")</p>
                        </div>

                        <div class="draft-head-actions">
                            @if (_editingQueueId is not null)
                            {
                                <span class="badge running">Mode edit antrian</span>
                            }
                            else if (RunningBatchForSelectedRecipe is not null)
                            {
                                <span class="badge running">Sedang berjalan</span>
                            }

                            @if (_snapshot.Draft is not null)
                            {
                                <span class="draft-readiness @(GetDraftReadinessClass(_snapshot.Draft))">@GetDraftReadinessLabel(_snapshot.Draft)</span>
                            }
                        </div>
                    </div>

                    <section class="recipe-lookup-panel">
                        <div class="section-head lookup-head ds-card-header">
                            <div>
                                <span class="section-tag">Pilih resep</span>
                                <h3>Cari resep produksi dari katalog resep</h3>
                                <p>Gunakan autocomplete untuk memilih resep aktif, lalu langsung atur batch dan timer targetnya.</p>
                            </div>
                        </div>

                        <div class="recipe-lookup-grid lookup-single">
                            <label class="recipe-lookup-field wide-field">
                                <span>Resep produksi</span>
                                <div class="picker-field">
                                    <input value="@_recipeLookupText"
                                           @oninput="OnRecipeLookupInput"
                                           @onchange="OnRecipeLookupCommitAsync"
                                           placeholder="Cari kode atau nama resep" />

                                    @if (ShowRecipeSuggestions)
                                    {
                                        <div class="picker-suggestion-list" role="listbox" aria-label="Saran resep produksi">
                                            @foreach (var recipe in RecipeLookupSuggestions)
                                            {
                                                <button type="button" class="picker-suggestion" @onclick="() => SelectRecipeAsync(recipe.RecipeId)">
                                                    <div class="table-primary">
                                                        <strong>@recipe.Name</strong>
                                                        <small>@recipe.Code - @recipe.PortionYieldPerBatch.ToString("0.##") @recipe.PortionUnit / batch</small>
                                                    </div>
                                                    <span class="badge @(recipe.CanStart ? "ok" : "warn")">@(recipe.CanStart ? "Siap" : "Tertahan")</span>
                                                </button>
                                            }
                                        </div>
                                    }
                                </div>
                            </label>
                        </div>

                        <div class="lookup-inline-meta">
                            <span>@ReadyRecipeCount resep siap mulai</span>
                            <span>@BlockedRecipeCount resep tertahan stok</span>
                        </div>
                    </section>

                    @if (_snapshot.Draft is null)
                    {
                        <div class="empty-state">
                            Pilih resep dari autocomplete untuk menyiapkan draft produksi.
                        </div>
                    }
                    else
                    {

                        <div class="detail-summary-strip draft-summary-strip">
                            <article>
                                <small>Batch</small>
                                <strong>@_productionForm.BatchCount</strong>
                            </article>
                            <article>
                                <small>Total porsi</small>
                                <strong>@_snapshot.Draft.TotalPortions.ToString("0.##") @_snapshot.Draft.PortionUnit</strong>
                            </article>
                            <article>
                                <small>Modal bahan</small>
                                <strong>@FormatCurrency(_snapshot.Draft.EstimatedMaterialCost)</strong>
                            </article>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_message))
                        {
                            <div class="form-message">@_message</div>
                        }

                        @if (_snapshot.Draft.ValidationMessages.Count > 0)
                        {
                            <div class="draft-alert-summary">
                                <strong>@_snapshot.Draft.ValidationMessages.Count catatan stok perlu diperhatikan</strong>
                                <span>@_snapshot.Draft.ValidationMessages[0]</span>
                                @if (_snapshot.Draft.ValidationMessages.Count > 1)
                                {
                                    <small>+@(_snapshot.Draft.ValidationMessages.Count - 1) catatan lain tersedia di panel kebutuhan bahan.</small>
                                }
                            </div>
                        }

                        <section class="entry-form-card">
                            <div class="section-head ds-card-header">
                                <div>
                                    <span class="section-tag">Tambah antrian</span>
                                    <h3>Atur batch, timer target, dan detail produksi</h3>
                                    <p>Item di antrian masih bisa diedit sebelum benar-benar dimulai.</p>
                                </div>
                            </div>

                            <EditForm EditContext="_productionEditContext" OnValidSubmit="SaveQueueAsync">
                                <DataAnnotationsValidator />
                                <ValidationSummary />

                                <div class="entry-grid">
                                    <label>
                                        <span>Jumlah batch</span>
                                        <InputNumber TValue="int"
                                                     Value="_productionForm.BatchCount"
                                                     ValueChanged="OnBatchCountChangedAsync"
                                                     ValueExpression="() => _productionForm.BatchCount" />
                                        <ValidationMessage For="() => _productionForm.BatchCount" />
                                    </label>

                                    <label>
                                        <span>Timer target (menit)</span>
                                        <InputNumber TValue="int"
                                                     Value="_productionForm.TargetDurationMinutes"
                                                     ValueChanged="OnTargetDurationChangedAsync"
                                                     ValueExpression="() => _productionForm.TargetDurationMinutes" />
                                        <ValidationMessage For="() => _productionForm.TargetDurationMinutes" />
                                    </label>

                                    <label class="wide-field">
                                        <span>Catatan produksi</span>
                                        <InputTextArea @bind-Value="_productionForm.Notes" />
                                    </label>
                                </div>

                                <div class="timer-preview">
                                    <small>Target produksi</small>
                                    <strong>@FormatDuration(_productionForm.TargetDurationMinutes)</strong>
                                    <span>Batch bisa langsung dijalankan dari sini, atau hanya diantrikan dulu jika belum siap dieksekusi.</span>
                                </div>

                                <div class="submit-confidence-note">
                                    <strong>Konsekuensi aksi</strong>
                                    <span><em>Antrikan Saja</em> hanya menyimpan batch ke queue. <em>Antrikan & Mulai</em> akan langsung memulai timer produksi dan memindahkan batch ke status berjalan.</span>
                                </div>

                                <div class="form-actions">
                                    @if (_editingQueueId is not null)
                                    {
                                        <button type="button" class="ghost-button" @onclick="CancelQueueEdit">Batal Edit</button>
                                    }

                                    <button type="submit" class="@(_snapshot.Draft.CanStart ? "ghost-button" : "primary-button")" disabled="@(!_snapshot.Draft.CanQueue)">@QueueSubmitLabel</button>

                                    @if (_snapshot.Draft.CanStart)
                                    {
                                        <button type="button" class="primary-button" disabled="@(!_snapshot.Draft.CanQueue)" @onclick="SaveQueueAndStartAsync">@QueueAndStartLabel</button>
                                    }
                                </div>
                            </EditForm>
                        </section>
                    }
                </section>

            </div>

            <div class="operations-column">
                @if (_snapshot.Draft is not null)
                {
                    <section class="requirement-card catalog-datagrid" id="production-requirement-card">
                        <div class="section-head ds-card-header">
                            <div>
                                <span class="section-tag">Kebutuhan bahan</span>
                                <h3>Simulasi stok untuk draft ini</h3>
                                <p>Panel ini dipindah ke sisi operasi supaya kebutuhan bahan, antrian, dan riwayat produksi terbaca sebagai satu cluster eksekusi.</p>
                            </div>

                            <label class="display-count-control compact">
                                <span>Baris tampil</span>
                                <select value="@_requirementDisplayCount" @onchange="OnRequirementDisplayCountChanged">
                                    @foreach (var option in GridDisplayOptions)
                                    {
                                        <option value="@option">@option baris</option>
                                    }
                                </select>
                            </label>
                        </div>

                        @if (QuickStockRequirement is not null)
                        {
                            <section class="quick-stock-panel" id="production-quick-stock">
                                <div class="quick-stock-head">
                                    <div>
                                        <span class="section-tag">Isi stok cepat</span>
                                        <h4>@QuickStockRequirement.MaterialName</h4>
                                        <p>Tambahkan stok langsung dari halaman produksi. Setelah disimpan, simulasi bahan akan refresh otomatis tanpa pindah ke gudang.</p>
                                    </div>

                                    <button type="button" class="ghost-button compact" @onclick="CloseQuickStockComposer">Tutup</button>
                                </div>

                                <div class="quick-stock-metrics">
                                    <article>
                                        <small>Stok sekarang</small>
                                        <strong>@QuickStockRequirement.AvailableQuantity.ToString("0.####") @QuickStockRequirement.BaseUnit</strong>
                                    </article>
                                    <article>
                                        <small>Total butuh</small>
                                        <strong>@QuickStockRequirement.RequiredQuantity.ToString("0.####") @QuickStockRequirement.BaseUnit</strong>
                                    </article>
                                    <article>
                                        <small>Kekurangan</small>
                                        <strong>@QuickStockRequirement.ShortageQuantity.ToString("0.####") @QuickStockRequirement.BaseUnit</strong>
                                    </article>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(_quickStockMessage))
                                {
                                    <div class="form-message @_quickStockMessageTone">@_quickStockMessage</div>
                                }

                                <div class="quick-stock-form">
                                    <label>
                                        <span>Tambah stok sekarang</span>
                                        <InputNumber @bind-Value="_quickStockForm.Quantity" id="production-quick-stock-input" />
                                    </label>

                                    <div class="quick-stock-actions">
                                        <button type="button" class="ghost-button compact" @onclick="UseSuggestedQuickStockQuantity">Gunakan nilai kurang</button>
                                        <button type="button" class="primary-button compact" disabled="@(!CanSaveQuickStock)" @onclick="SaveQuickStockAsync">
                                            @(_isSavingQuickStock ? "Menyimpan..." : "Simpan stok cepat")
                                        </button>
                                    </div>
                                </div>
                            </section>
                        }

                        @if (_snapshot.Draft.Requirements.Count == 0)
                        {
                            <div class="empty-mini">Resep ini belum punya material.</div>
                        }
                        else
                        {
                            <div class="requirement-grid-shell">
                                <table class="requirement-table">
                                    <thead>
                                        <tr>
                                            <th>Material</th>
                                            <th>Butuh / batch</th>
                                            <th>Total butuh</th>
                                            <th>Stok</th>
                                            <th>Status</th>
                                            <th>Aksi</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in VisibleDraftRequirements)
                                        {
                                            <tr>
                                                <td>
                                                    <div class="table-primary">
                                                        <strong>@item.MaterialName</strong>
                                                        <small>@item.MaterialCode - @(string.IsNullOrWhiteSpace(item.Brand) ? "Tanpa merk" : item.Brand)</small>
                                                    </div>
                                                </td>
                                                <td>@item.QuantityPerBatch.ToString("0.####") @item.BaseUnit</td>
                                                <td>@item.RequiredQuantity.ToString("0.####") @item.BaseUnit</td>
                                                <td>@item.AvailableQuantity.ToString("0.####") @item.BaseUnit</td>
                                                <td>
                                                    <span class="badge @(item.IsSufficient ? "ok" : "warn")">
                                                        @(item.IsSufficient ? "Cukup" : item.AvailableQuantity <= 0 ? "Kosong" : $"Kurang {item.ShortageQuantity:0.####}")
                                                    </span>
                                                </td>
                                                <td class="requirement-action-cell">
                                                    @if (!item.IsSufficient)
                                                    {
                                                        <button type="button" class="ghost-button compact" @onclick="() => OpenQuickStockAsync(item)">Isi stok</button>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            <div class="production-card-list requirement-card-list">
                                @foreach (var item in VisibleDraftRequirements)
                                {
                                    <article class="requirement-list-item">
                                        <div class="requirement-list-main">
                                            <div class="table-primary">
                                                <strong>@item.MaterialName</strong>
                                                <small>@item.MaterialCode - @(string.IsNullOrWhiteSpace(item.Brand) ? "Tanpa merk" : item.Brand)</small>
                                            </div>

                                            <span class="badge @(item.IsSufficient ? "ok" : "warn")">
                                                @(item.IsSufficient ? "Cukup" : item.AvailableQuantity <= 0 ? "Kosong" : $"Kurang {item.ShortageQuantity:0.####}")
                                            </span>
                                        </div>

                                        <div class="requirement-list-stats">
                                            <span>Per batch @item.QuantityPerBatch.ToString("0.####") @item.BaseUnit</span>
                                            <span>Total @item.RequiredQuantity.ToString("0.####") @item.BaseUnit</span>
                                            <span>Stok @item.AvailableQuantity.ToString("0.####") @item.BaseUnit</span>
                                        </div>

                                        @if (!item.IsSufficient)
                                        {
                                            <div class="requirement-list-actions">
                                                <button type="button" class="ghost-button compact" @onclick="() => OpenQuickStockAsync(item)">Isi stok cepat</button>
                                            </div>
                                        }
                                    </article>
                                }
                            </div>

                            <div class="table-footer">
                                <small>@(_snapshot.Draft.Requirements.Count) bahan</small>
                                <div class="pager">
                                    <button type="button" @onclick="PrevRequirementPage" disabled="@(CurrentRequirementPage <= 1)">Prev</button>
                                    <label class="pager-select">
                                        <select aria-label="Pilih halaman kebutuhan bahan" value="@CurrentRequirementPage" @onchange="OnRequirementPageChanged">
                                            @for (var pageNumber = 1; pageNumber <= RequirementTotalPages; pageNumber++)
                                            {
                                                <option value="@pageNumber">Halaman @pageNumber</option>
                                            }
                                        </select>
                                    </label>
                                    <span>@CurrentRequirementPage / @RequirementTotalPages</span>
                                    <button type="button" @onclick="NextRequirementPage" disabled="@(CurrentRequirementPage >= RequirementTotalPages)">Next</button>
                                </div>
                                <div class="table-footer-spacer" aria-hidden="true"></div>
                            </div>
                        }
                    </section>
                }

                <div class="operations-section" id="production-queue">
                    @if (_snapshot.Queue.Count == 0)
                    {
                        <div class="queue-empty-strip">
                            <strong>Belum ada antrian aktif.</strong>
                            <span>Tambahkan batch dari draft untuk mulai mengisi queue produksi.</span>
                        </div>
                    }
                    else
                    {
                        <section class="queue-card catalog-datagrid">
                        <div class="section-head ds-card-header">
                            <div>
                                <span class="section-tag">Antrian aktif</span>
                                <h2>Draft yang siap dijalankan</h2>
                                <p>Produksi dimulai dari sini agar batch masih bisa diedit sampai sebelum benar-benar berjalan.</p>
                            </div>

                            <label class="display-count-control compact">
                                <span>Baris tampil</span>
                                <select value="@_queueDisplayCount" @onchange="OnQueueDisplayCountChanged">
                                    @foreach (var option in GridDisplayOptions)
                                    {
                                        <option value="@option">@option baris</option>
                                    }
                                </select>
                            </label>
                        </div>

                <div class="queue-grid-shell">
                    <QuickGrid Items="VisibleQueueItems.AsQueryable()" Class="queue-quickgrid">
                        <TemplateColumn Title="Produksi" Context="item">
                            <div class="table-primary">
                                <strong>@item.RecipeName</strong>
                                <small>@item.BatchCode - @item.RecipeCode</small>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Batch" Context="item">
                            <div class="history-meta-cell">
                                <strong>@item.BatchCount batch</strong>
                                <small>@item.TotalPortions.ToString("0.##") @item.PortionUnit</small>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Timer Target" Context="item">
                            <div class="timer-meta-cell">
                                <strong>@FormatDuration(item.TargetDurationMinutes)</strong>
                                <small>Masuk antrian @item.QueuedAt.ToString("dd MMM HH:mm")</small>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Catatan" Context="item">
                            <div class="history-meta-cell">
                                <strong>@(string.IsNullOrWhiteSpace(item.Notes) ? "Tanpa catatan" : item.Notes)</strong>
                                <small>@(item.CanStart ? "Siap mulai" : item.StartWarning ?? "Menunggu stok cukup")</small>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Status" Context="item">
                            <span class="badge @(item.CanStart ? "ok" : "warn")">
                                @(item.CanStart ? "Siap mulai" : "Tertahan stok")
                            </span>
                        </TemplateColumn>
                        <TemplateColumn Title="Aksi" Context="item">
                            <div class="queue-actions">
                                <button type="button" class="icon-button" title="Edit" aria-label="Edit" @onclick="() => EditQueueAsync(item.Id)">
                                    <AppIcon Name="edit" Class="icon-glyph" />
                                </button>
                                <button type="button" class="primary-button compact" @onclick="() => StartQueuedProductionAsync(item.Id)" disabled="@(!item.CanStart)">Mulai Produksi</button>
                            </div>
                        </TemplateColumn>
                    </QuickGrid>
                </div>

                <div class="production-card-list queue-card-list">
                    @foreach (var item in VisibleQueueItems)
                    {
                        <article class="production-mobile-card">
                            <div class="production-mobile-head">
                                <div class="table-primary">
                                    <strong>@item.RecipeName</strong>
                                    <small>@item.BatchCode - @item.RecipeCode</small>
                                </div>

                                <span class="badge @(item.CanStart ? "ok" : "warn")">
                                    @(item.CanStart ? "Siap mulai" : "Tertahan stok")
                                </span>
                            </div>

                            <div class="production-mobile-grid">
                                <article>
                                    <small>Batch</small>
                                    <strong>@item.BatchCount batch</strong>
                                    <span>@item.TotalPortions.ToString("0.##") @item.PortionUnit</span>
                                </article>
                                <article>
                                    <small>Timer target</small>
                                    <strong>@FormatDuration(item.TargetDurationMinutes)</strong>
                                    <span>Masuk @item.QueuedAt.ToString("dd MMM HH:mm")</span>
                                </article>
                                <article class="wide-metric">
                                    <small>Catatan</small>
                                    <strong>@(string.IsNullOrWhiteSpace(item.Notes) ? "Tanpa catatan" : item.Notes)</strong>
                                    <span>@(item.CanStart ? "Siap mulai" : item.StartWarning ?? "Menunggu stok cukup")</span>
                                </article>
                            </div>

                            <div class="production-mobile-actions">
                                <button type="button" class="icon-button" title="Edit" aria-label="Edit" @onclick="() => EditQueueAsync(item.Id)">
                                    <AppIcon Name="edit" Class="icon-glyph" />
                                </button>
                                <button type="button" class="primary-button compact" @onclick="() => StartQueuedProductionAsync(item.Id)" disabled="@(!item.CanStart)">Mulai Produksi</button>
                            </div>
                        </article>
                    }
                </div>

                <div class="table-footer">
                    <small>@_snapshot.Queue.Count antrian</small>
                    <div class="pager">
                        <button type="button" @onclick="PrevQueuePage" disabled="@(CurrentQueuePage <= 1)">Prev</button>
                        <label class="pager-select">
                            <select aria-label="Pilih halaman antrian produksi" value="@CurrentQueuePage" @onchange="OnQueuePageChanged">
                                @for (var pageNumber = 1; pageNumber <= QueueTotalPages; pageNumber++)
                                {
                                    <option value="@pageNumber">Halaman @pageNumber</option>
                                }
                            </select>
                        </label>
                        <span>@CurrentQueuePage / @QueueTotalPages</span>
                        <button type="button" @onclick="NextQueuePage" disabled="@(CurrentQueuePage >= QueueTotalPages)">Next</button>
                    </div>
                    <div class="table-footer-spacer" aria-hidden="true"></div>
                </div>
                        </section>
                    }
                </div>

                <section class="history-card catalog-datagrid" id="production-history">
                    <div class="section-head ds-card-header">
                        <div>
                            <span class="section-tag">Riwayat produksi</span>
                            <h2>Produksi berjalan dan selesai</h2>
                            <p>Timer target berjalan otomatis saat produksi dimulai, lalu alarm berbunyi saat target waktunya habis.</p>
                        </div>

                        <label class="display-count-control compact">
                            <span>Baris tampil</span>
                            <select value="@_historyDisplayCount" @onchange="OnHistoryDisplayCountChanged">
                                @foreach (var option in GridDisplayOptions)
                                {
                                    <option value="@option">@option baris</option>
                                }
                            </select>
                        </label>
                    </div>

                    @if (_snapshot.History.Count == 0)
                    {
                        <div class="empty-state">
                            Belum ada histori produksi.
                        </div>
                    }
                    else
                    {
                <div class="history-grid-shell">
                    <QuickGrid Items="VisibleHistoryItems.AsQueryable()" Class="history-quickgrid">
                        <TemplateColumn Title="Produksi" Context="item">
                            <div class="table-primary">
                                <strong>@item.RecipeName</strong>
                                <small>@item.BatchCode - @item.RecipeCode</small>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Batch" Context="item">
                            <div class="history-meta-cell">
                                <strong>@item.BatchCount batch</strong>
                                <small>@item.TotalPortions.ToString("0.##") @item.PortionUnit</small>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Timer" Context="item">
                            <div class="timer-meta-cell">
                                <strong>@GetTimerDisplay(item)</strong>
                                <small>@GetTimerSubcopy(item)</small>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Mulai" Context="item">
                            <div class="history-meta-cell">
                                <strong>@(item.StartedAt?.ToString("dd MMM yy HH:mm") ?? "-")</strong>
                                <small>@(item.CompletedAt is null ? "Belum selesai" : $"Selesai {item.CompletedAt.Value:dd MMM yy HH:mm}")</small>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Status" Context="item">
                            <span class="badge @(item.Status == ProductionRunStatus.Running ? (IsTimerExpired(item) ? "warn" : "running") : "ok")">
                                @(item.Status == ProductionRunStatus.Running ? (IsTimerExpired(item) ? "Lewat target" : "Berjalan") : "Selesai")
                            </span>
                        </TemplateColumn>
                        <TemplateColumn Title="Aksi" Context="item">
                            <div class="history-actions">
                                @if (item.Status == ProductionRunStatus.Running)
                                {
                                    <button type="button" class="ghost-button compact" @onclick="() => CompleteProductionAsync(item.Id)">Selesai</button>
                                }
                            </div>
                        </TemplateColumn>
                    </QuickGrid>
                </div>

                <div class="production-card-list history-card-list">
                    @foreach (var item in VisibleHistoryItems)
                    {
                        <article class="production-mobile-card">
                            <div class="production-mobile-head">
                                <div class="table-primary">
                                    <strong>@item.RecipeName</strong>
                                    <small>@item.BatchCode - @item.RecipeCode</small>
                                </div>

                                <span class="badge @(item.Status == ProductionRunStatus.Running ? (IsTimerExpired(item) ? "warn" : "running") : "ok")">
                                    @(item.Status == ProductionRunStatus.Running ? (IsTimerExpired(item) ? "Lewat target" : "Berjalan") : "Selesai")
                                </span>
                            </div>

                            <div class="production-mobile-grid">
                                <article>
                                    <small>Batch</small>
                                    <strong>@item.BatchCount batch</strong>
                                    <span>@item.TotalPortions.ToString("0.##") @item.PortionUnit</span>
                                </article>
                                <article>
                                    <small>Timer</small>
                                    <strong>@GetTimerDisplay(item)</strong>
                                    <span>@GetTimerSubcopy(item)</span>
                                </article>
                                <article>
                                    <small>Mulai</small>
                                    <strong>@(item.StartedAt?.ToString("dd MMM yy HH:mm") ?? "-")</strong>
                                    <span>@(item.CompletedAt is null ? "Belum selesai" : $"Selesai {item.CompletedAt.Value:dd MMM yy HH:mm}")</span>
                                </article>
                            </div>

                            @if (item.Status == ProductionRunStatus.Running)
                            {
                                <div class="production-mobile-actions">
                                    <button type="button" class="ghost-button compact" @onclick="() => CompleteProductionAsync(item.Id)">Selesai</button>
                                </div>
                            }
                        </article>
                    }
                </div>

                <div class="table-footer">
                    <small>@_snapshot.History.Count histori</small>
                    <div class="pager">
                        <button type="button" @onclick="PrevHistoryPage" disabled="@(CurrentHistoryPage <= 1)">Prev</button>
                        <label class="pager-select">
                            <select aria-label="Pilih halaman history produksi" value="@CurrentHistoryPage" @onchange="OnHistoryPageChanged">
                                @for (var pageNumber = 1; pageNumber <= HistoryTotalPages; pageNumber++)
                                {
                                    <option value="@pageNumber">Halaman @pageNumber</option>
                                }
                            </select>
                        </label>
                        <span>@CurrentHistoryPage / @HistoryTotalPages</span>
                        <button type="button" @onclick="NextHistoryPage" disabled="@(CurrentHistoryPage >= HistoryTotalPages)">Next</button>
                    </div>
                    <div class="table-footer-spacer" aria-hidden="true"></div>
                </div>
                    }
                </section>
            </div>
        </div>
    }
</section>

@code {
    private ProductionSnapshot? _snapshot;
    private static readonly int[] GridDisplayOptions = [8, 12, 20, 50];
    private string _recipeLookupText = string.Empty;
    private Guid? _selectedRecipeId;
    private Guid? _editingQueueId;
    private bool _isLoading = true;
    private bool _isDisposed;
    private string _message = string.Empty;
    private int _requirementDisplayCount = 12;
    private int _requirementPage = 1;
    private int _queueDisplayCount = 8;
    private int _queuePage = 1;
    private int _historyDisplayCount = 12;
    private int _historyPage = 1;
    private CancellationTokenSource? _clockCts;
    private Task? _clockTask;
    private readonly HashSet<Guid> _alarmedBatchIds = [];
    private string _productionAiMessage = string.Empty;
    private readonly List<ProductionAiSuggestion> _productionAiSuggestions = [];
    private Guid? _quickStockMaterialId;
    private bool _isSavingQuickStock;
    private string _quickStockMessage = string.Empty;
    private string _quickStockMessageTone = "info";
    private ProductionBatchCreateRequest _productionForm = new()
    {
        BatchCount = 1,
        TargetDurationMinutes = 30,
        StartedAt = DateTime.Now
    };
    private StockMovementRequest _quickStockForm = CreateQuickStockRequest();
    private EditContext _productionEditContext = default!;

    private string QueueSubmitLabel => _editingQueueId is null ? "Antrikan Saja" : "Simpan Tanpa Mulai";
    private string QueueAndStartLabel => _editingQueueId is null ? "Antrikan & Mulai" : "Simpan & Mulai";

    private int ReadyRecipeCount
        => _snapshot?.Recipes.Count(item => item.CanStart) ?? 0;

    private int BlockedRecipeCount
        => _snapshot?.Recipes.Count(item => !item.CanStart) ?? 0;

    private ProductionRecipeOption? SelectedRecipeOption
        => _selectedRecipeId is Guid recipeId
            ? _snapshot?.Recipes.FirstOrDefault(item => item.RecipeId == recipeId)
            : null;
    private IReadOnlyList<ProductionRecipeOption> RecipeLookupSuggestions
        => _snapshot is null || string.IsNullOrWhiteSpace(_recipeLookupText)
            ? Array.Empty<ProductionRecipeOption>()
            : _snapshot.Recipes
                .Where(item =>
                    item.Name.Contains(_recipeLookupText, StringComparison.OrdinalIgnoreCase) ||
                    item.Code.Contains(_recipeLookupText, StringComparison.OrdinalIgnoreCase))
                .Take(6)
                .ToArray();
    private bool ShowRecipeSuggestions
        => _selectedRecipeId is null && RecipeLookupSuggestions.Count > 0;

    private int RequirementTotalPages => CalculateTotalPages(_snapshot?.Draft?.Requirements.Count ?? 0, _requirementDisplayCount);
    private int CurrentRequirementPage => ClampPage(_requirementPage, RequirementTotalPages);
    private IReadOnlyList<ProductionRequirementLine> VisibleDraftRequirements
        => (_snapshot?.Draft?.Requirements ?? Array.Empty<ProductionRequirementLine>())
            .Skip((CurrentRequirementPage - 1) * _requirementDisplayCount)
            .Take(_requirementDisplayCount)
            .ToArray();

    private int QueueTotalPages => CalculateTotalPages(_snapshot?.Queue.Count ?? 0, _queueDisplayCount);
    private int CurrentQueuePage => ClampPage(_queuePage, QueueTotalPages);
    private IReadOnlyList<ProductionBatchListItem> VisibleQueueItems
        => (_snapshot?.Queue ?? Array.Empty<ProductionBatchListItem>())
            .Skip((CurrentQueuePage - 1) * _queueDisplayCount)
            .Take(_queueDisplayCount)
            .ToArray();

    private int HistoryTotalPages => CalculateTotalPages(_snapshot?.History.Count ?? 0, _historyDisplayCount);
    private int CurrentHistoryPage => ClampPage(_historyPage, HistoryTotalPages);
    private IReadOnlyList<ProductionBatchListItem> VisibleHistoryItems
        => (_snapshot?.History ?? Array.Empty<ProductionBatchListItem>())
            .Skip((CurrentHistoryPage - 1) * _historyDisplayCount)
            .Take(_historyDisplayCount)
            .ToArray();

    private ProductionBatchListItem? RunningBatchForSelectedRecipe
        => _selectedRecipeId is Guid recipeId
            ? _snapshot?.History.FirstOrDefault(item => item.RecipeId == recipeId && item.Status == ProductionRunStatus.Running)
            : null;
    private ProductionRequirementLine? QuickStockRequirement
        => _quickStockMaterialId is Guid materialId
            ? _snapshot?.Draft?.Requirements.FirstOrDefault(item => item.MaterialId == materialId && !item.IsSufficient)
            : null;
    private bool CanSaveQuickStock
        => !_isSavingQuickStock && _quickStockForm.MaterialId is not null && _quickStockForm.Quantity > 0;

    protected override async Task OnInitializedAsync()
    {
        InitializeProductionEditContext();
        Store.Changed += HandleStoreChanged;
        await LoadAsync();
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return Task.CompletedTask;
        }

        _clockCts = new CancellationTokenSource();
        _clockTask = RunClockAsync(_clockCts.Token);
        return Task.CompletedTask;
    }

    private async Task LoadAsync()
    {
        if (_isDisposed)
        {
            return;
        }

        _isLoading = true;
        _snapshot = await ProductionService.GetSnapshotAsync(null, _selectedRecipeId, Math.Max(1, _productionForm.BatchCount));
        _selectedRecipeId = _snapshot.SelectedRecipeId;
        _requirementPage = CurrentRequirementPage;
        _queuePage = CurrentQueuePage;
        _historyPage = CurrentHistoryPage;

        if (_editingQueueId is Guid editingId && !_snapshot.Queue.Any(item => item.Id == editingId))
        {
            _editingQueueId = null;
            ResetProductionForm(_selectedRecipeId);
        }
        else if (_editingQueueId is null)
        {
            _productionForm.RecipeId = _selectedRecipeId;
        }

        SyncRecipeLookupText();

        _alarmedBatchIds.RemoveWhere(id => _snapshot.History.All(item => item.Id != id || item.Status != ProductionRunStatus.Running));

        _isLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private Task ReloadAsync() => LoadAsync();

    private async Task GenerateProductionRecommendationsAsync()
    {
        if (_snapshot is null)
        {
            return;
        }

        _productionAiMessage = string.Empty;

        try
        {
            var result = await GeminiProductionRecommendationService.RecommendAsync(new ProductionAiRecommendationRequest(
                _snapshot.Recipes.Select(item => new ProductionAiRecipeContext(
                    item.RecipeId,
                    item.Code,
                    item.Name,
                    item.PortionYieldPerBatch,
                    item.PortionUnit,
                    item.MaterialCount,
                    item.HasRunningBatch,
                    item.CanStart,
                    item.ReadinessMessage)).ToArray(),
                _snapshot.Queue.Select(item => new ProductionAiHistoryContext(
                    item.RecipeId,
                    item.RecipeCode,
                    item.RecipeName,
                    item.BatchCount,
                    item.TotalPortions,
                    item.QueuedAt,
                    item.Status)).ToArray(),
                _snapshot.History.Select(item => new ProductionAiHistoryContext(
                    item.RecipeId,
                    item.RecipeCode,
                    item.RecipeName,
                    item.BatchCount,
                    item.TotalPortions,
                    item.QueuedAt,
                    item.Status)).ToArray()));

            _productionAiSuggestions.Clear();
            if (result.Success)
            {
                _productionAiSuggestions.AddRange(result.Suggestions);
            }

            _productionAiMessage = result.Message;
        }
        finally
        {
        }
    }

    private void OnRequirementDisplayCountChanged(ChangeEventArgs args)
    {
        _requirementDisplayCount = ParseDisplayCount(args.Value?.ToString(), _requirementDisplayCount);
        _requirementPage = 1;
    }

    private void OnRequirementPageChanged(ChangeEventArgs args)
        => _requirementPage = ParsePage(args.Value?.ToString(), CurrentRequirementPage, RequirementTotalPages);

    private void PrevRequirementPage()
        => _requirementPage = Math.Max(1, CurrentRequirementPage - 1);

    private void NextRequirementPage()
        => _requirementPage = Math.Min(RequirementTotalPages, CurrentRequirementPage + 1);

    private void OnQueueDisplayCountChanged(ChangeEventArgs args)
    {
        _queueDisplayCount = ParseDisplayCount(args.Value?.ToString(), _queueDisplayCount);
        _queuePage = 1;
    }

    private void OnQueuePageChanged(ChangeEventArgs args)
        => _queuePage = ParsePage(args.Value?.ToString(), CurrentQueuePage, QueueTotalPages);

    private void PrevQueuePage()
        => _queuePage = Math.Max(1, CurrentQueuePage - 1);

    private void NextQueuePage()
        => _queuePage = Math.Min(QueueTotalPages, CurrentQueuePage + 1);

    private void OnHistoryDisplayCountChanged(ChangeEventArgs args)
    {
        _historyDisplayCount = ParseDisplayCount(args.Value?.ToString(), _historyDisplayCount);
        _historyPage = 1;
    }

    private void OnHistoryPageChanged(ChangeEventArgs args)
        => _historyPage = ParsePage(args.Value?.ToString(), CurrentHistoryPage, HistoryTotalPages);

    private void PrevHistoryPage()
        => _historyPage = Math.Max(1, CurrentHistoryPage - 1);

    private void NextHistoryPage()
        => _historyPage = Math.Min(HistoryTotalPages, CurrentHistoryPage + 1);

    private void OnRecipeLookupInput(ChangeEventArgs args)
    {
        _recipeLookupText = args.Value?.ToString() ?? string.Empty;

        if (SelectedRecipeOption is not null
            && !string.Equals(GetRecipeLookupLabel(SelectedRecipeOption), _recipeLookupText, StringComparison.OrdinalIgnoreCase))
        {
            _selectedRecipeId = null;
        }
    }

    private async Task OnRecipeLookupCommitAsync(ChangeEventArgs args)
    {
        _recipeLookupText = args.Value?.ToString() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(_recipeLookupText))
        {
            _selectedRecipeId = null;
            _editingQueueId = null;
            ResetProductionForm(null, Math.Max(1, _productionForm.BatchCount), Math.Max(1, _productionForm.TargetDurationMinutes));
            _message = string.Empty;
            await LoadAsync();
            return;
        }

        var recipeId = TryResolveRecipeId(_recipeLookupText);
        if (recipeId is Guid selectedId)
        {
            await SelectRecipeAsync(selectedId);
            return;
        }

        _message = "Pilih resep dari daftar autocomplete yang tersedia.";
        SyncRecipeLookupText();
    }

    private async Task SelectRecipeAsync(Guid recipeId)
    {
        _selectedRecipeId = recipeId;
        _editingQueueId = null;
        ResetProductionForm(recipeId, Math.Max(1, _productionForm.BatchCount), Math.Max(1, _productionForm.TargetDurationMinutes));
        _message = string.Empty;
        await LoadAsync();
    }

    private async Task ApplyProductionRecommendationAsync(ProductionAiSuggestion suggestion)
    {
        _selectedRecipeId = suggestion.RecipeId;
        _editingQueueId = null;
        ResetProductionForm(suggestion.RecipeId, suggestion.SuggestedBatchCount, suggestion.SuggestedTargetDurationMinutes);
        _message = $"Draft produksi diisi dari rekomendasi AI untuk {suggestion.RecipeName}.";
        await LoadAsync();
    }

    private async Task OnBatchCountChangedAsync(int value)
    {
        _productionForm.BatchCount = Math.Max(1, value);
        _message = string.Empty;
        await LoadAsync();
    }

    private async Task OnTargetDurationChangedAsync(int value)
    {
        _productionForm.TargetDurationMinutes = Math.Max(1, value);
        _message = string.Empty;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OpenQuickStockAsync(ProductionRequirementLine requirement)
    {
        if (requirement.IsSufficient)
        {
            return;
        }

        _quickStockMaterialId = requirement.MaterialId;
        _quickStockForm = CreateQuickStockRequest(requirement);
        _quickStockMessage = string.Empty;
        _quickStockMessageTone = "info";
        await FocusQuickStockAsync();
    }

    private void CloseQuickStockComposer()
    {
        _quickStockMaterialId = null;
        _quickStockForm = CreateQuickStockRequest();
        _quickStockMessage = string.Empty;
        _quickStockMessageTone = "info";
    }

    private void UseSuggestedQuickStockQuantity()
    {
        if (QuickStockRequirement is null)
        {
            return;
        }

        _quickStockForm.Quantity = GetSuggestedQuickStockQuantity(QuickStockRequirement);
        _quickStockMessage = string.Empty;
        _quickStockMessageTone = "info";
    }

    private async Task SaveQuickStockAsync()
    {
        var requirement = QuickStockRequirement;
        if (requirement is null)
        {
            CloseQuickStockComposer();
            return;
        }

        _isSavingQuickStock = true;
        _quickStockMessage = string.Empty;
        _quickStockMessageTone = "info";
        _quickStockForm.MaterialId = requirement.MaterialId;
        _quickStockForm.Type = StockMovementType.StockIn;
        _quickStockForm.OccurredAt = DateTime.Now;
        _quickStockForm.Note = $"Isi stok cepat dari produksi untuk {requirement.MaterialName}";

        var result = await WarehouseService.RecordMovementAsync(_quickStockForm);
        _isSavingQuickStock = false;
        _quickStockMessage = result.Message;
        _quickStockMessageTone = result.Success ? "success" : "error";
        if (!result.Success)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        await LoadAsync();

        var refreshedRequirement = QuickStockRequirement;
        if (refreshedRequirement is null)
        {
            _message = $"Stok {requirement.MaterialName} sudah ditambahkan dan kebutuhan draft ini sekarang cukup.";
            CloseQuickStockComposer();
            return;
        }

        _quickStockForm = CreateQuickStockRequest(refreshedRequirement);
        _quickStockMessage = $"Stok masuk dicatat. Tersisa kurang {refreshedRequirement.ShortageQuantity:0.####} {refreshedRequirement.BaseUnit} untuk draft ini.";
        _quickStockMessageTone = "info";
        await FocusQuickStockAsync();
    }

    private Task SaveQueueAsync()
        => SaveQueueCoreAsync(false);

    private async Task SaveQueueAndStartAsync()
    {
        if (!_productionEditContext.Validate())
        {
            _message = "Periksa lagi batch dan timer target yang masih belum valid.";
            return;
        }

        await SaveQueueCoreAsync(true);
    }

    private async Task SaveQueueCoreAsync(bool startImmediately)
    {
        _productionForm.BatchId = _editingQueueId;
        _productionForm.RecipeId = _selectedRecipeId;

        var result = await ProductionService.UpsertQueueAsync(_productionForm);
        _message = result.Message;
        if (!result.Success)
        {
            return;
        }

        if (startImmediately && result.Batch is { Id: var batchId, CanStart: true })
        {
            var started = await ProductionService.StartQueuedProductionAsync(batchId);
            _message = started.Message;
            if (!started.Success)
            {
                await LoadAsync();
                return;
            }
        }

        _editingQueueId = null;
        ResetProductionForm(_selectedRecipeId);
        await LoadAsync();
    }

    private async Task EditQueueAsync(Guid batchId)
    {
        if (_snapshot is null)
        {
            return;
        }

        var item = _snapshot.Queue.FirstOrDefault(queue => queue.Id == batchId);
        if (item is null)
        {
            _message = "Antrian produksi tidak ditemukan.";
            return;
        }

        _editingQueueId = item.Id;
        _selectedRecipeId = item.RecipeId;
        _productionForm = new ProductionBatchCreateRequest
        {
            BatchId = item.Id,
            RecipeId = item.RecipeId,
            BatchCount = item.BatchCount,
            TargetDurationMinutes = Math.Max(1, item.TargetDurationMinutes),
            StartedAt = item.StartedAt ?? DateTime.Now,
            Notes = item.Notes
        };
        InitializeProductionEditContext();

        _message = $"Mode edit aktif untuk antrian {item.BatchCode}.";
        await LoadAsync();
    }

    private async Task StartQueuedProductionAsync(Guid batchId)
    {
        _alarmedBatchIds.Remove(batchId);

        var result = await ProductionService.StartQueuedProductionAsync(batchId);
        _message = result.Message;
        if (!result.Success)
        {
            return;
        }

        if (_editingQueueId == batchId)
        {
            _editingQueueId = null;
            ResetProductionForm(_selectedRecipeId);
        }

        await LoadAsync();
    }

    private async Task CompleteProductionAsync(Guid batchId)
    {
        var result = await ProductionService.CompleteProductionAsync(batchId);
        _message = result.Message;
        await LoadAsync();
    }

    private void CancelQueueEdit()
    {
        _editingQueueId = null;
        ResetProductionForm(_selectedRecipeId);
        _message = string.Empty;
    }

    private async Task RunClockAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));

        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(async () =>
                {
                    await CheckExpiredTimersAsync();
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task CheckExpiredTimersAsync()
    {
        if (_snapshot is null || _isDisposed)
        {
            return;
        }

        var newlyExpired = _snapshot.History
            .Where(item => item.Status == ProductionRunStatus.Running && IsTimerExpired(item) && !_alarmedBatchIds.Contains(item.Id))
            .Select(item => item.Id)
            .ToArray();

        if (newlyExpired.Length == 0)
        {
            return;
        }

        foreach (var id in newlyExpired)
        {
            _alarmedBatchIds.Add(id);
        }

        try
        {
            await JS.InvokeVoidAsync("productionTimer.playAlarm");
        }
        catch (JSDisconnectedException)
        {
        }
        catch (InvalidOperationException)
        {
        }
    }

    private DateTime? GetTargetEndsAt(ProductionBatchListItem item)
        => item.StartedAt?.AddMinutes(item.TargetDurationMinutes);

    private bool IsTimerExpired(ProductionBatchListItem item)
        => item.Status == ProductionRunStatus.Running
            && GetTargetEndsAt(item) is DateTime targetEndsAt
            && targetEndsAt <= DateTime.Now;

    private string GetTimerDisplay(ProductionBatchListItem item)
    {
        if (item.Status == ProductionRunStatus.Queued)
        {
            return FormatDuration(item.TargetDurationMinutes);
        }

        if (item.Status == ProductionRunStatus.Completed)
        {
            return FormatDuration(item.TargetDurationMinutes);
        }

        var targetEndsAt = GetTargetEndsAt(item);
        if (targetEndsAt is null)
        {
            return FormatDuration(item.TargetDurationMinutes);
        }

        var delta = targetEndsAt.Value - DateTime.Now;
        return delta >= TimeSpan.Zero
            ? FormatClock(delta)
            : $"Lewat {FormatClock(delta.Duration())}";
    }

    private string GetTimerSubcopy(ProductionBatchListItem item)
    {
        if (item.Status == ProductionRunStatus.Queued)
        {
            return $"Masuk antrian {item.QueuedAt:dd MMM yyyy HH:mm}";
        }

        if (item.Status == ProductionRunStatus.Completed)
        {
            return $"Target {FormatDuration(item.TargetDurationMinutes)}";
        }

        return IsTimerExpired(item)
            ? $"Target {FormatDuration(item.TargetDurationMinutes)} telah lewat"
            : $"Alarm berbunyi saat sisa waktu habis";
    }

    private static string FormatDuration(int minutes)
    {
        var safeMinutes = Math.Max(1, minutes);
        var duration = TimeSpan.FromMinutes(safeMinutes);
        return duration.TotalHours >= 1
            ? $"{(int)duration.TotalHours} jam {duration.Minutes:00} menit"
            : $"{duration.Minutes} menit";
    }

    private static string FormatClock(TimeSpan value)
    {
        var totalHours = (int)Math.Floor(value.TotalHours);
        return $"{totalHours:00}:{value.Minutes:00}:{value.Seconds:00}";
    }

    private static int ParseDisplayCount(string? value, int fallback)
        => int.TryParse(value, out var parsed) && parsed > 0 ? parsed : fallback;

    private static int ParsePage(string? value, int fallback, int totalPages)
        => int.TryParse(value, out var parsed) && parsed > 0
            ? Math.Min(parsed, Math.Max(1, totalPages))
            : fallback;

    private static int CalculateTotalPages(int totalItems, int pageSize)
        => Math.Max(1, (int)Math.Ceiling(totalItems / (double)Math.Max(1, pageSize)));

    private static int ClampPage(int page, int totalPages)
        => Math.Min(Math.Max(1, page), Math.Max(1, totalPages));

    private async Task FocusQuickStockAsync()
    {
        await InvokeAsync(StateHasChanged);

        try
        {
            await JS.InvokeVoidAsync("viewportHelper.scrollToId", "production-quick-stock", "nearest");
            await JS.InvokeVoidAsync("viewportHelper.focusById", "production-quick-stock-input", true);
        }
        catch (JSDisconnectedException)
        {
        }
        catch (InvalidOperationException)
        {
        }
    }

    private void ResetProductionForm(Guid? recipeId, int batchCount = 1, int targetDuration = 30)
    {
        _productionForm = new ProductionBatchCreateRequest
        {
            RecipeId = recipeId,
            BatchCount = Math.Max(1, batchCount),
            TargetDurationMinutes = Math.Max(1, targetDuration),
            StartedAt = DateTime.Now
        };
        InitializeProductionEditContext();
    }

    private void InitializeProductionEditContext()
        => _productionEditContext = new EditContext(_productionForm);

    private static StockMovementRequest CreateQuickStockRequest(ProductionRequirementLine? requirement = null)
        => new()
        {
            MaterialId = requirement?.MaterialId,
            Type = StockMovementType.StockIn,
            Quantity = GetSuggestedQuickStockQuantity(requirement),
            OccurredAt = DateTime.Now,
            Note = requirement is null ? string.Empty : $"Isi stok cepat dari produksi untuk {requirement.MaterialName}"
        };

    private static decimal GetSuggestedQuickStockQuantity(ProductionRequirementLine? requirement)
    {
        if (requirement is null)
        {
            return 1m;
        }

        var suggested = requirement.ShortageQuantity > 0
            ? requirement.ShortageQuantity
            : requirement.RequiredQuantity;

        return decimal.Round(Math.Max(0.0001m, suggested), 4);
    }

    private static string FormatCurrency(decimal value)
        => value.ToString("C0", new System.Globalization.CultureInfo("id-ID"));

    private Guid? TryResolveRecipeId(string? value)
    {
        if (_snapshot is null || string.IsNullOrWhiteSpace(value))
        {
            return null;
        }

        var query = value.Trim();
        var exact = _snapshot.Recipes.FirstOrDefault(item =>
            string.Equals(GetRecipeLookupLabel(item), query, StringComparison.OrdinalIgnoreCase)
            || string.Equals(item.Code, query, StringComparison.OrdinalIgnoreCase)
            || string.Equals(item.Name, query, StringComparison.OrdinalIgnoreCase));

        if (exact is not null)
        {
            return exact.RecipeId;
        }

        var partial = _snapshot.Recipes.FirstOrDefault(item =>
            item.Code.Contains(query, StringComparison.OrdinalIgnoreCase)
            || item.Name.Contains(query, StringComparison.OrdinalIgnoreCase));

        return partial?.RecipeId;
    }

    private static string GetRecipeLookupLabel(ProductionRecipeOption recipe)
        => $"{recipe.Code} - {recipe.Name}";

    private void SyncRecipeLookupText()
    {
        if (SelectedRecipeOption is not null)
        {
            _recipeLookupText = GetRecipeLookupLabel(SelectedRecipeOption);
            return;
        }

        if (_selectedRecipeId is null)
        {
            _recipeLookupText = string.Empty;
        }
    }

    private static string GetDraftReadinessClass(ProductionDraft draft)
        => draft.CanStart ? "ok" : draft.CanQueue ? "warn" : "muted";

    private static string GetDraftReadinessLabel(ProductionDraft draft)
        => draft.CanStart ? "Siap masuk produksi" : draft.CanQueue ? "Bisa diantrikan" : "Perlu perbaikan resep";

    private static string GetAiConfidenceLabel(string confidence) => confidence switch
    {
        "high" => "Tinggi",
        "low" => "Rendah",
        _ => "Sedang"
    };

    private static string GetAiConfidenceClass(string confidence) => confidence switch
    {
        "high" => "ok",
        "low" => "muted",
        _ => "running"
    };

    private async Task ScrollToSectionAsync(string sectionId)
    {
        try
        {
            await JS.InvokeVoidAsync("viewportHelper.scrollToId", sectionId);
        }
        catch (JSDisconnectedException)
        {
        }
        catch (InvalidOperationException)
        {
        }
    }

    private void HandleStoreChanged()
    {
        if (_isDisposed)
        {
            return;
        }

        _ = InvokeAsync(LoadAsync);
    }

    public async ValueTask DisposeAsync()
    {
        if (_isDisposed)
        {
            return;
        }

        _isDisposed = true;
        Store.Changed -= HandleStoreChanged;

        if (_clockCts is not null)
        {
            await _clockCts.CancelAsync();
            _clockCts.Dispose();
        }

        if (_clockTask is not null)
        {
            try
            {
                await _clockTask;
            }
            catch (OperationCanceledException)
            {
            }
        }
    }
}
