@page "/"
@page "/dashboard"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject DashboardService DashboardService
@inject DashboardState State
@inject IBusinessDataStore DataStore

<PageTitle>Dashboard | HPP Ultimate</PageTitle>

<section class="dashboard-page">
    <div class="dashboard-toolbar">
        <div class="toolbar-copy">
            <span>Real-time dashboard</span>
            <h1>Kondisi bisnis, HPP, biaya, dan profit dalam satu layar.</h1>
        </div>

        <div class="toolbar-actions">
            <div class="period-switch">
                @foreach (var preset in Presets)
                {
                    <button type="button"
                            class="@(State.Preset == preset ? "active" : null)"
                            @onclick="() => ApplyPresetAsync(preset)">
                        @GetPresetLabel(preset)
                    </button>
                }
            </div>

            <div class="filter-row">
                <select value="@SelectedProductValue" @onchange="OnProductChangedAsync">
                    <option value="">Semua produk</option>
                    @if (_snapshot is not null)
                    {
                        @foreach (var product in _snapshot.AvailableProducts)
                        {
                            <option value="@product.Id">@product.Name</option>
                        }
                    }
                </select>

                @if (State.Preset == DashboardPeriodPreset.Custom)
                {
                    <InputDate @bind-Value="_customFrom" class="date-input" />
                    <InputDate @bind-Value="_customTo" class="date-input" />
                    <button type="button" class="ghost-button" @onclick="ApplyCustomRangeAsync">Terapkan</button>
                }

                <button type="button" class="ghost-button" @onclick="ReloadFromUiAsync">Refresh</button>
                <div class="update-chip">@GetUpdatedLabel()</div>
            </div>
        </div>
    </div>

    @if (_isLoading && _snapshot is null)
    {
        <div class="skeleton-grid">
            @for (var index = 0; index < 6; index++)
            {
                <div class="skeleton-card"></div>
            }
        </div>
    }
    else if (_snapshot is not null)
    {
        <div class="summary-grid">
            @foreach (var metric in _snapshot.Metrics)
            {
                <SummaryCard Metric="metric" />
            }
        </div>

        <div class="visual-grid">
            <DonutChartCard Title="Cost Mix"
                            Subtitle="Komposisi biaya produksi"
                            TotalValue="@TotalCostLabel"
                            Items="_snapshot.CostBreakdown" />

            <BarSeriesCard Title="Produksi"
                           Subtitle="@($"Output { _snapshot.Range.Label.ToLowerInvariant() }")"
                           Items="_snapshot.ProductionSeries" />

            <div class="top-grid">
                <RankedBarsCard Title="Top Volume"
                                Subtitle="Produksi terbanyak"
                                Items="_snapshot.TopProductsByVolume" />

                <RankedBarsCard Title="Top Profit"
                                Subtitle="Profit tertinggi"
                                Items="_snapshot.TopProductsByProfit" />
            </div>
        </div>

        <div class="detail-grid">
            <section class="table-card">
                <div class="table-head">
                    <div>
                        <span>Ringkasan produk</span>
                        <h2>HPP, harga jual, dan profit per produk</h2>
                    </div>

                    <input value="@State.SearchText"
                           @oninput="OnSearchInput"
                           class="table-search"
                           placeholder="Cari produk" />
                </div>

                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th><button type="button" @onclick='() => SortBy("name")'>Produk</button></th>
                                <th><button type="button" @onclick='() => SortBy("production")'>Produksi</button></th>
                                <th><button type="button" @onclick='() => SortBy("hpp")'>HPP / Unit</button></th>
                                <th><button type="button" @onclick='() => SortBy("price")'>Harga Jual</button></th>
                                <th><button type="button" @onclick='() => SortBy("profitunit")'>Profit / Unit</button></th>
                                <th><button type="button" @onclick='() => SortBy("profit")'>Total Profit</button></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (PagedRows.Count == 0)
                            {
                                <tr>
                                    <td colspan="6" class="empty-cell">Tidak ada data untuk filter ini.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var row in PagedRows)
                                {
                                    <tr>
                                        <td>
                                            <strong>@row.ProductName</strong>
                                            <small>Margin @row.MarginPercentage.ToString("0.0")%</small>
                                        </td>
                                        <td>@row.TotalProduction.ToString("N0") unit</td>
                                        <td>@FormatCurrency(row.HppPerUnit)</td>
                                        <td>@FormatCurrency(row.SellingPrice)</td>
                                        <td class="@(row.ProfitPerUnit >= 0 ? "profit-text" : "loss-text")">@FormatCurrency(row.ProfitPerUnit)</td>
                                        <td class="@(row.TotalProfit >= 0 ? "profit-text" : "loss-text")">@FormatCurrency(row.TotalProfit)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <div class="table-footer">
                    <small>@FilteredRows.Count produk ditemukan</small>

                    <div class="pager">
                        <button type="button" @onclick="PreviousPage" disabled="@(State.Page == 1)">Prev</button>
                        <span>Halaman @State.Page / @TotalPages</span>
                        <button type="button" @onclick="NextPage" disabled="@(State.Page >= TotalPages)">Next</button>
                    </div>
                </div>
            </section>

            <aside class="side-stack">
                <section class="insight-card">
                    <div class="side-head">
                        <span>Insight otomatis</span>
                        <h2>Alert & rekomendasi</h2>
                    </div>

                    <div class="insight-list">
                        @foreach (var insight in _snapshot.Insights)
                        {
                            <article class="insight-item @GetSeverityClass(insight.Severity)">
                                <strong>@insight.Title</strong>
                                <small>@insight.Detail</small>
                            </article>
                        }
                    </div>
                </section>

                <section class="activity-card">
                    <div class="side-head">
                        <span>Aktivitas terbaru</span>
                        <h2>Perubahan produksi dan biaya</h2>
                    </div>

                    <div class="activity-list">
                        @foreach (var activity in _snapshot.Activities)
                        {
                            <article class="activity-item">
                                <div class="activity-dot"></div>
                                <div>
                                    <span>@activity.Type</span>
                                    <strong>@activity.Title</strong>
                                    <small>@activity.Detail</small>
                                </div>
                                <time>@activity.Timestamp.ToString("dd MMM HH:mm")</time>
                            </article>
                        }
                    </div>
                </section>
            </aside>
        </div>
    }
</section>

@code {
    private readonly DashboardPeriodPreset[] Presets =
    [
        DashboardPeriodPreset.Today,
        DashboardPeriodPreset.ThisWeek,
        DashboardPeriodPreset.ThisMonth,
        DashboardPeriodPreset.Custom
    ];

    private DashboardSnapshot? _snapshot;
    private bool _isLoading = true;
    private PeriodicTimer? _timer;
    private CancellationTokenSource? _timerCancellation;
    private DateOnly? _customFrom = DateOnly.FromDateTime(DateTime.Today.AddDays(-29));
    private DateOnly? _customTo = DateOnly.FromDateTime(DateTime.Today);

    private string SelectedProductValue => State.SelectedProductId?.ToString() ?? string.Empty;
    private string TotalCostLabel => _snapshot is null ? "Rp 0" : FormatCurrency(_snapshot.CostBreakdown.Sum(item => item.Amount));

    private IReadOnlyList<ProductSummaryRow> FilteredRows =>
        ApplySearchAndSorting(_snapshot?.ProductRows ?? Array.Empty<ProductSummaryRow>()).ToArray();

    private IReadOnlyList<ProductSummaryRow> PagedRows =>
        FilteredRows.Skip((State.Page - 1) * State.PageSize).Take(State.PageSize).ToArray();

    private int TotalPages => Math.Max(1, (int)Math.Ceiling(FilteredRows.Count / (double)State.PageSize));

    protected override async Task OnInitializedAsync()
    {
        DataStore.Changed += HandleStoreChanged;
        _timerCancellation = new CancellationTokenSource();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(20));
        _ = RunPeriodicRefreshAsync(_timer, _timerCancellation.Token);

        await ReloadAsync();
    }

    private async Task RunPeriodicRefreshAsync(PeriodicTimer timer, CancellationToken cancellationToken)
    {
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(async () => await ReloadAsync(silent: true));
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async void HandleStoreChanged()
    {
        await InvokeAsync(async () => await ReloadAsync(silent: true));
    }

    private async Task ReloadAsync(bool silent = false)
    {
        if (!silent)
        {
            _isLoading = true;
        }

        _snapshot = await DashboardService.GetSnapshotAsync(State.CurrentFilter);
        _isLoading = false;

        if (State.Page > TotalPages)
        {
            State.SetPage(TotalPages);
        }

        await InvokeAsync(StateHasChanged);
    }

    private Task ReloadFromUiAsync() => ReloadAsync();

    private async Task ApplyPresetAsync(DashboardPeriodPreset preset)
    {
        State.SetPreset(preset);
        await ReloadAsync();
    }

    private async Task ApplyCustomRangeAsync()
    {
        State.SetCustomRange(_customFrom, _customTo);
        await ReloadAsync();
    }

    private async Task OnProductChangedAsync(ChangeEventArgs args)
    {
        var selected = args.Value?.ToString();
        State.SetProduct(Guid.TryParse(selected, out var parsed) ? parsed : null);
        await ReloadAsync();
    }

    private void OnSearchInput(ChangeEventArgs args)
    {
        State.SetSearch(args.Value?.ToString());
        StateHasChanged();
    }

    private void SortBy(string column)
    {
        State.SetSort(column);
        StateHasChanged();
    }

    private void PreviousPage()
    {
        State.SetPage(Math.Max(1, State.Page - 1));
        StateHasChanged();
    }

    private void NextPage()
    {
        State.SetPage(Math.Min(TotalPages, State.Page + 1));
        StateHasChanged();
    }

    private IEnumerable<ProductSummaryRow> ApplySearchAndSorting(IEnumerable<ProductSummaryRow> rows)
    {
        if (!string.IsNullOrWhiteSpace(State.SearchText))
        {
            rows = rows.Where(row => row.ProductName.Contains(State.SearchText, StringComparison.OrdinalIgnoreCase));
        }

        rows = State.SortColumn switch
        {
            "name" => State.SortDescending ? rows.OrderByDescending(row => row.ProductName) : rows.OrderBy(row => row.ProductName),
            "production" => State.SortDescending ? rows.OrderByDescending(row => row.TotalProduction) : rows.OrderBy(row => row.TotalProduction),
            "hpp" => State.SortDescending ? rows.OrderByDescending(row => row.HppPerUnit) : rows.OrderBy(row => row.HppPerUnit),
            "price" => State.SortDescending ? rows.OrderByDescending(row => row.SellingPrice) : rows.OrderBy(row => row.SellingPrice),
            "profitunit" => State.SortDescending ? rows.OrderByDescending(row => row.ProfitPerUnit) : rows.OrderBy(row => row.ProfitPerUnit),
            _ => State.SortDescending ? rows.OrderByDescending(row => row.TotalProfit) : rows.OrderBy(row => row.TotalProfit)
        };

        return rows;
    }

    private static string GetPresetLabel(DashboardPeriodPreset preset) => preset switch
    {
        DashboardPeriodPreset.Today => "Hari ini",
        DashboardPeriodPreset.ThisWeek => "Minggu ini",
        DashboardPeriodPreset.ThisMonth => "Bulan ini",
        DashboardPeriodPreset.Custom => "Custom",
        _ => preset.ToString()
    };

    private string GetUpdatedLabel()
    {
        if (_isLoading)
        {
            return "Memuat...";
        }

        return _snapshot is null ? "Belum ada data" : $"Update {_snapshot.LastUpdated:HH:mm:ss}";
    }

    private static string FormatCurrency(decimal value) => string.Create(new System.Globalization.CultureInfo("id-ID"), $"Rp {value:N0}");

    private static string GetSeverityClass(InsightSeverity severity) => severity switch
    {
        InsightSeverity.Success => "is-success",
        InsightSeverity.Warning => "is-warning",
        InsightSeverity.Danger => "is-danger",
        _ => string.Empty
    };

    public async ValueTask DisposeAsync()
    {
        DataStore.Changed -= HandleStoreChanged;

        if (_timerCancellation is not null)
        {
            await _timerCancellation.CancelAsync();
            _timerCancellation.Dispose();
        }

        _timer?.Dispose();
    }
}
