@page "/pengaturan/akun"
@rendermode InteractiveServer
@implements IDisposable
@inject AuthService AuthService
@inject SeededBusinessDataStore Store
@inject NavigationManager Navigation

<PageTitle>Pengaturan Akun | HPP Ultimate</PageTitle>

<section class="account-page">
    <div class="account-hero">
        <div class="hero-copy">
            <div class="hero-nav">
                <a class="back-link" href="/pengaturan">Kembali ke Pengaturan</a>
            </div>
            <span>Account control center</span>
            <h1>Kelola identitas akun, keamanan sesi, dan orkestrasi akses tim dalam satu workspace.</h1>
            <p>Halaman ini menggantikan menu login sebagai pusat pengelolaan akun. Profil akun aktif, password, sesi, dan daftar user tim sekarang dipusatkan di sini.</p>

            <div class="hero-ribbon">
                <article>
                    <small>Akun aktif</small>
                    <strong>@(_snapshot?.Session?.FullName ?? "Belum login")</strong>
                </article>
                <article>
                    <small>Mode sesi</small>
                    <strong>@(_snapshot?.Session?.RememberMe == true ? "Remembered" : "Session-only")</strong>
                </article>
                <article>
                    <small>Hak akses</small>
                    <strong>@(_currentUser?.Role.ToString() ?? "-")</strong>
                </article>
            </div>
        </div>

        <div class="hero-panel">
            <article class="hero-panel-card primary">
                <span>Session Runtime</span>
                <strong>@SessionAgeLabel</strong>
                <small>@(_snapshot?.Session is null ? "Belum ada sesi login aktif." : $"Sesi dimulai {_snapshot.Session.SignedInAt:dd MMM yyyy HH:mm}")</small>
            </article>

            <article class="hero-panel-card">
                <span>Team Pulse</span>
                <strong>@(_snapshot?.ActiveUsers ?? 0) user aktif</strong>
                <small>@(_snapshot?.AdminCount ?? 0) admin dan @(_snapshot?.StaffCount ?? 0) staff tersimpan.</small>
            </article>
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="account-skeleton"></div>
    }
    else if (_snapshot is not null && _currentUser is not null)
    {
        <div class="account-layout">
            <section class="profile-card">
                <div class="section-head">
                    <div>
                        <span>Profile studio</span>
                        <h2>Profil akun aktif dan kontrol sesi</h2>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(_profileMessage))
                {
                    <div class="form-message">@_profileMessage</div>
                }

                <EditForm Model="_profileForm" OnValidSubmit="SaveProfileAsync" class="profile-form">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="profile-grid">
                        <label class="profile-identity">
                            <span>Nama Lengkap</span>
                            <InputText @bind-Value="_profileForm.FullName" />
                        </label>

                        <label>
                            <span>Email</span>
                            <InputText @bind-Value="_profileForm.Email" />
                        </label>

                        <label>
                            <span>Username</span>
                            <InputText @bind-Value="_profileForm.Username" />
                        </label>

                        <label>
                            <span>Password Baru</span>
                            <InputText @bind-Value="_profileForm.NewPassword" type="password" placeholder="Kosongkan jika tidak diubah" />
                        </label>

                        <label class="toggle-card">
                            <div>
                                <span>Remember Session</span>
                                <small>Simpan preferensi sesi saat browser ditutup.</small>
                            </div>
                            <InputCheckbox @bind-Value="_profileForm.RememberMe" />
                        </label>

                        <article class="profile-stat">
                            <small>Role</small>
                            <strong>@_currentUser.Role</strong>
                            <p>Role aktif hanya bisa berubah dari panel admin di bawah.</p>
                        </article>

                        <article class="profile-stat">
                            <small>Terakhir login</small>
                            <strong>@(_currentUser.LastLoginAt?.ToString("dd MMM yyyy HH:mm") ?? "Belum pernah")</strong>
                            <p>Timestamp ini otomatis diperbarui saat autentikasi berhasil.</p>
                        </article>

                        <article class="profile-stat">
                            <small>Updated</small>
                            <strong>@_currentUser.UpdatedAt.ToString("dd MMM yyyy HH:mm")</strong>
                            <p>Perubahan identitas dan password akan tersimpan ke store akun.</p>
                        </article>
                    </div>

                    <div class="profile-actions">
                        <button type="button" class="ghost-button" @onclick="ResetProfileForm">Reset</button>
                        <button type="button" class="ghost-button danger-outline" @onclick="LogoutAsync">Logout</button>
                        <button type="submit" class="primary-button">Simpan Profil Akun</button>
                    </div>
                </EditForm>
            </section>

            <aside class="account-side">
                <section class="insight-card">
                    <div class="section-head">
                        <div>
                            <span>Security telemetry</span>
                            <h2>Status akses dan sinyal akun</h2>
                        </div>
                    </div>

                    <div class="insight-grid">
                        <article>
                            <small>Status akun</small>
                            <strong>@_currentUser.Status</strong>
                        </article>
                        <article>
                            <small>Remember me</small>
                            <strong>@(_snapshot.Session?.RememberMe == true ? "Aktif" : "Tidak aktif")</strong>
                        </article>
                        <article>
                            <small>Admin aktif</small>
                            <strong>@_snapshot.Users.Count(item => item.Role == UserRole.Admin && item.Status == UserStatus.Active)</strong>
                        </article>
                        <article>
                            <small>User nonaktif</small>
                            <strong>@_snapshot.Users.Count(item => item.Status == UserStatus.Inactive)</strong>
                        </article>
                    </div>

                    <div class="insight-list">
                        @foreach (var insight in _snapshot.Insights)
                        {
                            <article>@insight</article>
                        }
                    </div>
                </section>

                <section class="timeline-card">
                    <div class="section-head">
                        <div>
                            <span>Activity lane</span>
                            <h2>Jejak akun dan tim terbaru</h2>
                        </div>
                    </div>

                    <div class="timeline-list">
                        @foreach (var item in RecentActivity)
                        {
                            <article>
                                <div class="timeline-dot"></div>
                                <div>
                                    <strong>@item.FullName</strong>
                                    <small>@item.Email</small>
                                    <p>@(item.LastLoginAt is null ? $"Profil diperbarui {item.UpdatedAt:dd MMM HH:mm}" : $"Login terakhir {item.LastLoginAt:dd MMM yyyy HH:mm}")</p>
                                </div>
                                <span class="mini-role">@item.Role</span>
                            </article>
                        }
                    </div>
                </section>
            </aside>
        </div>

        @if (IsAdmin)
        {
            <section class="team-card">
                <div class="team-header">
                    <div>
                        <span>Admin cockpit</span>
                        <h2>Manajemen user, peran, dan keberlanjutan akses tim</h2>
                    </div>

                    <div class="team-actions">
                        <button type="button" class="ghost-button" @onclick="ReloadAsync">Refresh</button>
                        <button type="button" class="primary-button" @onclick="OpenCreateModal">+ Tambah User</button>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(_teamMessage))
                {
                    <div class="form-message">@_teamMessage</div>
                }

                <div class="team-metrics">
                    <article>
                        <small>Total akun</small>
                        <strong>@_snapshot.TotalUsers</strong>
                    </article>
                    <article>
                        <small>Admin aktif</small>
                        <strong>@_snapshot.Users.Count(item => item.Role == UserRole.Admin && item.Status == UserStatus.Active)</strong>
                    </article>
                    <article>
                        <small>Staff aktif</small>
                        <strong>@_snapshot.Users.Count(item => item.Role == UserRole.Staff && item.Status == UserStatus.Active)</strong>
                    </article>
                    <article>
                        <small>Nonaktif</small>
                        <strong>@_snapshot.Users.Count(item => item.Status == UserStatus.Inactive)</strong>
                    </article>
                </div>

                <div class="team-workspace">
                    <div class="team-directory">
                        @foreach (var user in OrderedUsers)
                        {
                            <article class="team-user @(user.Status == UserStatus.Inactive ? "is-inactive" : null)">
                                <div class="team-user-head">
                                    <div>
                                        <strong>@user.FullName</strong>
                                        <small>@user.Email</small>
                                    </div>

                                    <span class="role-badge @(user.Role == UserRole.Admin ? "admin" : "staff")">@user.Role</span>
                                </div>

                                <div class="team-user-meta">
                                    <span>@user.Username</span>
                                    <span>@(user.LastLoginAt is null ? "Belum pernah login" : $"Login {user.LastLoginAt:dd MMM HH:mm}")</span>
                                    <span>Status: @user.Status</span>
                                </div>

                                <div class="team-user-actions">
                                    <button type="button" class="ghost-button" @onclick="() => OpenEditModal(user.Id)">Edit</button>
                                    <button type="button" class="ghost-button danger-outline" disabled="@(user.Id == _currentUser.Id)" @onclick="() => DeactivateAsync(user.Id)">
                                        Nonaktifkan
                                    </button>
                                </div>
                            </article>
                        }
                    </div>

                    <div class="permission-panel">
                        <article>
                            <small>Akun aktif saat ini</small>
                            <strong>@_currentUser.FullName</strong>
                            <p>@_currentUser.Email</p>
                        </article>
                        <article>
                            <small>Hak admin</small>
                            <strong>@(_currentUser.Role == UserRole.Admin ? "Penuh" : "Terbatas")</strong>
                            <p>Admin dapat menambah, mengubah, dan menonaktifkan akun tim.</p>
                        </article>
                        <article>
                            <small>Kebijakan password</small>
                            <strong>Min 6 karakter</strong>
                            <p>Password akun aktif bisa diubah dari panel profil di kiri.</p>
                        </article>
                    </div>
                </div>
            </section>
        }
    }
</section>

@if (_showUserModal)
{
    <div class="overlay" @onclick="CloseUserModal">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-head">
                <div>
                    <span>@(_editingUserId is null ? "Tambah user" : "Edit user")</span>
                    <h2>@(_editingUserId is null ? "Rakit akun tim baru" : "Perbarui konfigurasi akses user")</h2>
                </div>

                <button type="button" class="ghost-button" @onclick="CloseUserModal">Tutup</button>
            </div>

            @if (!string.IsNullOrWhiteSpace(_modalMessage))
            {
                <div class="form-message">@_modalMessage</div>
            }

            <EditForm Model="_userForm" OnValidSubmit="SaveUserAsync" class="modal-form">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="modal-grid">
                    <label>
                        <span>Nama Lengkap</span>
                        <InputText @bind-Value="_userForm.FullName" />
                    </label>
                    <label>
                        <span>Email</span>
                        <InputText @bind-Value="_userForm.Email" />
                    </label>
                    <label>
                        <span>Username</span>
                        <InputText @bind-Value="_userForm.Username" />
                    </label>
                    <label>
                        <span>Password</span>
                        <InputText @bind-Value="_userForm.Password" type="password" />
                    </label>
                    <label>
                        <span>Role</span>
                        <select @bind="_userForm.Role">
                            <option value="@UserRole.Admin">Admin</option>
                            <option value="@UserRole.Staff">Staff</option>
                        </select>
                    </label>
                    <label>
                        <span>Status</span>
                        <select @bind="_userForm.Status">
                            <option value="@UserStatus.Active">Aktif</option>
                            <option value="@UserStatus.Inactive">Nonaktif</option>
                        </select>
                    </label>
                </div>

                <div class="profile-actions">
                    <button type="button" class="ghost-button" @onclick="CloseUserModal">Batal</button>
                    <button type="submit" class="primary-button">@(_editingUserId is null ? "Simpan User" : "Update User")</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private AuthSnapshot? _snapshot;
    private BusinessUser? _currentUser;
    private AccountProfileRequest _profileForm = new();
    private UserUpsertRequest _userForm = new();
    private bool _isLoading = true;
    private bool _showUserModal;
    private Guid? _editingUserId;
    private string _profileMessage = string.Empty;
    private string _teamMessage = string.Empty;
    private string _modalMessage = string.Empty;

    private bool IsAdmin => _currentUser?.Role == UserRole.Admin;

    private string SessionAgeLabel
    {
        get
        {
            if (_snapshot?.Session is null)
            {
                return "-";
            }

            var elapsed = DateTime.Now - _snapshot.Session.SignedInAt;
            if (elapsed.TotalHours >= 1)
            {
                return $"{(int)elapsed.TotalHours}j {elapsed.Minutes}m";
            }

            return $"{Math.Max(1, elapsed.Minutes)}m";
        }
    }

    private IReadOnlyList<UserListItem> OrderedUsers =>
        (_snapshot?.Users ?? Array.Empty<UserListItem>())
        .OrderByDescending(item => item.Status == UserStatus.Active)
        .ThenByDescending(item => item.Role == UserRole.Admin)
        .ThenBy(item => item.FullName)
        .ToArray();

    private IReadOnlyList<UserListItem> RecentActivity =>
        (_snapshot?.Users ?? Array.Empty<UserListItem>())
        .OrderByDescending(item => item.LastLoginAt ?? item.UpdatedAt)
        .Take(6)
        .ToArray();

    protected override async Task OnInitializedAsync()
    {
        Store.Changed += HandleStoreChanged;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _snapshot = await AuthService.GetSnapshotAsync();

        if (_snapshot?.Session is null)
        {
            Navigation.NavigateTo("/login", replace: true);
            return;
        }

        _currentUser = Store.FindUser(_snapshot.Session.UserId);
        if (_currentUser is null)
        {
            await AuthService.LogoutAsync();
            Navigation.NavigateTo("/login", replace: true);
            return;
        }

        SyncProfileForm();
        _isLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private void SyncProfileForm()
    {
        if (_currentUser is null || _snapshot?.Session is null)
        {
            return;
        }

        _profileForm = new AccountProfileRequest
        {
            FullName = _currentUser.FullName,
            Email = _currentUser.Email,
            Username = _currentUser.Username,
            RememberMe = _snapshot.Session.RememberMe
        };
    }

    private async Task SaveProfileAsync()
    {
        var result = await AuthService.SaveCurrentAccountAsync(_profileForm);
        _profileMessage = result.Message;
        if (!result.Success)
        {
            return;
        }

        _profileForm.NewPassword = string.Empty;
        await LoadAsync();
    }

    private Task ReloadAsync() => LoadAsync();

    private void ResetProfileForm()
    {
        SyncProfileForm();
        _profileMessage = "Form profil dikembalikan ke data akun yang tersimpan.";
    }

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", replace: true);
    }

    private void OpenCreateModal()
    {
        _editingUserId = null;
        _modalMessage = string.Empty;
        _userForm = new UserUpsertRequest
        {
            Role = UserRole.Staff,
            Status = UserStatus.Active
        };
        _showUserModal = true;
    }

    private void OpenEditModal(Guid id)
    {
        var user = Store.FindUser(id);
        if (user is null)
        {
            return;
        }

        _editingUserId = id;
        _modalMessage = string.Empty;
        _userForm = new UserUpsertRequest
        {
            Id = user.Id,
            FullName = user.FullName,
            Email = user.Email,
            Username = user.Username,
            Password = user.Password,
            Role = user.Role,
            Status = user.Status
        };
        _showUserModal = true;
    }

    private void CloseUserModal()
    {
        _showUserModal = false;
        _editingUserId = null;
        _modalMessage = string.Empty;
    }

    private async Task SaveUserAsync()
    {
        var result = await AuthService.SaveUserAsync(_userForm);
        _modalMessage = result.Message;
        _teamMessage = result.Message;
        if (!result.Success)
        {
            return;
        }

        CloseUserModal();
        await LoadAsync();
    }

    private async Task DeactivateAsync(Guid id)
    {
        var result = await AuthService.DeactivateUserAsync(id);
        _teamMessage = result.Message;
        await LoadAsync();
    }

    private async void HandleStoreChanged()
    {
        await InvokeAsync(async () => await LoadAsync());
    }

    public void Dispose()
    {
        Store.Changed -= HandleStoreChanged;
    }
}
