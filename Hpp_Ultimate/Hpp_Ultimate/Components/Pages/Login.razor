@page "/login"
@rendermode InteractiveServer
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Login | HPP Ultimate</PageTitle>

<section class="login-page">
    <div class="login-brand">
        <span class="brand-eyebrow">HPP Ultimate</span>
        <h1>Masuk ke workspace material.</h1>
        <p>Gunakan email atau username yang tersimpan untuk melanjutkan ke katalog material.</p>
    </div>

    <section class="login-card">
        <div class="login-card-head">
            <span>Sign In</span>
            <h2>Masuk ke akun kamu</h2>
        </div>

        @if (!string.IsNullOrWhiteSpace(_loginMessage))
        {
            <div class="form-message">@_loginMessage</div>
        }

        <EditForm Model="_loginForm" OnValidSubmit="SignInAsync" class="login-form">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <label>
                <span>Email / Username</span>
                <InputText @bind-Value="_loginForm.Identity" placeholder="Masukkan email atau username" />
                <ValidationMessage For="@(() => _loginForm.Identity)" />
            </label>

            <label>
                <span>Password</span>
                <InputText @bind-Value="_loginForm.Password" type="password" placeholder="Masukkan password" />
                <ValidationMessage For="@(() => _loginForm.Password)" />
            </label>

            <label class="remember-row">
                <InputCheckbox @bind-Value="_loginForm.RememberMe" />
                <small>Ingat sesi ini</small>
            </label>

            <button type="submit" class="login-button">Masuk</button>
        </EditForm>
    </section>
</section>

@code {
    private LoginRequest _loginForm = new();
    private string _loginMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var snapshot = await AuthService.GetSnapshotAsync();
        if (snapshot.Session is not null)
        {
            Navigation.NavigateTo("/produk", replace: true);
        }
    }

    private async Task SignInAsync()
    {
        var result = await AuthService.LoginAsync(_loginForm);
        _loginMessage = result.Message;
        if (!result.Success)
        {
            return;
        }

        _loginForm = new LoginRequest();
        Navigation.NavigateTo("/produk", replace: true);
    }
}
