@page "/login"
@rendermode InteractiveServer
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Login | HPP Ultimate</PageTitle>

<section class="login-page ds-page ds-page-stack theme-indigo">
    <section class="login-intro-card">
        <div class="login-intro-copy">
            <span>Workspace operasional</span>
            <h1>Masuk ke workspace</h1>
            <p>Setelah login, user langsung masuk ke dashboard prioritas untuk stok, pembelian, produksi, kasir, dan pembukuan dalam satu workspace operasional.</p>
        </div>

        <div class="login-benefit-list">
            <article>
                <strong>Stok dan restock lebih cepat</strong>
                <small>Pantau stok minimum, catat mutasi, dan tindak lanjuti pembelian yang masih pending.</small>
            </article>
            <article>
                <strong>Produksi dan kasir tetap nyambung</strong>
                <small>Batch yang selesai langsung bisa dijual, lalu transaksi masuk ke pembukuan tanpa input ulang.</small>
            </article>
            <article>
                <strong>Satu workspace per operasi harian</strong>
                <small>Data tersimpan dalam workspace aktif, jadi user bisa lanjut kerja dari dashboard yang sama setelah berhasil masuk.</small>
            </article>
        </div>

        <div class="login-trust-note">
            <strong>Masuk aman ke workspace aktif</strong>
            <small>Gunakan akun tim yang sudah dibuat admin. Setelah berhasil login, sistem langsung membuka dashboard prioritas harian.</small>
        </div>
    </section>

    <section class="login-card">
        <div class="login-card-head">
            <span>Masuk</span>
            <h2>Login akun</h2>
            <p>Isi akun untuk membuka dashboard prioritas, stok, produksi, kasir, dan pembukuan dalam satu workspace.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(_loginMessage))
        {
            <div class="form-message">@_loginMessage</div>
        }

        <EditForm Model="_loginForm" OnValidSubmit="SignInAsync" class="login-form">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <label>
                <span>Email / Username</span>
                <div class="field-shell">
                    <InputText @bind-Value="_loginForm.Identity" class="login-input" autocomplete="username" placeholder="Masukkan email atau username" />
                </div>
                <ValidationMessage For="@(() => _loginForm.Identity)" />
            </label>

            <label>
                <span>Password</span>
                <div class="field-shell">
                    <InputText @bind-Value="_loginForm.Password" class="login-input" type="password" autocomplete="current-password" placeholder="Masukkan password" />
                </div>
                <ValidationMessage For="@(() => _loginForm.Password)" />
            </label>

            <label class="remember-row">
                <InputCheckbox @bind-Value="_loginForm.RememberMe" class="remember-input" />
                <small>Ingat sesi ini</small>
            </label>

            <button type="submit" class="login-button">Masuk ke Dashboard</button>
        </EditForm>
    </section>
</section>

@code {
    private LoginRequest _loginForm = new();
    private string _loginMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var snapshot = await AuthService.GetSnapshotAsync();
        if (snapshot.Session is not null)
        {
            Navigation.NavigateTo("/", replace: true);
        }
    }

    private async Task SignInAsync()
    {
        var result = await AuthService.LoginAsync(_loginForm);
        _loginMessage = result.Message;
        if (!result.Success)
        {
            return;
        }

        _loginForm = new LoginRequest();
        Navigation.NavigateTo("/", replace: true);
    }
}
