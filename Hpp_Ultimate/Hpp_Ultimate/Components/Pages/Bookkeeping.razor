@page "/pembukuan"
@rendermode InteractiveServer
@implements IAsyncDisposable
@using System.Globalization
@inject BookkeepingService BookkeepingService
@inject GeminiBookkeepingAssistantService GeminiBookkeepingAssistantService
@inject SeededBusinessDataStore Store

<PageTitle>Pembukuan | HPP Ultimate</PageTitle>

<section class="bookkeeping-page ds-page ds-split-workspace theme-indigo">
    <header class="bookkeeping-header ds-page-header">
        <div class="header-copy">
            <span class="section-tag">Pembukuan</span>
            <h1>Ledger kas kerja</h1>
            <p>Semua transaksi kasir, pembelian selesai, dan entry manual dibaca dari satu ledger yang lebih cepat discan.</p>
        </div>

        <div class="header-actions">
            <div class="status-chip">@_statusMessage</div>
        </div>
    </header>

    @if (_isLoading && _snapshot is null)
    {
        <div class="table-skeleton"></div>
    }
    else if (_snapshot is not null)
    {
        <div class="bookkeeping-workspace ds-list-detail">
            <section class="ledger-card catalog-datagrid">
                <div class="section-head ds-card-header">
                    <div>
                        <span class="section-tag">Ledger</span>
                        <h2>Arus kas terkini</h2>
                        <p>Tabel utama untuk membaca mutasi, sumber transaksi, dan saldo berjalan tanpa pindah panel.</p>
                    </div>

                    <div class="ledger-head-actions">
                        <label class="display-count-control">
                            <span>Baris tampil</span>
                            <select value="@_ledgerDisplayCount" @onchange="OnLedgerDisplayCountChanged">
                                @foreach (var option in GridDisplayOptions)
                                {
                                    <option value="@option">@option baris</option>
                                }
                            </select>
                        </label>
                    </div>
                </div>

                <div class="ledger-overview-band">
                    <div class="summary-strip ds-summary-strip compact">
                        <article>
                            <small>Total masuk</small>
                            <strong>@FormatCurrency(_snapshot.TotalIncome)</strong>
                        </article>
                        <article>
                            <small>Total keluar</small>
                            <strong>@FormatCurrency(_snapshot.TotalExpense)</strong>
                        </article>
                        <article>
                            <small>Saldo</small>
                            <strong>@FormatCurrency(_snapshot.ClosingBalance)</strong>
                        </article>
                        <article>
                            <small>Entry</small>
                            <strong>@_snapshot.TotalEntries</strong>
                        </article>
                    </div>
                    <p class="ledger-overview-copy">Tambah entry manual hanya untuk transaksi kecil di luar kasir, pembelian, atau sistem stok utama.</p>
                </div>

                @if (_snapshot.Items.Count == 0)
                {
                    <div class="empty-state">
                        Belum ada data pembukuan.
                    </div>
                }
                else
                {
                    <div class="ledger-grid-shell">
                        <QuickGrid Items="VisibleLedgerItems.AsQueryable()" Class="ledger-quickgrid">
                        <TemplateColumn Title="Tanggal" Context="item">
                            <div class="table-primary">
                                <strong>@item.OccurredAt.ToString("dd MMM yyyy")</strong>
                                <small>@item.OccurredAt.ToString("HH:mm")</small>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Ref" Context="item">
                            <div class="table-primary">
                                <strong>@item.ReferenceNumber</strong>
                                <small>@item.SourceType</small>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Keterangan" Context="item">
                            <div class="table-primary">
                                <strong>@item.Title</strong>
                                <small>@item.Detail</small>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Pihak" Context="item">
                            <div class="history-meta-cell">
                                <strong>@(string.IsNullOrWhiteSpace(item.Counterparty) ? "-" : item.Counterparty)</strong>
                                <small>@item.StatusLabel</small>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Masuk" Context="item">
                            <div class="amount-cell income">
                                <strong>@(item.AmountIn <= 0 ? "-" : FormatCurrency(item.AmountIn))</strong>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Keluar" Context="item">
                            <div class="amount-cell expense">
                                <strong>@(item.AmountOut <= 0 ? "-" : FormatCurrency(item.AmountOut))</strong>
                            </div>
                        </TemplateColumn>
                        <TemplateColumn Title="Saldo" Context="item">
                            <div class="amount-cell balance">
                                <strong>@FormatCurrency(item.RunningBalance)</strong>
                            </div>
                        </TemplateColumn>
                        </QuickGrid>
                    </div>

                    <div class="ledger-card-list">
                        @foreach (var item in VisibleLedgerItems)
                        {
                            <article class="ledger-mobile-card">
                                <div class="ledger-mobile-head">
                                    <div class="table-primary">
                                        <strong>@item.Title</strong>
                                        <small>@item.ReferenceNumber - @item.SourceType</small>
                                    </div>

                                    <div class="amount-cell balance">
                                        <small>Saldo</small>
                                        <strong>@FormatCurrency(item.RunningBalance)</strong>
                                    </div>
                                </div>

                                <div class="ledger-mobile-grid">
                                    <article>
                                        <small>Tanggal</small>
                                        <strong>@item.OccurredAt.ToString("dd MMM yyyy")</strong>
                                        <span>@item.OccurredAt.ToString("HH:mm")</span>
                                    </article>
                                    <article>
                                        <small>Pihak</small>
                                        <strong>@(string.IsNullOrWhiteSpace(item.Counterparty) ? "-" : item.Counterparty)</strong>
                                        <span>@item.StatusLabel</span>
                                    </article>
                                    <article>
                                        <small>Masuk</small>
                                        <strong>@(item.AmountIn <= 0 ? "-" : FormatCurrency(item.AmountIn))</strong>
                                    </article>
                                    <article>
                                        <small>Keluar</small>
                                        <strong>@(item.AmountOut <= 0 ? "-" : FormatCurrency(item.AmountOut))</strong>
                                    </article>
                                </div>

                                <p class="ledger-mobile-copy">@item.Detail</p>
                            </article>
                        }
                    </div>

                    <div class="table-footer">
                        <small>@_snapshot.TotalEntries entry</small>
                        <div class="pager">
                            <button type="button" @onclick="PrevLedgerPage" disabled="@(CurrentLedgerPage <= 1)">Prev</button>
                            <label class="pager-select" aria-label="Pilih halaman pembukuan">
                                <select value="@CurrentLedgerPage" @onchange="OnLedgerPageChanged">
                                    @for (var pageNumber = 1; pageNumber <= LedgerTotalPages; pageNumber++)
                                    {
                                        <option value="@pageNumber">Halaman @pageNumber</option>
                                    }
                                </select>
                            </label>
                            <span>@CurrentLedgerPage / @LedgerTotalPages</span>
                            <button type="button" @onclick="NextLedgerPage" disabled="@(CurrentLedgerPage >= LedgerTotalPages)">Next</button>
                        </div>
                        <div class="table-footer-spacer" aria-hidden="true"></div>
                    </div>
                }
            </section>

            <aside class="entry-form-card">
                <div class="section-head ds-card-header">
                    <div>
                        <span class="section-tag">Entry manual</span>
                        <h2>Tambah mutasi cepat</h2>
                        <p>Composer singkat untuk biaya kecil, pemasukan tambahan, atau koreksi manual yang tidak masuk dari modul lain.</p>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(_message))
                {
                    <div class="form-message">@_message</div>
                }

                <EditForm Model="_formModel" OnValidSubmit="SubmitAsync">
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="direction-row">
                        <span class="field-label">Tipe transaksi</span>
                        <div class="method-row">
                            <button type="button" class="method-chip @(_formModel.Direction == LedgerEntryDirection.Income ? "active" : null)" @onclick="() => SelectDirection(LedgerEntryDirection.Income)">Pemasukan</button>
                            <button type="button" class="method-chip @(_formModel.Direction == LedgerEntryDirection.Expense ? "active" : null)" @onclick="() => SelectDirection(LedgerEntryDirection.Expense)">Pengeluaran</button>
                        </div>
                    </div>

                    <div class="form-grid compact-grid">
                        <label class="wide-field">
                            <span>Judul transaksi</span>
                            <InputText @bind-Value="_formModel.Title" />
                        </label>

                        <label>
                            <span>Nominal</span>
                            <InputNumber @bind-Value="_formModel.Amount" />
                        </label>

                        <label>
                            <span>Tanggal & jam</span>
                            <input type="datetime-local" value="@FormatDateTimeLocal(_formModel.OccurredAt)" @onchange="OnOccurredAtChanged" />
                        </label>

                        <label class="wide-field">
                            <span>Pihak terkait</span>
                            <InputText @bind-Value="_formModel.Counterparty" />
                        </label>
                    </div>

                    <details class="bookkeeping-assistant-disclosure">
                        <summary>
                            <div class="disclosure-copy">
                                <small>Bantuan AI</small>
                                <strong>Rapikan draft entry</strong>
                                <span>@(GeminiBookkeepingAssistantService.IsConfigured ? "Gunakan hanya saat draft perlu dirapikan cepat." : "Aktifkan Gemini jika ingin bantuan merapikan draft.")</span>
                            </div>
                            <span class="disclosure-state">Buka</span>
                        </summary>

                        <div class="disclosure-panel">
                            <div class="assistant-toolbar">
                                <span class="status-chip">@(GeminiBookkeepingAssistantService.IsConfigured ? "Gemini aktif" : "Gemini belum aktif")</span>
                                <button type="button" class="ghost-button" disabled="@_isBookkeepingAiDraftLoading" @onclick="AnalyzeBookkeepingDraftAsync">
                                    @(_isBookkeepingAiDraftLoading ? "Menganalisa..." : "Analisa Draft")
                                </button>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(_bookkeepingAiDraftMessage))
                            {
                                <div class="form-message bookkeeping-ai-message">@_bookkeepingAiDraftMessage</div>
                            }

                            @if (_bookkeepingAiDraftSuggestion is not null)
                            {
                                <article class="bookkeeping-ai-suggestion">
                                    <div class="table-primary">
                                        <small>@_bookkeepingAiDraftSuggestion.SuggestedCategory</small>
                                        <strong>@_bookkeepingAiDraftSuggestion.SuggestedTitle</strong>
                                        <span>@_bookkeepingAiDraftSuggestion.Reason</span>
                                    </div>

                                    <div class="bookkeeping-ai-chip-list">
                                        <span>@(_bookkeepingAiDraftSuggestion.SuggestedDirection == LedgerEntryDirection.Income ? "Pemasukan" : "Pengeluaran")</span>
                                        <span>@(string.IsNullOrWhiteSpace(_bookkeepingAiDraftSuggestion.SuggestedCounterparty) ? "Tanpa pihak" : _bookkeepingAiDraftSuggestion.SuggestedCounterparty)</span>
                                    </div>

                                    <div class="form-actions bookkeeping-ai-actions">
                                        <button type="button" class="ghost-button" @onclick="ApplyBookkeepingAiDraftSuggestion">Pakai Saran AI</button>
                                    </div>
                                </article>
                            }
                        </div>
                    </details>

                    <div class="composer-footnote">
                        Entry manual akan langsung masuk ke ledger dan mempengaruhi saldo berjalan saat disimpan.
                    </div>

                    <div class="form-actions">
                        <button type="button" class="ghost-button" @onclick="ResetForm">Reset</button>
                        <button type="submit" class="primary-button">Simpan Entry</button>
                    </div>
                </EditForm>
            </aside>
        </div>
    }
</section>

@code {
    private BookkeepingSnapshot? _snapshot;
    private static readonly int[] GridDisplayOptions = [8, 12, 20, 50];
    private bool _isLoading = true;
    private string _statusMessage = "Memuat pembukuan...";
    private string _message = string.Empty;
    private int _ledgerDisplayCount = 12;
    private int _ledgerPage = 1;
    private bool _isBookkeepingAiDraftLoading;
    private string _bookkeepingAiDraftMessage = string.Empty;
    private BookkeepingAiDraftSuggestion? _bookkeepingAiDraftSuggestion;
    private ManualLedgerEntryRequest _formModel = new()
    {
        Direction = LedgerEntryDirection.Expense,
        OccurredAt = DateTime.Now
    };

    private int LedgerTotalPages => CalculateTotalPages(_snapshot?.Items.Count ?? 0, _ledgerDisplayCount);
    private int CurrentLedgerPage => ClampPage(_ledgerPage, LedgerTotalPages);
    private IReadOnlyList<BookkeepingListItem> VisibleLedgerItems
        => (_snapshot?.Items ?? Array.Empty<BookkeepingListItem>())
            .Skip((CurrentLedgerPage - 1) * _ledgerDisplayCount)
            .Take(_ledgerDisplayCount)
            .ToArray();

    protected override async Task OnInitializedAsync()
    {
        Store.Changed += HandleStoreChanged;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _snapshot = await BookkeepingService.GetSnapshotAsync();
        _ledgerPage = CurrentLedgerPage;
        _statusMessage = _snapshot.TotalEntries == 0
            ? "Ledger masih kosong"
            : $"{_snapshot.TotalEntries} entry tercatat";
        _isLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task AnalyzeBookkeepingDraftAsync()
    {
        _isBookkeepingAiDraftLoading = true;
        _bookkeepingAiDraftMessage = string.Empty;

        try
        {
            var result = await GeminiBookkeepingAssistantService.AnalyzeManualDraftAsync(new BookkeepingAiDraftRequest(
                _formModel.Title,
                _formModel.Direction,
                _formModel.Amount,
                _formModel.Counterparty,
                _formModel.Notes));

            _bookkeepingAiDraftMessage = result.Message;
            _bookkeepingAiDraftSuggestion = result.Success ? result.Suggestion : null;
        }
        finally
        {
            _isBookkeepingAiDraftLoading = false;
        }
    }

    private void ApplyBookkeepingAiDraftSuggestion()
    {
        if (_bookkeepingAiDraftSuggestion is null)
        {
            return;
        }

        _formModel.Direction = _bookkeepingAiDraftSuggestion.SuggestedDirection;
        _formModel.Title = _bookkeepingAiDraftSuggestion.SuggestedTitle;
        _formModel.Counterparty = _bookkeepingAiDraftSuggestion.SuggestedCounterparty;
        _formModel.Notes = _bookkeepingAiDraftSuggestion.SuggestedNotes;
        _bookkeepingAiDraftMessage = $"Saran AI diterapkan ke draft. Kategori rekomendasi: {_bookkeepingAiDraftSuggestion.SuggestedCategory}.";
    }

    private void OnLedgerDisplayCountChanged(ChangeEventArgs args)
    {
        _ledgerDisplayCount = ParseDisplayCount(args.Value?.ToString(), _ledgerDisplayCount);
        _ledgerPage = 1;
    }

    private void OnLedgerPageChanged(ChangeEventArgs args)
        => _ledgerPage = ParsePage(args.Value?.ToString(), CurrentLedgerPage, LedgerTotalPages);

    private void PrevLedgerPage()
        => _ledgerPage = Math.Max(1, CurrentLedgerPage - 1);

    private void NextLedgerPage()
        => _ledgerPage = Math.Min(LedgerTotalPages, CurrentLedgerPage + 1);

    private void SelectDirection(LedgerEntryDirection direction)
        => _formModel.Direction = direction;

    private void OnOccurredAtChanged(ChangeEventArgs args)
        => _formModel.OccurredAt = ParseDateTimeLocal(args.Value?.ToString(), _formModel.OccurredAt == default ? DateTime.Now : _formModel.OccurredAt);

    private async Task SubmitAsync()
    {
        var result = await BookkeepingService.AddManualEntryAsync(_formModel);
        _message = result.Message;
        if (!result.Success)
        {
            return;
        }

        ResetForm();
        await LoadAsync();
    }

    private void ResetForm()
    {
        _formModel = new ManualLedgerEntryRequest
        {
            Direction = LedgerEntryDirection.Expense,
            OccurredAt = DateTime.Now
        };
        _bookkeepingAiDraftSuggestion = null;
        _bookkeepingAiDraftMessage = string.Empty;
    }

    private static string FormatCurrency(decimal value)
        => string.Create(new CultureInfo("id-ID"), $"Rp {value:N0}");

    private static string FormatDateTimeLocal(DateTime value)
        => value.ToString("yyyy-MM-ddTHH:mm", CultureInfo.InvariantCulture);

    private static DateTime ParseDateTimeLocal(string? value, DateTime fallback)
        => DateTime.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out var parsed)
            ? parsed
            : fallback;

    private static int ParseDisplayCount(string? value, int fallback)
        => int.TryParse(value, out var parsed) && parsed > 0 ? parsed : fallback;

    private static int ParsePage(string? value, int fallback, int totalPages)
        => int.TryParse(value, out var parsed) && parsed > 0
            ? Math.Min(parsed, Math.Max(1, totalPages))
            : fallback;

    private static int CalculateTotalPages(int totalItems, int pageSize)
        => Math.Max(1, (int)Math.Ceiling(totalItems / (double)Math.Max(1, pageSize)));

    private static int ClampPage(int page, int totalPages)
        => Math.Min(Math.Max(1, page), Math.Max(1, totalPages));

    private async void HandleStoreChanged()
        => await InvokeAsync(LoadAsync);

    public ValueTask DisposeAsync()
    {
        Store.Changed -= HandleStoreChanged;
        return ValueTask.CompletedTask;
    }
}
