@using Hpp_Ultimate.Domain

<article class="summary-card tone-@Metric.Tone">
    <div class="summary-head">
        <span>@Metric.Title</span>
        <small class="@GetTrendClass()">@Metric.DeltaText</small>
    </div>

    <strong>@Metric.Value</strong>
    <p>@Metric.Subtitle</p>
</article>

@code {
    [Parameter, EditorRequired] public DashboardMetric Metric { get; set; } = default!;

    private string GetTrendClass() => Metric.Trend switch
    {
        TrendDirection.Up => "trend-up",
        TrendDirection.Down => "trend-down",
        _ => "trend-neutral"
    };
}
