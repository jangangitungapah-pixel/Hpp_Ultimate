@using System.Globalization
@using Hpp_Ultimate.Domain

<section class="chart-card">
    <div class="chart-head">
        <div>
            <span>@Title</span>
            <h2>@Subtitle</h2>
        </div>
    </div>

    <div class="donut-layout">
        <div class="donut-shell">
            <div class="donut-chart" style="@DonutStyle">
                <div class="donut-center">
                    <small>Total</small>
                    <strong>@TotalValue</strong>
                </div>
            </div>
        </div>

        <div class="donut-legend">
            @foreach (var item in Items)
            {
                <article>
                    <span class="swatch" style="@($"background:{GetColor(item.Tone)}")"></span>
                    <div>
                        <strong>@item.Label</strong>
                        <small>@string.Create(new CultureInfo("id-ID"), $"Rp {item.Amount:N0}")</small>
                    </div>
                    <em>@item.Percentage.ToString("0.0")%</em>
                </article>
            }
        </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Subtitle { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string TotalValue { get; set; } = string.Empty;
    [Parameter, EditorRequired] public IReadOnlyList<CostBreakdownItem> Items { get; set; } = Array.Empty<CostBreakdownItem>();

    private string DonutStyle
    {
        get
        {
            if (Items.Count == 0)
            {
                return "background: conic-gradient(#e2e8f0 0 100%);";
            }

            decimal start = 0;
            var segments = new List<string>();

            foreach (var item in Items)
            {
                var end = start + item.Percentage;
                segments.Add($"{GetColor(item.Tone)} {start.ToString("0.##", CultureInfo.InvariantCulture)}% {end.ToString("0.##", CultureInfo.InvariantCulture)}%");
                start = end;
            }

            if (start < 100m)
            {
                segments.Add($"#e2e8f0 {start.ToString("0.##", CultureInfo.InvariantCulture)}% 100%");
            }

            return $"background: conic-gradient({string.Join(", ", segments)});";
        }
    }

    private static string GetColor(string tone) => tone switch
    {
        "accent" => "#f97316",
        "ocean" => "#0ea5e9",
        "warning" => "#facc15",
        "success" => "#22c55e",
        _ => "#94a3b8"
    };
}
